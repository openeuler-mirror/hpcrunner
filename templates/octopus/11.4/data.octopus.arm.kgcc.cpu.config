[SERVER]
11.11.11.11

[DOWNLOAD]
octopus/11.4 https://octopus-code.org/download/11.4/octopus-11.4.tar.gz octopus-11.4.tar.gz

[DEPENDENCY]
sudo yum install fftw3-devel fftw3-mpi-devel
module purge
./jarvis -install kgcc/9.3.1 com
module use ./software/modulefiles
module load kgcc/9.3.1
export CC=`which gcc`
export CXX=`which g++`
export FC=`which gfortran`
./jarvis -install hmpi/1.1.1 gcc
./jarvis -install gsl/2.6 gcc
./jarvis -install lapack/3.10.1 gcc
./jarvis -install libxc/4.3.4 gcc
./jarvis -install blas/3.10.0 gcc
module load hmpi/1.1.1
export CC=`which mpicc`
export CXX=`which mpicxx`
export FC=`which mpifort`
module load kgcc/9.3.1
module load lapack/3.10.1
module load gsl/2.6
module load libxc/4.3.4
module load hmpi/1.1.1
module load blas/3.10.0
module use ./software/moduledeps/kgcc9.3.1-hmpi1.1.1
./jarvis -install fftw/3.3.8  gcc+mpi
module load fftw/3.3.8
./jarvis -install libvdwxc/0.4.0  gcc+mpi
tar -xvf ${JARVIS_DOWNLOAD}/octopus-11.4.tar.gz

[ENV]
module purge
module use ${JARVIS_ROOT}/software/modulefiles
module load kgcc/9.3.1
module load lapack/3.10.1
module load gsl/2.6
module load libxc/4.3.4
module load hmpi/1.1.1
module load blas/3.10.0
module use ${JARVIS_ROOT}/software/moduledeps/kgcc9.3.1-hmpi1.1.1
#module load libvdwxc/0.4.0
module load fftw/3.3.8

[APP]
app_name = octopus
build_dir = ${JARVIS_ROOT}/octopus-11.4
binary_dir = ${JARVIS_ROOT}/software/apps/octopus/11.4 
case_dir =

[BUILD]
./configure CC=mpicc CXX=mpicxx FC=mpifort \
--prefix=${JARVIS_ROOT}/software/apps/octopus/11.4 \
CFLAGS='-lgfortran'  \
FCFLAGS=' -lgfortran' \
--with-gsl-prefix==${JARVIS_LIBS}/kgcc9.3.1/gsl/2.6 \
--with-libxc-prefix=${JARVIS_LIBS}/kgcc9.3.1/libxc/4.3.4 \
--with-fftw-prefix=${JARVIS_LIBS}/kgcc9.3.1-hmpi1.1.1/fftw/3.3.8 \
--with-blas=${JARVIS_LIBS}/kgcc9.3.1/blas/3.10.0/lib/libblas.so \
--with-lapack=${JARVIS_LIBS}/kgcc9.3.1/lapack/3.10.1/lib/liblapack.so \
--enable-mpi 

patch -p0 < ${JARVIS_ROOT}/templates/octopus/11.4/cuda.F90.patch
patch -p0 < ${JARVIS_ROOT}/templates/octopus/11.4/run.F90.patch
patch -p0 < ${JARVIS_ROOT}/templates/octopus/11.4/accel_inc.F90.patch
sed -i '273d' src/main/run.F90

make -j
make install


[RUN]
run = ${JARVIS_ROOT}/software/apps/octopus/11.4/bin/octopus --version
binary =
nodes = 1

