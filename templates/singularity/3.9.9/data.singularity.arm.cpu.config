[SERVER]
11.11.11.11

[DOWNLOAD]


[DEPENDENCY]
./jarvis -install go/1.18 com

[ENV]
module use ./software/modulefiles
module purge
module load go/1.18

[APP]
app_name = singularity
build_dir = ${JARVIS_ROOT}
binary_dir = ${JARVIS_UTILS}/singularity/3.9.9/bin
case_dir =

[BUILD]
./jarvis -install singularity/3.9.9 any

[RUN]
run = 
binary = singularity --version
nodes = 1

