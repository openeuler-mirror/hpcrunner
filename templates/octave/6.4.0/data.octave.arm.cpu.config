[SERVER]
11.11.11.11

[DOWNLOAD]
octave/6.4.0 https://ftp.gnu.org/gnu/octave/octave-6.4.0.tar.gz

[DEPENDENCY]
set -e
yum install pcre-devel -y
module purge
./jarvis -install hpckit/${HPCKIT_VERSION} any
module use ./software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles
module load gcc/compiler12.3.1/gccmodule

[ENV]
module purge
module use ./software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles
module load gcc/compiler12.3.1/gccmodule

[APP]
app_name = octave
build_dir = ${JARVIS_ROOT}
binary_dir = ./software/apps/bisheng/octave/6.4.0
case_dir =

[BUILD]
cd ${JARVIS_TMP}
rm -rf octave-6.4.0
tar -xvf ${JARVIS_DOWNLOAD}/octave-6.4.0.tar.gz
cd octave-6.4.0
./configure --prefix=${JARVIS_ROOT}/software/apps/bisheng/octave/6.4.0/ --disable-readline
make -j
make install

[RUN]
run =
binary =
nodes = 1

