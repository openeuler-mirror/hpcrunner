[SERVER]
11.11.11.11

[DOWNLOAD]
octave/6.4.0 https://ftp.gnu.org/gnu/octave/octave-6.4.0.tar.gz

[DEPENDENCY]
set -e
yum install pcre-devel -y
module purge
./jarvis -install hpckit/${HPCKIT_VERSION} any
module use ${JARVIS_ROOT}/software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles
GCC_VERSION=`ls software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles/gcc|grep compiler|awk -F "compiler" '{print $2}'`
module load gcc/compiler${GCC_VERSION}/gccmodule
./jarvis -install lapack/3.8.0 gcc
./jarvis -install blas/3.10.0 gcc
module use ${JARVIS_ROOT}/software/moduledeps/gcc${GCC_VERSION}
module load blas/3.10.0
module load lapack/3.8.0


[ENV]
module purge
module use ${JARVIS_ROOT}/software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles
GCC_VERSION=`ls software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles/gcc|grep compiler|awk -F "compiler" '{print $2}'`
module load gcc/compiler${GCC_VERSION}/gccmodule
module use ./software/moduledeps/gcc${GCC_VERSION}
module load blas/3.10.0
module load lapack/3.8.0

[APP]
app_name = octave
build_dir = ${JARVIS_TMP}
binary_dir = ${JARVIS_ROOT}/software/apps/gcc${GCC_VERSION}/octave/6.4.0/bin
case_dir =

[BUILD]
cd ${JARVIS_TMP}
rm -rf octave-6.4.0
tar -xvf ${JARVIS_DOWNLOAD}/octave-6.4.0.tar.gz
cd octave-6.4.0
./configure --prefix=${JARVIS_ROOT}/software/apps/gcc${GCC_VERSION}/octave/6.4.0/ --disable-readline --with-blas=$BLAS_PATH/lib/libblas.so --with-lapack=$LAPACK_PATH/lib/liblapack.so LDFLAGS="-L$BLAS_PATH/lib -lblas -L$LAPACK_PATH/lib -llapack"
make -j $(nproc)
make install

[RUN]
run = ${JARVIS_ROOT}/software/apps/gcc${GCC_VERSION}/octave/6.4.0/bin/octave --version
binary = octave
nodes = 1

