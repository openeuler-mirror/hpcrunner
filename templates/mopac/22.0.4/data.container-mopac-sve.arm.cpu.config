[SERVER]
11.11.11.11

[DOWNLOAD]
mopac/22.0.4 https://github.com/openmopac/mopac/archive/refs/tags/v22.0.4.tar.gz


[DEPENDENCY]
export CC=mpicc CXX=mpicxx FC=mpifort
./jarvis -install hpckit/${HPCKIT_VERSION} any
module use ${JARVIS_ROOT}/software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles
module add bisheng/compiler${BISHENG_VERSION}/bishengmodule bisheng/hmpi${HMPI_VERSION}/release
./jarvis -install package/lapack/3.8.0/bisheng/ bisheng
module use ${JARVIS_ROOT}/software/moduledeps/bisheng${BISHENG_VERSION}
module add lapack-bisheng/3.8.0
export LAPACK_PATH=$LAPACK_BISHENG_PATH
export CFLAGS="-Wno-implicit-function-declaration"
./jarvis -install package/openblas/0.3.14 bisheng+mpi
module use ${JARVIS_ROOT}/software/moduledeps/bisheng${BISHENG_VERSION}-hmpi${HMPI_VERSION}
module add openblas/0.3.14

[ENV]
module use ${JARVIS_ROOT}/software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles
module purge
module add bisheng/compiler${BISHENG_VERSION}/bishengmodule bisheng/hmpi${HMPI_VERSION}/release
export CC=mpicc CXX=mpicxx FC=mpifort
module use ${JARVIS_ROOT}/software/moduledeps/bisheng${BISHENG_VERSION}
module add lapack-bisheng/3.8.0
export LAPACK_PATH=$LAPACK_BISHENG_PATH
export CFLAGS="-Wno-implicit-function-declaration"
module use ${JARVIS_ROOT}/software/moduledeps/bisheng${BISHENG_VERSION}-hmpi${HMPI_VERSION}
module add openblas/0.3.14
export PATH=${JARVIS_ROOT}/software/apps/bisheng${BISHENG_VERSION}-hmpi${HPCKIT_VERSION}/mopac/22.0.4/bin:$PATH
export LD_LIBRARY_PATH=${JARVIS_ROOT}/software/apps/bisheng${BISHENG_VERSION}-hmpi${HPCKIT_VERSION}/mopac/22.0.4/lib64:$LD_LIBRARY_PATH


[APP]
app_name = mopac
build_dir = ${JARVIS_ROOT}/tmp
binary_dir = ${JARVIS_ROOT}/software/apps/bisheng${BISHENG_VERSION}-hmpi${HPCKIT_VERSION}/mopac/22.0.4/bin
case_dir = ${JARVIS_ROOT}/software/apps/bisheng${BISHENG_VERSION}-hmpi${HPCKIT_VERSION}/mopac/22.0.4/tests

[BUILD]
cd ${JARVIS_ROOT}/tmp
rm mopac-22.0.4 -rf
tar -xf ${JARVIS_DOWNLOAD}/v22.0.4.tar.gz
cd mopac-22.0.4
mkdir build && cd build
export CC=mpicc FC=mpifort CXX=mpicxx
cmake -DCMAKE_INSTALL_PREFIX=${JARVIS_ROOT}/software/apps/bisheng${BISHENG_VERSION}-hmpi${HPCKIT_VERSION}/mopac/22.0.4 -DCMAKE_C_FLAGS="-mcpu=hip09 -mllvm -force-customized-pipeline=true" -DCMAKE_Fortran_FLAGS="-mcpu=hip09 -mllvm -force-customized-pipeline=true" ..
make -j
make install
cp ../tests -r ${JARVIS_ROOT}/software/apps/bisheng${BISHENG_VERSION}-hmpi${HPCKIT_VERSION}/mopac/22.0.4


[RUN]
run =  
binary = mopac
nodes = 1
