[SERVER]
11.11.11.11

[DOWNLOAD]
Code_Saturne/7.0.6 https://github.com/code-saturne/code_saturne/archive/refs/tags/v7.0.6.tar.gz


[DEPENDENCY]
yum install automake libtool xz -y
yum install python3-qt5 cmake patch -y
module purge
./jarvis -install hpckit/${HPCKIT_VERSION} any
module use ${JARVIS_ROOT}/software/modulefiles
module load hpckit25.1.0/bisheng/compiler${BISHENG_VERSION}/bishengmodule  hpckit25.1.0/bisheng/hmpi${HMPI_VERSION}/release
./jarvis -install package/hdf5/1.10.3/clang/ bisheng+mpi
module use ./software/moduledeps/bisheng${BISHENG_VERSION}-hmpi${HMPI_VERSION}
module load hdf5-clang/1.10.3
export HDF5_DIR=${HDF5_CLANG_PATH}
./jarvis -install package/med/4.0.0/ bisheng+mpi
module load med/4.0.0
./jarvis -install package/scotch/6.0.9 bisheng+mpi
module load scotch/6.0.9
./jarvis -install package/metis/5.1.0 bisheng+mpi
module load metis/5.1.0

[ENV]
module purge
module use ${JARVIS_ROOT}/software/modulefiles
module load hpckit25.1.0/bisheng/compiler${BISHENG_VERSION}/bishengmodule  hpckit25.1.0/bisheng/hmpi${HMPI_VERSION}/release
module use ${JARVIS_ROOT}/software/moduledeps/bisheng${BISHENG_VERSION}-hmpi${HMPI_VERSION}
module load hdf5-clang/1.10.3
export HDF5_DIR=${HDF5_CLANG_PATH}
export CC=mpicc FC=mpifort CXX=mpicxx
module load med/4.0.0
module load scotch/6.0.9
module load metis/5.1.0
module load hpckit25.1.0/bisheng/kml${HMPI_VERSION}/kblas/multi
export PATH=${JARVIS_ROOT}/software/apps/bisheng{BISHENG_VERSION}-hmpi${HMPI_VERSION}/Code_Saturne/7.0.6/bin:$PATH
export KML_BLAS_THREAD_TYPE=OMP
export CS_MPIEXEC_OPTIONS="--allow-run-as-root --mca btl ^openib"

[APP]
app_name = Code_Saturne
build_dir = ${JARVIS_TMP}
binary_dir = ${JARVIS_ROOT}/software/apps/bisheng${BISHENG_VERSION}-hmpi${HMPI_VERSION}/Code_Saturne/7.0.6/bin
case_dir =${JARVIS_ROOT}/workloads/Code_Saturne

[BUILD]
rm code_saturne-7.0.6 -rf
tar -xvf ${JARVIS_DOWNLOAD}/v7.0.6.tar.gz
cd code_saturne-7.0.6
cd src/comb/
patch -p0 < ${JARVIS_ROOT}/templates/Code_Saturne/7.0.6/cplym1.patch
sed -i "s/#/\!#/g" cppdfr.f90
cd -
./sbin/bootstrap
CC=mpicc FC=mpifort CXX=mpicxx ./configure  --prefix=${JARVIS_ROOT}/software/apps/bisheng${BISHENG_VERSION}-hmpi${HMPI_VERSION}/Code_Saturne/7.0.6 --with-blas-lib=${JARVIS_UTILS}/hpckit/${HPCKIT_VERSION}/HPCKit/latest/kml/bisheng/lib/${kp}/kblas/multi --with-hdf5=${HDF5_CLANG_PATH} --with-scotch=${SCOTCH_PATH} --with-metis=${METIS_PATH} --with-med=${MED_PATH} --enable-shared --with-mpi CXXFLAGS="-O3 -std=c++11 -march=armv8.2-a -mtune=tsv110 -mcpu=hip09  -mllvm -force-customized-pipeline=true"
make -j 32
make install
mkdir -p ${JARVIS_ROOT}/workloads/Code_Saturne

[RUN]
run = rm -rf ${JARVIS_ROOT}/workloads/Code_Saturne/test && code_saturne create -s test -c case1 && cp ${JARVIS_TMP}/code_saturne-7.0.6/examples/2-full_domain/mesh/* ${JARVIS_ROOT}/workloads/Code_Saturne/test/MESH -rf && cp ${JARVIS_TMP}/code_saturne-7.0.6/examples/1-simple_junction/mesh/*  ${JARVIS_ROOT}/workloads/Code_Saturne/test/MESH -rf && cp ${JARVIS_TMP}/code_saturne-7.0.6/examples/1-simple_junction/case1/setup.xml ${JARVIS_ROOT}/workloads/Code_Saturne/test/case1/DATA -rf &&
binary = code_saturne run -n 8 --nt=1 --param=${JARVIS_ROOT}/workloads/Code_Saturne/test/case1/DATA/setup.xml --case=${JARVIS_ROOT}/workloads/Code_Saturne/test/case1
nodes = 1

