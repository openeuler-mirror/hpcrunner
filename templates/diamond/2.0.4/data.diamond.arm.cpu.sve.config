[SERVER]
11.11.11.11

[DOWNLOAD]
diamond/2.0.4 $JARVIS_PROXY/bbuchfink/diamond/archive/v2.0.4.tar.gz diamond-2.0.4.tar.gz
swissprot http://ftp.ncbi.nlm.nih.gov/blast/db/FASTA/swissprot.gz swissprot.gz
human_g1k_v37 http://ftp.1000genomes.ebi.ac.uk/vol1/ftp/technical/reference/human_g1k_v37.fasta.gz human_g1k_v37.fasta.gz

[DEPENDENCY]
set -e
set -x

module purge
./jarvis -install hpckit/${HPCKIT_VERSION} any

cd ${JARVIS_TMP}
rm -rf diamond-2.0.4
tar -xvzf ${JARVIS_DOWNLOAD}/diamond-2.0.4.tar.gz

[ENV]
module purge
module use ${JARVIS_ROOT}/software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles
module load bisheng/compiler${BISHENG_VERSION}/bishengmodule


[APP]
app_name = diamond
build_dir = ${JARVIS_TMP}/diamond-2.0.4
binary_dir = ${JARVIS_ROOT}/software/apps/bisheng${BISHENG_VERSION}/diamond/2.0.4/sve/bin/
case_dir = ${JARVIS_TMP}/diamond-2.0.4/examples

[BUILD]
mkdir build install examples
cd build
cmake -DCMAKE_INSTALL_PREFIX=${JARVIS_ROOT}/software/apps/bisheng${BISHENG_VERSION}/diamond/2.0.4/sve \
        -DCMAKE_CXX_FLAGS="-O3 -g -mcpu=hip09  -mllvm -force-customized-pipeline=true" \
        ../
make -j
make install

cd ../examples
gzip -dkcv ${JARVIS_DOWNLOAD}/human_g1k_v37.fasta.gz > human_g1k_v37.fasta
gzip -dkcv ${JARVIS_DOWNLOAD}/swissprot.gz > swissprot

[CLEAN]
cd build
make clean

[RUN]
#run = time -p numactl -C 0-113
#binary = diamond blastp -p 114 -q human_g1k_v37.fasta -d swissprot -o out.tsv --very-sensitive
run = time -p 
binary = diamond blastp -p $(nproc) -q human_g1k_v37.fasta -d swissprot -o out.tsv --very-sensitive
nodes = 1

