[SERVER]
11.11.11.11

[DOWNLOAD]
palabos/2.1 https://gitlab.com/unigespc/palabos/-/archive/v2.1r0/palabos-v2.1r0.zip palabos-v2.1r0.zip

[DEPENDENCY]
yum install -y ImageMagick
./jarvis -install hpckit/${HPCKIT_VERSION} any
module use ${JARVIS_ROOT}/software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles
module purge
module add bisheng/compiler${BISHENG_VERSION}/bishengmodule bisheng/hmpi${HMPI_VERSION}/release

./jarvis -install cmake/3.23.1 clang
module use ${JARVIS_ROOT}/software/moduledeps/bisheng${BISHENG_VERSION}
module load cmake/3.23.1

[ENV]
module use ${JARVIS_ROOT}/software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles
module purge
module add bisheng/compiler${BISHENG_VERSION}/bishengmodule bisheng/hmpi${HMPI_VERSION}/release
module use ${JARVIS_ROOT}/software/moduledeps/bisheng${BISHENG_VERSION}
module load cmake/3.23.1
export PMIX_INSTALL_PREFIX=${OPAL_PREFIX}
export PATH=${JARVIS_ROOT}/software/apps/bisheng${BISHENG_VERSION}-hmpi${HMPI_VERSION}/palabos/v2.1r0/examples/showCases/cavity2d:$PATH
export PATH=${JARVIS_ROOT}/software/apps/bisheng${BISHENG_VERSION}-hmpi${HMPI_VERSION}/palabos/v2.1r0/examples/showCases/boussinesqThermal3d:$PATH

[APP]
app_name = palabos
build_dir = ${JARVIS_TMP}
binary_dir = ${JARVIS_ROOT}/software/apps/bisheng${BISHENG_VERSION}-hmpi${HMPI_VERSION}/palabos/v2.1r0
case_dir = ${JARVIS_ROOT}/software/apps/bisheng${BISHENG_VERSION}-hmpi${HMPI_VERSION}/palabos/v2.1r0/examples/showCases/cavity2d

[BUILD]
set -e
set -x
cd ${JARVIS_TMP}
rm palabos-v2.1r0 -rf
unzip ${JARVIS_DOWNLOAD}/palabos-v2.1r0.zip
cd palabos-v2.1r0
cd examples/showCases/cavity2d
make -j 2>&1 |tee make.log
cd ${JARVIS_TMP}/palabos-v2.1r0/examples/showCases/boussinesqThermal3d
make -j 2>&1 |tee make.log
cd ${JARVIS_TMP}/palabos-v2.1r0/examples/benchmarks/cavity3d
sed -n "s|sed::max( (plint)3|std:max( (plint)1000|p" ./cavity3d.cpp
sed -i "s|sed::max( (plint)3|std:max( (plint)1000|" ./cavity3d.cpp
make -j$(nproc) 2>&1 |tee make$(nproc).log
make -j1 2>&1 |tee make1.log

mkdir -p ${JARVIS_ROOT}/software/apps/bisheng${BISHENG_VERSION}-hmpi${HMPI_VERSION}/palabos/v2.1r0
mv ${JARVIS_TMP}/palabos-v2.1r0/* ${JARVIS_ROOT}/software/apps/bisheng${BISHENG_VERSION}-hmpi${HMPI_VERSION}/palabos/v2.1r0

[RUN]
run = time -p mpirun  --allow-run-as-root -mca pml ucx -mca btl tcp -x UCX_TLS=sm,tcp -np $(nproc)
binary = examples/benchmarks/cavity3d/cavity3d 6
nodes = 1

