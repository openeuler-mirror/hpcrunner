[SERVER]
11.11.11.11

[DOWNLOAD]
ncview/2.1.7 https://src.fedoraproject.org/repo/pkgs/ncview/ncview-2.1.7.tar.gz/debd6ca61410aac3514e53122ab2ba07/ncview-2.1.7.tar.gz

[DEPENDENCY]
set -x
set -e
. $CHECK_ROOT && cmake yum install libX11 libX11-devel libXaw libXaw-devel libpng-devel libpng curl curl-devel zlib zlib-devel libXt-devel xorg-x11-xauth xorg-x11-server-utils xorg-x11-server-Xnest libXtst -y
module purge
./jarvis -install hpckit/${HPCKIT_VERSION} any
module use ./software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles
module add bisheng/compiler${BISHENG_VERSION}/bishengmodule
module add bisheng/hmpi${HPCKIT_VERSION}/release
export CC=`which mpicc`
export CXX=`which mpicxx`
export FC=`which mpifort`
export F77=`which mpifort`
./jarvis -install hdf5/1.10.1/clang clang+mpi
module use ./software/moduledeps/bisheng${BISHENG_VERSION}-hmpi${HPCKIT_VERSION}
module add hdf5-clang/1.10.1
./jarvis -install pnetcdf/1.12.3 clang+mpi
module add pnetcdf/1.12.3
./jarvis -install netcdf/4.7.0/clang clang+mpi
module add netcdf-clang/4.7.0
export CC=`which clang`
export CXX=`which clang++`
export FC=`which flang`
./jarvis -install udunits/2.2.28 clang
module use software/moduledeps/bisheng${BISHENG_VERSION}
module add udunits/2.2.28
./jarvis -install libexpat/r-2.4.7 clang
module add libexpat/r-2.4.7

[ENV]
module purge
module use ./software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles
module add bisheng/compiler${BISHENG_VERSION}/bishengmodule
module add bisheng/hmpi${HPCKIT_VERSION}/release
module use ./software/moduledeps/bisheng${BISHENG_VERSION}-hmpi${HPCKIT_VERSION}
module add hdf5-clang/1.10.1
module add pnetcdf/1.12.3
module add netcdf-clang/4.7.0
module use software/moduledeps/bisheng${BISHENG_VERSION}
module add udunits/2.2.28
module add libexpat/r-2.4.7
export PATH=${JARVIS_ROOT}/software/apps/bisheng/ncview/2.1.5/bin:$PATH
mkdir -p ${JARVIS_ROOT}/case/ncview
export CC=`which mpicc`
export CXX=`which mpicxx`
export FC=`which mpifort`
export F77=`which mpifort`

[APP]
app_name = ncview
build_dir = ${JARVIS_ROOT}
binary_dir = ${JARVIS_ROOT}/software/apps/bisheng/ncview/2.1.7/bin
case_dir = ${JARVIS_ROOT}/case/ncview

[BUILD]
./jarvis -install ncview/2.1.7 clang+mpi
mkdir -p ${JARVIS_ROOT}/case/ncview
cd ${JARVIS_ROOT}/case/ncview
if [ ! -f "ref_nccopy3_subset.nc" ];then
 tar xf ${JARVIS_DOWNLOAD}/netcdf-c-4.7.0.tar.gz
 mv netcdf-c-4.7.0/ncdump/ref_nccopy3_subset.nc .
 rm -rf netcdf-c-4.7.0
fi
rm -rf ${JARVIS_TMP}/ncview-2.1.7

[RUN]
run =
binary = ncview ref_nccopy3_subset.nc
nodes = 1

