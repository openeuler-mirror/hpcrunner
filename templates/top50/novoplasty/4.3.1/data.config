[SERVER]
11.11.11.11

[DOWNLOAD]
novoplasty/4.3.1 https://github.com/ndierckx/NOVOPlasty/archive/refs/tags/NOVOPlasty4.3.1.tar.gz

[DEPENDENCY]
set -e
set -x

if [ ! -f "/usr/bin/perl" ]; then
    echo "error: perl must be installed"
    exit 1
fi

module purge
module use $JARVIS_MODULES/modules
./jarvis -install hpckit/2025.1.0.SPC001 any
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1/gccmodule

tar --no-same-owner -zxvf ${JARVIS_DOWNLOAD}/NOVOPlasty4.3.1.tar.gz -C ${JARVIS_DEV}
echo "done"

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1/gccmodule

[APP]
fake = 0
app_name = novoplasty
app_version = 4.3.1
compiler = gcc
build_dir = ${JARVIS_DEV}/NOVOPlasty-NOVOPlasty4.3.1
binary_dir =
case_dir = ${JARVIS_JOBSCRIPT}/novoplasty/4.3.1

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

set +x && check_install_path "${PATH_INSTALL}" && set -x
set +x && build_mod_check "${PATH_INSTALL}/bin/NOVOPlasty4.3.1.pl" "prompt" && set -x
set +x && rm_file_from_base ${PATH_INSTALL}/bin NOVOPlasty4.3.1.pl  && set -x
####### build prepare
set +x && echo_info "build prepare!!!" && set -x

####### build start
set +x && echo_info "build start" && set -x

if [ ! -d "${PATH_INSTALL}/bin" ]; then
mkdir -p ${PATH_INSTALL}/bin
fi

cp -af NOVOPlasty4.3.1.pl ${PATH_INSTALL}/bin
cp -af filter_reads.pl ${PATH_INSTALL}/bin

chmod +x ${PATH_INSTALL}/bin/NOVOPlasty4.3.1.pl
chmod +x ${PATH_INSTALL}/bin/filter_reads.pl

set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/novoplasty/4.3.1
mkdir -p ${JOBDIR}

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_bma
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=128"
#DSUB -o pytorch_out_%J.log
#DSUB -e pytorch_err_%J.log
#DSUB -T '2h'
source env.sh
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1

EOF

cat >${JOBDIR}/local_run.sh << EOF
#!/bin/bash
module purge
module use $JARVIS_MODULES/modules
module load novoplasty/4.3.1-%#MYKGCCVER#%

if [ -d "test" ]; then
rm -rf test
fi
mkdir test
cd test
cp ${JARVIS_DEV}/NOVOPlasty-NOVOPlasty4.3.1/Test\ datasets/Chloroplast\ assembly/* .
time NOVOPlasty4.3.1.pl -c config_test_chloro.txt
EOF


cat > ${JOBDIR}/novoplasty-4.3.1-run.sh << EOF
#!/bin/bash
cd ${JOBDIR}

./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/novoplasty-4.3.1-run.sh

set +x && echo_info "Install done!!!" && set -x

[RUN]
