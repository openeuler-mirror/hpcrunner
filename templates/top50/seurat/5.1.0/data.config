[SERVER]
11.11.11.11

[DOWNLOAD]
seurat/5.1.0 https://github.com/satijalab/seurat/archive/refs/tags/v5.1.0.tar.gz seurat-5.1.0.tar.gz
Matrix/1.6-4 https://cran.r-project.org/src/contrib/Archive/Matrix/Matrix_1.6-4.tar.gz

[DEPENDENCY]
set -e
set -x
module purge
module use $JARVIS_MODULES/modules
./jarvis -install cmake/3.28.2 any
module load cmake/3.28.2
./jarvis -install hpckit/2025.1.0.SPC001 any
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1/gccmodule
./jarvis -install R/4.2.0 gcc
module load R/4.2.0-%#MYKGCCVER#%
echo "done"

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1/gccmodule
module load cmake/3.28.2
module load R/4.2.0-%#MYKGCCVER#%

[APP]
fake = 1
app_name = seurat
app_version = 5.1.0
compiler = gcc
build_dir = ${JARVIS_DEV}/seurat-5.1.0
binary_dir =
case_dir = ${JARVIS_JOBSCRIPT}/seurat/5.1.0

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

####### build prepare
set +x && echo_info "build prepare!!!" && set -x

set +x && check_rpms_installed libpng-devel libpng-tools libgit2-devel \
freetype-devel libpng-devel libtiff-devel libjpeg-devel libwebp-devel

####### build start
set +x && echo_info "build start" && set -x

cat > install.R << EOF
options("repos"= c(CRAN="http://mirrors.tuna.tsinghua.edu.cn/CRAN/"))
options(BioC_mirror="http://mirrors.tuna.tsinghua.edu.cn/bioconductor/")
setwd("${JARVIS_DEV}/seurat-5.1.0")
install.packages("openssl")
install.packages("devtools")
install.packages("sp")
install.packages("${JARVIS_DOWNLOAD}/Matrix_1.6-4.tar.gz",repos = NULL, type = "source")
install.packages("SeuratObject")
library(devtools)
devtools::install_local("${JARVIS_DOWNLOAD}/seurat-5.1.0.tar.gz")
EOF
Rscript --verbose ./install.R

####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/seurat/5.1.0
mkdir -p ${JOBDIR}

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_bma
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=128"
#DSUB -o pytorch_out_%J.log
#DSUB -e pytorch_err_%J.log
#DSUB -T '2h'
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1

EOF

cat >${JOBDIR}/local_run.sh << EOF
#!/bin/bash
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1/gccmodule
module load R/4.2.0-%#MYKGCCVER#%

if [ -d "seurat-5.1.0" ]; then
rm -rf seurat-5.1.0
fi
tar --no-same-owner -zxvf ${JARVIS_DOWNLOAD}/seurat-5.1.0.tar.gz
cd seurat-5.1.0/tests
time Rscript ./testthat.R
EOF


cat > ${JOBDIR}/seurat-5.1.0-run.sh << EOF
#!/bin/bash
cd ${JOBDIR}

./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/seurat-5.1.0-run.sh

set +x && echo_info "Install done!!!" && set -x

[RUN]
