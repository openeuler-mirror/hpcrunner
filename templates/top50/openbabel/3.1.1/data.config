[SERVER]
11.11.11.11

[DOWNLOAD]
openbabel/3.1.1 https://github.com/openbabel/openbabel/archive/refs/tags/openbabel-3-1-1.tar.gz openbabel-3-1-1.tar.gz

[DEPENDENCY]
set -e
set -x

module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule

./jarvis -install eigen3/3.4.0 any
module load eigen3/3.4.0

./jarvis -install boost/1.72.0/clang clang
module load boost-clang/1.72.0-%#MYKBSVER#%

tar --no-same-owner -zxvf ${JARVIS_DOWNLOAD}/openbabel-3-1-1.tar.gz -C ${JARVIS_DEV}

echo "done"

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule
module load eigen3/3.4.0
module load boost-clang/1.72.0-%#MYKBSVER#%

[APP]
fake = 0
app_name = openbabel
app_version = 3.1.1
compiler = bisheng
build_dir = ${JARVIS_DEV}/openbabel/3.1.1
binary_dir =
case_dir = ${JARVIS_JOBSCRIPT}/openbabel/3.1.1

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

set +x && check_install_path "${PATH_INSTALL}" && set -x
set +x && build_mod_check "${PATH_INSTALL}/bin/obabel" "prompt" && set -x
set +x && rm_file_from_base ${PATH_INSTALL}/bin obabel  && set -x
####### build prepare
set +x && echo_info "build prepare!!!" && set -x

####### build start
set +x && echo_info "build start" && set -x

if [ -d "build" ]; then
rm -rf build
fi
mkdir build
cd build
cmake .. -DCMAKE_INSTALL_PREFIX=$PATH_INSTALL \
-DEIGEN3_INCLUDE_DIR=$EIGEN3_PATH/include/eigen3 \
-DBoost_INCLUDE_DIR=$BOOST_CLANG_PATH/include \
-DCMAKE_CXX_FLAGS="-fsigned-char"

make -j16
make test
make install

####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/openbabel/3.1.1
mkdir -p ${JOBDIR}

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_bma
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=128"
#DSUB -o pytorch_out_%J.log
#DSUB -e pytorch_err_%J.log
#DSUB -T '2h'
source env.sh
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1

EOF

cat >${JOBDIR}/local_run.sh << EOF
#!/bin/bash
module purge
module use $JARVIS_MODULES/modules
module load openbabel/3.1.1-%#MYKBSVER#%

if [ -d "files" ]; then
rm -rf files
fi
cp -r ${JARVIS_DEV}/openbabel-openbabel-3-1-1/test/files . -ar
cd files
time -p obabel -i cif *.cif -o cif

EOF


cat > ${JOBDIR}/openbabel-3.1.1-run.sh << EOF
#!/bin/bash
cd ${JOBDIR}

./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/openbabel-3.1.1-run.sh

set +x && echo_info "Install done!!!" && set -x

[RUN]
