[SERVER]
11.11.11.11

[DOWNLOAD]
hmmer/3.4 http://eddylab.org/software/hmmer/hmmer-3.4.tar.gz
case1 https://ftp.uniprot.org/pub/databases/uniprot/current_release/knowledgebase/complete/uniprot_sprot.fasta.gz
case2 https://www.ebi.ac.uk/interpro/wwwapi//entry/sfld/SFLDG01205?annotation=hmm SFLDG01205.hmm.gz

[DEPENDENCY]
set -e
set -x

module purge
module use $JARVIS_MODULES/modules

./jarvis -install hpckit/2025.1.0.SPC001 any
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule
module load bisheng/%#MYKMPIVER#%/release

tar --no-same-owner -zxvf ${JARVIS_DOWNLOAD}/hmmer-3.4.tar.gz -C ${JARVIS_DEV}
echo "done"

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule
module load bisheng/%#MYKMPIVER#%/release

[APP]
fake = 0
app_name = hmmer
app_version = 3.4
compiler = bisheng+mpi
build_dir = ${JARVIS_DEV}/hmmer-3.4
binary_dir =
case_dir = ${JARVIS_JOBSCRIPT}/hmmer/3.4

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

set +x && check_install_path "${PATH_INSTALL}" && set -x
set +x && build_mod_check "${PATH_INSTALL}/bin/hmmbuild" "prompt" && set -x
set +x && rm_file_from_base ${PATH_INSTALL}/bin hmmbuild  && set -x
####### build prepare
set +x && echo_info "build prepare!!!" && set -x

./configure --prefix=$PATH_INSTALL --enable-mpi --enable-neon CC=mpicc CXX=mpicxx FC=mpifort F77=mpifort
make
make check
make install

####### build start
set +x && echo_info "build start" && set -x


####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/hmmer/3.4
mkdir -p ${JOBDIR}

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_bma
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=128"
#DSUB -o pytorch_out_%J.log
#DSUB -e pytorch_err_%J.log
#DSUB -T '2h'
source env.sh
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1

EOF

cat >${JOBDIR}/local_run.sh << EOF
#!/bin/bash
module purge
module use $JARVIS_MODULES/modules
module load hmmer/3.4-%#MYKBSVER#%-%#MYKMPIVER#%

if [ -d "test" ]; then
rm -rf test
fi
mkdir test
cd test
cp ${JARVIS_DEV}/hmmer-3.4/tutorial/globins4.hmm .
cp ${JARVIS_DEV}/hmmer-3.4/tutorial/globins4.sto .
cp ${JARVIS_DEV}/hmmer-3.4/tutorial/globins45.fa .

hmmbuild globins4.hmm globins4.sto
hmmsearch globins4.hmm globins45.fa | tee -a globins4.out
EOF


cat > ${JOBDIR}/hmmer-3.4-run.sh << EOF
#!/bin/bash
cd ${JOBDIR}

./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/hmmer-3.4-run.sh

set +x && echo_info "Install done!!!" && set -x

[RUN]
