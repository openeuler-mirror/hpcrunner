[SERVER]
11.11.11.11

[DOWNLOAD]
true

[DEPENDENCY]
set -e
source ${JARVIS_LIBSHELL}
check_rpms_installed libxml2-devel libxslt-devel libXt-devel libX11-devel libXext-devel openblas-devel lapack-devel bzip2-devel openssl-devel ncurses-devel sqlite-devel readline-devel tk-devel libffi-devel mesa-libGL-devel mesa-libGLU-devel || exit 1
set -x

module purge
module use $JARVIS_MODULES/modules

./jarvis -install python2/2.7.16/chaste any
module load python2-chaste/2.7.16

./jarvis -install hpckit/2025.1.0.SPC001 any
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule
module load bisheng/%#MYKMPIVER#%/release

./jarvis -install boost/1.70.0/clang bisheng
module load boost-clang/1.70.0-%#MYKBSVER#%

./jarvis -install sundials/5.8.0 bisheng
module load sundials/5.8.0-%#MYKBSVER#%

./jarvis -install xerces/3.3.0 bisheng
module load xerces/3.3.0-%#MYKBSVER#%

./jarvis -install amara/1.2.0.2 any

./jarvis -install xsd/4.0.0/clang bisheng
module load xsd-clang/4.0.0-%#MYKBSVER#%

./jarvis -install vtk/6.2.0/clang bisheng
module load vtk-clang/6.2.0-%#MYKBSVER#%

./jarvis -install petsc/3.19.6 bisheng+mpi
module load petsc/3.19.6-%#MYKBSVER#%-%#MYKMPIVER#%

echo "done"

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule
module load bisheng/%#MYKMPIVER#%/release
module load python2-chaste/2.7.16
module load boost-clang/1.70.0-%#MYKBSVER#%
module load sundials/5.8.0-%#MYKBSVER#%
module load xerces/3.3.0-%#MYKBSVER#%
module load xsd-clang/4.0.0-%#MYKBSVER#%
module load vtk-clang/6.2.0-%#MYKBSVER#%
module load petsc/3.19.6-%#MYKBSVER#%-%#MYKMPIVER#%

[APP]
fake = 0
app_name = chaste
app_version = 2019.1
compiler = bisheng+mpi
build_dir = ${JARVIS_DEV}/chaste/2019.1-%#MYKBSVER#%-%#MYKMPIVER#%
binary_dir =
case_dir = ${JARVIS_JOBSCRIPT}/chaste/2019.1

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

####### build prepare
set +x && echo_info "build prepare!!!" && set -x
install_path=$1
build_mod_check "${install_path}/bin/Chaste" "prompt"

tar --no-same-owner -zxvf ${JARVIS_DOWNLOAD}/chaste_2019.1_920F.tar.gz --strip-components=2 -C ${PATH_INSTALL} 

cat > ${PATH_INSTALL}/module_tail.modulefile << EOF
prepend-path LD_LIBRARY_PATH \${prefix}/lib/chaste:\${prefix}/lib/dep
EOF

####### build done
set +x && echo_info "build done!!!" && set -x


set +x && echo_info "Install jobscript!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/chaste/2019.1
mkdir -p ${JOBDIR}

${BUILD_DIR}/env.sh_gen.sh ${JOBDIR}/env.sh
echo "module load chaste/2019.1-%#MYKBSVER#%-%#MYKMPIVER#%" >> ${JOBDIR}/env.sh
cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_chaste
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=128"
#DSUB -o pytorch_out_%J.log
#DSUB -e pytorch_err_%J.log
#DSUB -T '2h'

EOF

cat > ${JOBDIR}/local_run.sh << EOF
#!/bin/bash
source ./env.sh
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1

cd $PATH_INSTALL/examples/Propagation3d

bash ./run.sh
EOF


cat > ${JOBDIR}/chaste-2019.1-run.sh << EOF
source env.sh
echo "Chaste project:${BUILD_DIR}/Chaste-release_2019.1"

./local_run.sh
dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/env.sh
chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/chaste-2019.1-run.sh

set +x && echo_info "Install done!!!" && set -x

[RUN]
