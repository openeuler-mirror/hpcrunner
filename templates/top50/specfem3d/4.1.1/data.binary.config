[SERVER]
11.11.11.11

[DOWNLOAD]
true

[DEPENDENCY]
set -e

module purge
module use $JARVIS_MODULES/modules
./jarvis -install hpckit/2025.1.0.SPC001 any
module load hpckit/2025.1.0.SPC001

echo "done"

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule
module load bisheng/kupl25.1.0.SPC001/release
module load bisheng/%#MYKMPIVER#%/release

[APP]
fake = 0
app_name = specfem3d
app_version = 4.1.1
compiler = bisheng+mpi
build_dir = ${JARVIS_APP}/specfem3d/4.1.1-%#MYKBSVER#%-%#MYKMPIVER#%
binary_dir =
case_dir = ${JARVIS_JOBSCRIPT}/specfem3d/4.1.1

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

####### build prepare
set +x && echo_info "build prepare!!!" && set -x

####### build start
set +x && echo_info "build start" && set -x

build_mod_check "${PATH_INSTALL}/bin/xspecfem3D" "prompt"
cd $PATH_INSTALL
if [ ! -d "bin" ]; then
mkdir bin
fi
cp ${JARVIS_DOWNLOAD}/specfem3d/bin/xspecfem3D ./bin -ar
cp ${JARVIS_DOWNLOAD}/specfem3d/bin/xgenerate_databases ./bin -ar
cp ${JARVIS_DOWNLOAD}/specfem3d/bin/xmeshfem3D ./bin -ar
cp ${JARVIS_DOWNLOAD}/specfem3d/bin/xdecompose_mesh ./bin -ar
chmod +x ./bin/xspecfem3D
chmod +x ./bin/xgenerate_databases
chmod +x ./bin/xmeshfem3D
chmod +x ./bin/xdecompose_mesh

####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x

JOBDIR=${JARVIS_JOBSCRIPT}/specfem3d/4.1.1
mkdir -p ${JOBDIR}
${BUILD_DIR}/env.sh_gen.sh ${JOBDIR}/env.sh
echo "module load specfem3d/4.1.1-%#MYKBSVER#%-%#MYKMPIVER#%" >> ${JOBDIR}/env.sh

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_specfem3d
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=256"
#DSUB -o out_%J.log
#DSUB -e err_%J.log
#DSUB -T '2h'

export HOSTFILE=hostfile.wrf
rm -f \$HOSTFILE
touch \$HOSTFILE
cat \${CCSCHEDULER_ALLOC_FILE} | sort > \$HOSTFILE
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
source ./env.sh

EOF

cat << 'EOF' > ${JOBDIR}/local_run.sh
#!/bin/bash
source ./env.sh
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1

cd regular
currentdir=`pwd`

mkdir -p OUTPUT_FILES
rm -rf OUTPUT_FILES/*

sed -i 's/NPROC                           = [0-9]\+/NPROC                           = 576/g' DATA/Par_file
sed -i 's/NPROC_XI                        = [0-9]\+/NPROC_XI                        = 24/g' DATA/meshfem3D_files/Mesh_Par_file
sed -i 's/NPROC_ETA                       = [0-9]\+/NPROC_ETA                       = 24/g' DATA/meshfem3D_files/Mesh_Par_file

cp DATA/meshfem3D_files/Mesh_Par_file OUTPUT_FILES/
cp DATA/Par_file OUTPUT_FILES/
cp DATA/CMTSOLUTION OUTPUT_FILES/
cp DATA/STATIONS OUTPUT_FILES/

NPROC=`grep ^NPROC DATA/Par_file | grep -v -E '^[[:space:]]*#' | cut -d = -f 2`

IO_NODES=`grep ^HDF5_IO_NODES DATA/Par_file | sed 's/#.*//' | cut -d = -f 2`

BASEMPIDIR=`grep ^LOCAL_PATH DATA/Par_file | cut -d = -f 2 `
mkdir -p $BASEMPIDIR

echo "  running mesher on $NPROC processors..."
mpirun --allow-run-as-root -np $NPROC --rankfile myrankfile576_1 -x OMP_NUM_THREADS=1 --mca rmaps_rank_file_physical true -x UCX_TLS=self,sm -x UCX_WARN_UNUSED_ENV_VARS=n xmeshfem3D

echo "  running database generation on $NPROC processors..."
mpirun --allow-run-as-root -np $NPROC --rankfile myrankfile576_1 -x OMP_NUM_THREADS=1 --mca rmaps_rank_file_physical true -x UCX_TLS=self,sm -x UCX_WARN_UNUSED_ENV_VARS=n xgenerate_databases

if [ "$IO_NODES" -gt 0 ]; then
  NPROC=$(($NPROC+$IO_NODES))
fi

echo "  running solver on $NPROC processors..."
mpirun --allow-run-as-root -np $NPROC --rankfile myrankfile576_1 -x OMP_NUM_THREADS=1 --mca rmaps_rank_file_physical true -x UCX_TLS=self,sm -x UCX_WARN_UNUSED_ENV_VARS=n xspecfem3D
EOF

cat > ${JOBDIR}/specfem3d-4.1.1-run.sh << EOF
#!/bin/bash
source ./env.sh

if [ -d "regular" ]; then
rm -rf regular
fi
cp -r ${JARVIS_DOWNLOAD}/regular .
cp ${JARVIS_DOWNLOAD}/specfem3d/bin/myrankfile576_1 ./regular

./local_run.sh
dsub -s ./job_run.sh
EOF

chmod u+x ${JOBDIR}/env.sh
chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/specfem3d-4.1.1-run.sh

set +x && echo_info "Install done!!!" && set -x

[RUN]
