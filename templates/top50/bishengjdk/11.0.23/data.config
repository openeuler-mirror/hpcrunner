[SERVER]
11.11.11.11

[DOWNLOAD]
true

[DEPENDENCY]
set -e
set -x

module purge
module use $JARVIS_MODULES/modules
./jarvis -install bishengjdk/11.0.23 any
module load bishengjdk/11.0.23
#yum_install_system_rpms perl ksh

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load bishengjdk/11.0.23

[APP]
fake = 1
app_name = bishengjdk
app_version = 11.0.23
compiler = gcc
build_dir = ${JARVIS_DEV}/bishengjdk/11.0.23
binary_dir = ${JARVIS_DEV}/bishengjdk/11.0.23
case_dir = ${JARVIS_JOBSCRIPT}/bishengjdk/11.0.23

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

####### build prepare
set +x && echo_info "build prepare!!!" && set -x

####### build start
set +x && echo_info "build start ..." && set -x

####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install ..." && set -x

JOB_DIR="${JARVIS_JOBSCRIPT}/bishengjdk/11.0.23"
mkdir -p ${JARVIS_JOBSCRIPT}/bishengjdk/11.0.23
${JARVIS_DEV}/bishengjdk/11.0.23/env.sh_gen.sh "${JOB_DIR}"/env.sh
echo "export JAVA_HOME=\${BISHENGJDK_PATH}" >> "${JOB_DIR}"/env.sh

cat > ${JOB_DIR}/HelloWorld.java <<  EOF
public class HelloWorld {
    public static void main(String[] args) {
        System.out.println("Hello, World!");
    }
}
EOF
cat > ${JOB_DIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_java
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=1"
#DSUB -o java_out_%J.log
#DSUB -e java_err_%J.log
#DSUB -T '2h'

export HOSTFILE=hostfile.java
rm -f \$HOSTFILE
touch \$HOSTFILE
cat \${CCSCHEDULER_ALLOC_FILE} | sort > \$HOSTFILE
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
source ./env.sh

ulimit -s unlimited

{ time  -p mpirun  --hostfile \$HOSTFILE -np 1 --allow-run-as-root --bind-to cpulist:ordered -x OMP_PROC_BIND=close -x OMP_PLACES=cores  -x OMP_NUM_THREADS=1 -x UCX_TLS=sm java HelloWorld ; } 2>&1 | tee tee_java.xlog
EOF

cat > ${JOB_DIR}/local_run.sh << EOF
#!/bin/bash
source ./env.sh
{ time  -p  java HelloWorld ; } 2>&1 | tee tee_java.xlog
EOF

cat > ${JOB_DIR}/bishengjdk-11.0.23-run.sh << EOF
#!/bin/bash
source ./env.sh
javac HelloWorld.java
./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF


chmod u+x ${JOB_DIR}/env.sh
chmod u+x ${JOB_DIR}/job_run.sh
chmod u+x ${JOB_DIR}/local_run.sh
chmod u+x ${JOB_DIR}/bishengjdk-11.0.23-run.sh

set +x && echo_info "Install done!!!" && set -x

[CLEAN]
echo "make clean"

[RUN]
run = mpirun --allow-run-as-root -x OMP_NUM_THREADS=1 -np 1 cmake --version
binary = cmake --version 
nodes = 1

[BATCH]
mpirun --allow-run-as-root -x OMP_NUM_THREADS=1 -np 1 cmake --version

[JOB]
#!/bin/bash
#DSUB -n case_cmake
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=1"
#DSUB -o cmake_out_%J.log
#DSUB -e cmake_err_%J.log
#DSUB -T '2h'

export HOSTFILE=hostfile.cmake
rm -f $HOSTFILE
touch $HOSTFILE
cat ${CCSCHEDULER_ALLOC_FILE} | sort > $HOSTFILE
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
source ./env.sh

ulimit -s unlimited

{ time  -p mpirun  --hostfile $HOSTFILE -np 1 --allow-run-as-root --bind-to cpulist:ordered -x OMP_PROC_BIND=close -x OMP_PLACES=cores  -x OMP_NUM_THREADS=1 -x UCX_TLS=sm cmake --version ; } 2>&1 | tee tee_cmake.xlog
