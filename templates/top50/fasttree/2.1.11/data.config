[SERVER]
11.11.11.11

[DOWNLOAD]
fasttree/2.1.11 http://meta.microbesonline.org/fasttree/FastTree.c
case http://morgannprice.org/16S/403K/all.masked.gz

[DEPENDENCY]
set -e
module purge
module use $JARVIS_MODULES/modules
./jarvis -install hpckit/2025.1.0.SPC001 any
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule

echo "done"

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule

[APP]
fake = 0
app_name = fasttree
app_version = 2.1.11
compiler = bisheng
build_dir = ${JARVIS_DEV}/fasttree/2.1.11
binary_dir =
case_dir = ${JARVIS_JOBSCRIPT}/fasttree/2.1.11

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

set +x && check_install_path "${PATH_INSTALL}" && set -x
set +x && build_mod_check "${PATH_INSTALL}/bin/FastTreePar-2.1.11" "prompt" && set -x
set +x && rm_file_from_base ${PATH_INSTALL}/bin FastTreePar-2.1.11  && set -x
####### build prepare
set +x && echo_info "build prepare!!!" && set -x

####### build start
set +x && echo_info "build start" && set -x

if [ ! -d "$PATH_INSTALL/bin" ]; then
mkdir -p $PATH_INSTALL/bin
fi

cp ${JARVIS_DOWNLOAD}/FastTree.c .
clang -DOPENMP -DUSE_DOUBLE -fopenmp -O3 -mcpu=hip11 -finline-functions -funroll-loops -Wall -o FastTreePar-2.1.11 FastTree.c -lm
cp FastTreePar-2.1.11 $PATH_INSTALL/bin

####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/fasttree/2.1.11
mkdir -p ${JOBDIR}

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_bma
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=128"
#DSUB -o pytorch_out_%J.log
#DSUB -e pytorch_err_%J.log
#DSUB -T '2h'
source env.sh
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1

EOF

cat >${JOBDIR}/local_run.sh << EOF
#!/bin/bash
module purge
module use $JARVIS_MODULES/modules
module load fasttree/2.1.11-%#MYKBSVER#%

if [ -d "test" ]; then
rm -rf test
fi
mkdir test
cd test

cp ${JARVIS_DOWNLOAD}/all.masked.gz .
gzip -d all.masked.gz

time OMP_NUM_THREADS=128 FastTreePar-2.1.11 -fastest -noml -gtr -nt all.masked
EOF

cat > ${JOBDIR}/fasttree-2.1.11-run.sh << EOF
#!/bin/bash
cd ${JOBDIR}

./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/fasttree-2.1.11-run.sh

set +x && echo_info "Install done!!!" && set -x

[RUN]
