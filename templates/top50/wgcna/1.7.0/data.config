[SERVER]
11.11.11.11

[DOWNLOAD]
BiocManager https://mirrors.nju.edu.cn/CRAN/src/contrib/BiocManager_1.30.26.tar.gz

[DEPENDENCY]
set -e
module purge
module use $JARVIS_MODULES/modules
./jarvis -install hpckit/2025.1.0.SPC001 any
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1/gccmodule

./jarvis -install R/4.2.0 gcc
module load R/4.2.0-%#MYKGCCVER#%

echo "done"

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1/gccmodule
module load R/4.2.0-%#MYKGCCVER#%

[APP]
fake = 1
app_name = wgcna
app_version = 1.7.0
compiler = gcc
build_dir = ${JARVIS_DEV}/wgcna-1.7.0
binary_dir =
case_dir = ${JARVIS_JOBSCRIPT}/wgcna/1.7.0

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

####### build prepare
set +x && echo_info "build prepare!!!" && set -x

set +x && check_rpms_installed libpng-devel libpng-tools || exit 1

####### build start
set +x && echo_info "build start" && set -x

cp ${JARVIS_DOWNLOAD}/BiocManager_1.30.26.tar.gz .
Rscript -e 'options(download.file.method="curl",download.file.extra = "-k");options("repos"= c(CRAN="http://mirrors.tuna.tsinghua.edu.cn/CRAN/"));install.packages("BiocManager_1.30.26.tar.gz")'
Rscript -e 'options(download.file.method="curl",download.file.extra = "-k");options("repos"= c(CRAN="http://mirrors.tuna.tsinghua.edu.cn/CRAN/"));options(BioC_mirror="http://mirrors.tuna.tsinghua.edu.cn/bioconductor/");BiocManager::install("WGCNA")'

####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/wgcna/1.7.0
mkdir -p ${JOBDIR}

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_bma
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=128"
#DSUB -o pytorch_out_%J.log
#DSUB -e pytorch_err_%J.log
#DSUB -T '2h'
source env.sh
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1

EOF

cat >${JOBDIR}/local_run.sh << EOF
#!/bin/bash
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1/gccmodule
module load R/4.2.0-%#MYKGCCVER#%

if [ -d "test" ]; then
rm -rf test
fi
mkdir test
cd test

cp ${JARVIS_ROOT}/templates/top50/wgcna/1.7.0/test.R .
time -p Rscript test.R
EOF

cat > ${JOBDIR}/wgcna-1.7.0-run.sh << EOF
#!/bin/bash
cd ${JOBDIR}

./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/wgcna-1.7.0-run.sh

set +x && echo_info "Install done!!!" && set -x

[RUN]
