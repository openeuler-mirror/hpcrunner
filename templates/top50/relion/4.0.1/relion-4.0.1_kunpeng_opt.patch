+				svfloat32_t g_imgs_imag_vec = svld1_f32(pg, &g_imgs_imag[pixel + x]);
+				svst1(pg, &imgs_real[x], svmul_f32_z(pg, g_imgs_real_vec, half_corr));
+				svst1(pg, &imgs_imag[x], svmul_f32_z(pg, g_imgs_imag_vec, half_corr));
+			}
+
+
+			for (unsigned long itrans=0; itrans<trans_num; itrans++) {
