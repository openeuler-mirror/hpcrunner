+    RFLOAT findMin(MultidimArray< RFLOAT > &arr, int l, int r) const {
+        int minVal = DIRECT_MULTIDIM_ELEM(arr,l);
+        for (int i = l + 1; i <= r; i++) {
+            if (DIRECT_MULTIDIM_ELEM(arr,i) < minVal) minVal = DIRECT_MULTIDIM_ELEM(arr,i);
+        } 
+
+        return minVal;
+    }
+    RFLOAT quickselect(MultidimArray< RFLOAT > &arr, int l, int r, int k) const {
+        while (true) {
+            if (l == r)
+                break;
+            RFLOAT partition = DIRECT_MULTIDIM_ELEM(arr,(l+r)/2);
+            int i = l - 1, j = r + 1;
+            while (i < j) {
+                do i++; while (DIRECT_MULTIDIM_ELEM(arr,i) < partition);
+                do j--; while (DIRECT_MULTIDIM_ELEM(arr,j) > partition);
+                if (i < j) {
+                    RFLOAT tmp = DIRECT_MULTIDIM_ELEM(arr,i);
+                    DIRECT_MULTIDIM_ELEM(arr,i) = DIRECT_MULTIDIM_ELEM(arr,j);
+                    DIRECT_MULTIDIM_ELEM(arr,j) = tmp;
+                }
+            }
+            if (k <= j) {
+                r = j;
+            } else {
+                l = j + 1;
+            }
+        }
+
+        return DIRECT_MULTIDIM_ELEM(arr,k);
+    }
