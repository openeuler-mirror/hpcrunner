+					XFLOAT shifted_imag = cc * imgs_imag[x] + ss * imgs_real[x];
+
+					XFLOAT diff_real =  ref_real[x] - shifted_real;
+					XFLOAT diff_imag =  ref_imag[x] - shifted_imag;
+
+					sum += (diff_real * diff_real + diff_imag * diff_imag);
+				}
+				s[itrans] += sum;
+			}
+
+			pixel += (unsigned long)xSize;
+		}  // for pass
