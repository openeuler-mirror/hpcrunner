[SERVER]
11.11.11.11

[DOWNLOAD]
relion/4.0.1 https://github.com/3dem/relion/archive/refs/tags/4.0.1.tar.gz relion-4.0.1.tar.gz
class_ranker/0.1.3 ftp://ftp.mrc-lmb.cam.ac.uk/pub/dari/class_ranker_0.1.3_torch_1.0.1.pt.tar.gz class_ranker_0.1.3_torch_1.0.1.pt.tar.gz

[DEPENDENCY]
set -e
source ${JARVIS_LIBSHELL}
check_rpms_installed tbb-devel || exit 1
set -x

module purge
module use $JARVIS_MODULES/modules
./jarvis -install cmake/3.28.2 any
module load cmake/3.28.2
./jarvis -install armpl/24.10 gcc
module load armpl/24.10-gcc10.3.1

./jarvis -install hpckit/2025.1.0.SPC001 any
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule
module load bisheng/%#MYKMPIVER#%/release
set -x
./jarvis -install fftw/3.3.8 bisheng+mpi
module load fftw/3.3.8-%#MYKBSVER#%-%#MYKMPIVER#%

./jarvis -install wxWidgets/3.0.5 bisheng
module load  wxWidgets/3.0.5-%#MYKBSVER#%

./jarvis -install ctffind/4.1.14/clang bisheng
module load ctffind-clang/4.1.14-%#MYKBSVER#%
set +x
./jarvis -install libpng/1.6.37 bisheng
module load libpng/1.6.37-%#MYKBSVER#%

echo "done"

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule
module load bisheng/%#MYKMPIVER#%/release
module load bisheng/kml25.1.0.SPC001/kml
module unload bisheng/kml25.1.0.SPC001/kvml/serial
module load bisheng/kml25.1.0.SPC001/kvml/omp
module load fftw/3.3.8-%#MYKBSVER#%-%#MYKMPIVER#%
module load wxWidgets/3.0.5-%#MYKBSVER#%
module load ctffind-clang/4.1.14-%#MYKBSVER#%
module load libpng/1.6.37-%#MYKBSVER#%
module load cmake/3.28.2
module load armpl/24.10-gcc10.3.1

[APP]
fake = 0
app_name = relion
app_version = 4.0.1
compiler = bisheng+mpi
build_dir = ${JARVIS_DEV}/relion/4.0.1-%#MYKBSVER#%-%#MYKMPIVER#%/project
binary_dir =
case_dir = ${JARVIS_JOBSCRIPT}/relion/4.0.1

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"


####### build prepare
set +x && echo_info "build prepare!!!" && set -x


install_path=$1
cd ${BUILD_DIR}
build_mod_check "${PATH_INSTALL}/bin/relion_refine_mpi" "prompt"

mymd5=$(md5sum  ${JARVIS_DOWNLOAD}/class_ranker_0.1.3_torch_1.0.1.pt.tar.gz | awk '{print $1}')
if [ $mymd5 != "b39f0cbc31f510e3a03e89f1e11110fe" ]; then
	set +x && echo_error "Invalid package:${JARVIS_DOWNLOAD}/class_ranker_0.1.3_torch_1.0.1.pt.tar.gz, expect md5:b39f0cbc31f510e3a03e89f1e11110fe" && set -x
	exit 1
fi

if true; then 
if [ -d "relion-4.0.1" ]; then
rm -rf relion-4.0.1
fi
tar --no-same-owner -zxvf ${JARVIS_DOWNLOAD}/relion-4.0.1.tar.gz
mkdir ${BUILD_DIR}/relion-4.0.1/external/
mkdir ${BUILD_DIR}/relion-4.0.1/external/torch_models/
cp -r ${JARVIS_DOWNLOAD}/class_ranker_0.1.3_torch_1.0.1.pt.tar.gz ${BUILD_DIR}/relion-4.0.1/external/torch_models/ -ar
####### build start
set +x && echo_info "build start" && set -x
cd relion-4.0.1
patch -p1 < ${JARVIS_ROOT}/templates/top50/relion/4.0.1/relion-4.0.1_kunpeng_opt.patch
if [ -d "build" ]; then
rm -rf build
fi
mkdir build
cd build

export CMAKE_PREFIX_PATH=${LIBPNG_PATH}:${FFTW_PATH}

sed -i '28i\file(ARCHIVE_EXTRACT\nINPUT \${MODELS_DIR}/\${CLASS_RANKER_MODEL_FILE_NAME_TAR}\nDESTINATION \${MODELS_DIR}/class_ranker)\nmessage(STATUS "Untar \${MODELS_DIR}/\${CLASS_RANKER_MODEL_FILE_NAME_TAR} to \${MODELS_DIR}/class_ranker")' ${BUILD_DIR}/relion-4.0.1/cmake/FetchTorchModels.cmake

cmake .. -DCUDA=OFF -DFETCH_TORCH_MODELS=OFF -DDoublePrec_CPU=OFF  -DGUI=OFF -DALTCPU=ON \
      -DCMAKE_INSTALL_PREFIX=${PATH_INSTALL} \
      -DBUILD_SHARED_LIBS=OFF -DCMAKE_BUILD_TYPE=release \
      -DCMAKE_CXX_COMPILER=clang++ -DCMAKE_C_COMPILER=clang  \
      -DMPI_C_COMPILER=mpicc -DMPI_CXX_COMPILER=mpicxx \
      -DFORCE_OWN_FFTW=OFF

make -j 32
make install

fi
####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/relion/4.0.1
mkdir -p ${JOBDIR}
${BUILD_DIR}/env.sh_gen.sh ${JOBDIR}/env.sh
echo "module load relion/4.0.1-%#MYKBSVER#%-%#MYKMPIVER#%" >> ${JOBDIR}/env.sh


cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_relion
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=128"
#DSUB -o out_%J.log
#DSUB -e err_%J.log
#DSUB -T '2h'

export HOSTFILE=hostfile.wrf
rm -f \$HOSTFILE
touch \$HOSTFILE
cat \${CCSCHEDULER_ALLOC_FILE} | sort > \$HOSTFILE
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
source ./env.sh
cd relion_benchmark

{ time -p mpirun --hostfile $HOSTFILE --allow-run-as-root -n 4 --bind-to cpulist:ordered -x OMP_PROC_BIND=close -x OMP_PLACES=cores -x OMP_NUM_THREADS=1 -x UCX_TLS=sm relion_refine_mpi --j 24 --cpu --pool 100 --dont_combine_weights_via_disc --i Particles/shiny_2sets.star --ref emd_2660.map:mrc --firstiter_cc --ini_high 60 --ctf --ctf_corrected_ref --iter 25 --tau2_fudge 4 --particle_diameter 360 --K 6 --flatten_solvent --zero_mask --oversampling 1 --healpix_order 2 --offset_range 5 --offset_step 2 --sym C1 --norm --scale --random_seed 0 --maxsig 500 --fast_subsets --o class3d/test01 ; } 2>&1 | tee tee_out.xlog
EOF

cat > ${JOBDIR}/local_run.sh << EOF
#!/bin/bash
source ./env.sh
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
cd relion_benchmark

procnum=32
trdnum=18
pernode=\${procnum}/2

if [ ! -d "class3d/" ]; then
    mkdir class3d/
fi

cp ${JARVIS_ROOT}/templates/top50/relion/4.0.1/myrankfile_32-18 . -ar

time -p mpirun --allow-run-as-root --rankfile myrankfile_32-18 --report-bindings \
     --bind-to core --rank-by core -x UCX_TLS=self,sm  -x UCG_PLANC_UCX_BARRIER_ATTR=I:8S:200R:0 -x UCG_PLANC_UCX_BCAST_ATTR=I:10S:200R:0 -mca pml ucx -mca btl ^vader,tcp,openib,uct \
       relion_refine_mpi --j \$trdnum --cpu --pool 40 --dont_combine_weights_via_disc \
         --i Particles/shiny_2sets.star --ref emd_2660.map:mrc --firstiter_cc \
        --ini_high 60  --iter 20 --tau2_fudge 4 --particle_diameter 360 --K 6 \
        --flatten_solvent --zero_mask --oversampling 1 --healpix_order 2 --offset_range 5 --offset_step 2 \
        --sym C1 --norm --scale --random_seed 0 --maxsig 500 --fast_subsets --o class3d/test_1N_20it_\${procnum}-\${trdnum}_0gpu
EOF

cat > ${JOBDIR}/relion-4.0.1-run.sh << EOF
#!/bin/bash
source ./env.sh
if [ ! -f relion_benchmark.tar.gz ]; then
	cp ${JARVIS_DOWNLOAD}/relion_benchmark.tar.gz ./ -ar
fi
if [ ! -d relion_benchmark ]; then
tar -zxf relion_benchmark.tar.gz
fi

./local_run.sh
dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/env.sh
chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/relion-4.0.1-run.sh

set +x && echo_info "Install done!!!" && set -x

[RUN]
