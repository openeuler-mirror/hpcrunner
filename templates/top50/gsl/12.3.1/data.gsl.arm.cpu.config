[SERVER]
11.11.11.11

[DOWNLOAD]
true

[DEPENDENCY]
set -e
source ${JARVIS_LIBSHELL}
check_rpms_installed tar byacc bison expat-devel expat libtirpc-devel libX11 libX11-devel libXmu libXmu-devel libXaw libXaw-devel flex flex-devel freetype-devel libpng-devel libpng libjpeg-turbo-devel libjpeg-turbo  libXi libSM-devel libXi-devel libXext-devel pkgconf curl libcurl-devel zlib-devel cairo cairo-devel pixman pixman-devel patch || exit 1

module purge
module use $JARVIS_MODULES/modules
./jarvis -install hpckit/2025.1.0.SPC001 any
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1/gccmodule
module load gcc/%#MYKMPIVER#%/release
./jarvis -install gsl/2.6 gcc
module add gsl/2.6-%#MYKGCCVER#%


[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1/gccmodule
module load gcc/%#MYKMPIVER#%/release
module add gsl/2.6-%#MYKGCCVER#%


[APP]
fake = 1
app_name = devgsl
app_version = 6.6.2
compiler = gcc
build_dir = ${JARVIS_DEV}/gsl/2.6-%#MYKGCCVER#%
binary_dir =
case_dir = ${JARVIS_JOBSCRIPT}/gsl/2.6

[BUILD]
set -e
set -x

####  build
echo "build start"
echo "build done!!!"

#### install jobsript for case test
echo "Install start"
JOB_DIR="${JARVIS_JOBSCRIPT}/gsl/2.6"
mkdir -p ${JOB_DIR}
${JARVIS_DEV}/gsl/2.6-%#MYKGCCVER#%/env.sh_gen.sh ${JOB_DIR}/env.sh
cat > ${JOB_DIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_cmake
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=1"
#DSUB -o cmake_out_%J.log
#DSUB -e cmake_err_%J.log
#DSUB -T '2h'

export HOSTFILE=hostfile.cmake
rm -f \$HOSTFILE
touch \$HOSTFILE
cat \${CCSCHEDULER_ALLOC_FILE} | sort > \$HOSTFILE
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
source ./env.sh

ulimit -s unlimited
echo "show GSL installation prefix"
{ time  -p mpirun  --hostfile $HOSTFILE -np 1 --allow-run-as-root --bind-to cpulist:ordered -x OMP_PROC_BIND=close -x OMP_PLACES=cores  -x OMP_NUM_THREADS=1 -x UCX_TLS=sm gsl-config --prefix; } 2>&1 | tee tee_gsl.xlog
EOF


cat > ${JOB_DIR}/local_run.sh << EOF
#!/bin/bash
source ./env.sh
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
echo -e "\033[0;32m=============================\033[0m"
echo "show GSL installation prefix:"
{ time  -p  mpirun --allow-run-as-root -np 1 --bind-to cpulist:ordered -x OMP_PROC_BIND=close -x OMP_PLACES=cores  -x OMP_NUM_THREADS=1 -x UCX_TLS=sm gsl-config --prefix; } 2>&1 | tee tee_gsl.xlog
echo -e "\033[0;32m=============================\033[0m"
EOF

cat > ${JOB_DIR}/gsl-2.6-%#MYKGCCVER#%-run.sh << EOF
#!/bin/bash
source ./env.sh
./local_run.sh 2>&1 | tee tee_local_run.xlog
#dsub -s job_run.sh
EOF


chmod u+x ${JOB_DIR}/env.sh
chmod u+x ${JOB_DIR}/job_run.sh
chmod u+x ${JOB_DIR}/local_run.sh
chmod u+x ${JOB_DIR}/gsl-2.6-%#MYKGCCVER#%-run.sh

echo "Install done!!!"

[BATCH]
mpirun --allow-run-as-root -x OMP_NUM_THREADS=1 -np 1 test.sh

[RUN]
run = mpirun -v --allow-run-as-root -x OMP_NUM_THREADS=1 -np 1  ${JARVIS_JOBSCRIPT}/NCL/6.6.2/test.sh
binary = 
nodes = 1

[JOB]
#!/bin/bash
#DSUB -n case_ncl
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=1"
#DSUB -o ncl_out_%J.log
#DSUB -e ncl_err_%J.log
#DSUB -T '2h'

export HOSTFILE=hostfile.ncl
rm -f $HOSTFILE
touch $HOSTFILE
cat ${CCSCHEDULER_ALLOC_FILE} | sort > $HOSTFILE
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
source ./env.sh

ulimit -s unlimited

{ time  -p mpirun  --hostfile $HOSTFILE -np 1 --allow-run-as-root --bind-to cpulist:ordered -x OMP_PROC_BIND=close -x OMP_PLACES=cores  -x OMP_NUM_THREADS=1 -x UCX_TLS=sm sh tast.sh ; } 2>&1 | tee tee_gsl.xlog

