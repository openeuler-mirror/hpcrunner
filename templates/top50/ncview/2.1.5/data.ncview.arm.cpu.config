[SERVER]
11.11.11.11

[DOWNLOAD]
ncview/2.1.5 https://src.fedoraproject.org/repo/pkgs/ncview/ncview-2.1.5.tar.gz/e1f170283cb84d33a7e42747c76fccd7/ncview-2.1.5.tar.gz

[DEPENDENCY]
source ${JARVIS_LIBSHELL}
check_rpms_installed libX11 libX11-devel libXaw libXaw-devel libpng-devel libpng curl libcurl-devel libcurl  zlib zlib-devel libXt-devel xorg-x11-xauth xorg-x11-server-utils xorg-x11-server-Xnest libXtst || exit 1

set -x
set -e

module purge
./jarvis -install hpckit/2025.1.0.SPC001 any
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule
module load bisheng/%#MYKMPIVER#%/release
./jarvis -install hdf5/1.10.1/clang clang+mpi
module add hdf5-clang/1.10.1-%#MYKBSVER#%-%#MYKMPIVER#%
./jarvis -install pnetcdf/1.12.3/clang clang+mpi
module add pnetcdf-clang/1.12.3-%#MYKBSVER#%-%#MYKMPIVER#%
./jarvis -install netcdf/4.7.0/clang clang+mpi
./jarvis -install udunits/2.2.28 clang

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule
module load bisheng/%#MYKMPIVER#%/release
module add hdf5-clang/1.10.1-%#MYKBSVER#%-%#MYKMPIVER#%
module add pnetcdf-clang/1.12.3-%#MYKBSVER#%-%#MYKMPIVER#%
module add netcdf-clang/4.7.0-%#MYKBSVER#%-%#MYKMPIVER#%-hdf51.10.1-pnetcdf1.12.3
module add udunits/2.2.28-%#MYKBSVER#%


[APP]
app_name = ncview
app_version = 2.1.5
compiler = bisheng+mpi
build_dir = ${JARVIS_DEV}/ncview/2.1.5-%#MYKBSVER#%-%#MYKMPIVER#%
binary_dir = 
case_dir = ${JARVIS_JOBSCRIPT}/ncview/2.1.5

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

set +x && build_mod_check "${PATH_INSTALL}/bin/ncview" "prompt" && set -x
if true; then
set +x && check_rpms_installed libX11 libX11-devel libXaw libXaw-devel libpng-devel libpng curl libcurl-devel libcurl zlib zlib-devel \
libXt-devel xorg-x11-xauth xorg-x11-server-utils xorg-x11-server-Xnest libXtst  || exit 1
set -x

####### build prepare
set +x && echo_info "build prepare!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/ncview/2.1.5

rm -rf ncview-2.1.5
tar -xvf ${JARVIS_DOWNLOAD}/ncview-2.1.5.tar.gz
cd ncview-2.1.5
CC=mpicc CXX=mpicxx FC=mpifort ./configure LDFLAGS="-L${NETCDF_CLANG_PATH}/lib -L${HDF5_CLANG_PATH}/lib -L${PNETCDF_PATH}/lib" CPPFLAGS="-I${NETCDF_CLANG_PATH}/include -I${HDF5_CLANG_PATH}/include -I${PNETCDF_PATH}/include" --prefix=$1 --with-nc-config=${NETCDF_CLANG_PATH}/bin/nc-config --with-udunits2_incdir=${UDUNITS_PATH}/include --with-udunits2_libdir=${UDUNITS_PATH}/lib CFLAGS="-Wno-implicit-function-declaration -Wno-implicit-int -Wno-int-conversion"

make -j
make install

fi
####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
mkdir -p ${JOBDIR}
${BUILD_DIR}/env.sh_gen.sh ${JOBDIR}/env.sh
echo "module load ncview/2.1.5-%#MYKBSVER#%-%#MYKMPIVER#%" >> ${JOBDIR}/env.sh

cp ${JARVIS_DOWNLOAD}/netcdf-c-4.7.0.tar.gz ${JOBDIR}/ -ar

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_ncview
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=1"
#DSUB -o ncl_out_%J.log
#DSUB -e ncl_err_%J.log
#DSUB -T '2h'

export HOSTFILE=hostfile.ncview
rm -f \$HOSTFILE
touch \$HOSTFILE
cat \${CCSCHEDULER_ALLOC_FILE} | sort > \$HOSTFILE
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
source ./env.sh

ulimit -s unlimited
{ time  -p ncview ref_nccopy3_subset.nc; } 2>&1 | tee tee_ncview.xlog
EOF

cat > ${JOBDIR}/local_run.sh << EOF
#!/bin/bash
source ./env.sh
cp netcdf-c-4.7.0/ncdump/ref_nccopy3_subset.nc . -ar
{ time  -p  ncview ref_nccopy3_subset.nc ; } 2>&1 | tee tee_ncview.xlog
EOF

cat > ${JOBDIR}/ncview-2.1.5-run.sh << EOF
#!/bin/bash
if [ ! -f netcdf-c-4.7.0 ]; then
tar zxf ./netcdf-c-4.7.0.tar.gz
fi

./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/env.sh
chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/ncview-2.1.5-run.sh

echo "Install done!!!"

[RUN]
run = 
binary = 
nodes = 1

[BATCH]


[JOB]
#!/bin/sh
#DSUB -n ncview_test
#DSUB --mpi hmpi
#DSUB -q default
#DSUB -N 1
#DSUB -R cpu =128
#DSUB -oo ncview_$J.out
#DSUB -eo ncview.$J.err

#生成算例
cd ${JARVIS_ROOT}/case
if [ ! -f "ref_nccopy3_subset.nc" ];then
 tar xf ${JARVIS_DOWNLOAD}/netcdf-c-4.7.0.tar.gz
 mv netcdf-c-4.7.0/ncdump/ref_nccopy3_subset.nc .
fi

#运行
#待补充
#ncview ref_nccopy3_subset.nc

