[SERVER]
11.11.11.11

[DOWNLOAD]
true

[DEPENDENCY]
set -e

module purge
module use $JARVIS_MODULES/modules
./jarvis -install cmake/3.28.2 any
module load cmake/3.28.2
./jarvis -install hpckit/2025.1.0.SPC001 any
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule
module load bisheng/%#MYKMPIVER#%/release
./jarvis -install openblas/0.3.18/clang  bisheng
module load openblas-clang/0.3.18-%#MYKBSVER#%

./jarvis -install lapack/3.8.0/clang bisheng

module load lapack-clang/3.8.0-%#MYKBSVER#%

./jarvis -install scalapack/2.0.2/clang bisheng
module load scalapack-clang/2.0.2-%#MYKBSVER#%-lapack3.8.0-openblas0.3.18

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load cmake/3.28.2
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1/gccmodule
module load bisheng/compiler4.2.0.2/bishengmodule
module load bisheng/%#MYKMPIVER#%/release
module load openblas-clang/0.3.18-%#MYKBSVER#%
module load lapack-clang/3.8.0-%#MYKBSVER#%
module load scalapack-clang/2.0.2-%#MYKBSVER#%-lapack3.8.0-openblas0.3.18

[APP]
fake = 1
app_name = kml
app_version = 25.1.0
compiler = bisheng+mpi
build_dir = ${JARVIS_DEV}/kml/25.1.0
binary_dir = ${JARVIS_DEV}/kml/25.1.0
case_dir = ${JARVIS_JOBSCRIPT}/kml/25.1.0

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

####### build prepare
set +x && echo_info "build prepare!!!" && set -x

####### build start
set +x && echo_info "build start" && set -x

cp ${JARVIS_ROOT}/dataconfig_patches/scalapack_samples01/kscalapack_pdgetrf.cpp ./

cp ${JARVIS_ROOT}/dataconfig_patches/scalapack_samples01/Makefile ./
make clean
make all SCALAPACK_PATH=${SCALAPACK_CLANG_PATH} HPCKIT_DIR=${HPCKIT_PATH}/HPCKit/latest

####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x

JOB_DIR="${JARVIS_JOBSCRIPT}/kml/25.1.0"
mkdir -p ${JOB_DIR}
${BUILD_DIR}/env.sh_gen.sh ${JOB_DIR}/env.sh

cp ${JARVIS_ROOT}/dataconfig_patches/scalapack_samples01/kscalapack_pdgetrf.cpp ${JOB_DIR}/ -ar
cp ${JARVIS_ROOT}/dataconfig_patches/scalapack_samples01/Makefile ${JOB_DIR}/ -ar
cp ${JARVIS_ROOT}/dataconfig_patches/scalapack_samples01/run_kml_job.sh ${JOB_DIR}/job_run.sh -ar
cp ${JARVIS_ROOT}/dataconfig_patches/scalapack_samples01/run_kml.sh ${JOB_DIR}/local_run.sh -ar

echo "export LD_LIBRARY_PATH=\${HPCKIT_PATH}/HPCKit/latest/hmpi/bisheng/hmpi/lib:\${HPCKIT_PATH}/HPCKit/latest/kml/bisheng/lib/noarch:\${HPCKIT_PATH}/HPCKit/latest/kml/bisheng/lib/sve512:\${HPCKIT_PATH}/HPCKit/latest/kml/bisheng/lib/sme/kblas/multi:\$LD_LIBRARY_PATH" >> ${JOB_DIR}/env.sh

cat > ${JOB_DIR}/kml-25.0.0-run.sh << EOF
#!/bin/bash
source ./env.sh
make clean
make all SCALAPACK_PATH=${SCALAPACK_CLANG_PATH} HPCKIT_DIR=${HPCKIT_PATH}/HPCKit/latest
./local_run.sh
dsub -s job_run.sh
EOF   

chmod u+x ${JOB_DIR}/env.sh
chmod u+x ${JOB_DIR}/job_run.sh
chmod u+x ${JOB_DIR}/local_run.sh
chmod u+x ${JOB_DIR}/kml-25.0.0-run.sh

set +x && echo_info "Install done!!!" && set -x


[CLEAN]
echo "make clean"

[RUN]
run = mpirun --allow-run-as-root -x OMP_NUM_THREADS=1 -np 8
binary = pw.x -input test_3.in
nodes = 1

[BATCH]
mpirun --allow-run-as-root -x OMP_NUM_THREADS=1 -np 8 $QE_ROOT/bin/pw.x -input test_3.in

[JOB]
#!/bin/bash
#DSUB -n case_scalapack
#DSUB --job_type cosched:hmpi
#DSUB -N 128
#DSUB -nn 1
#DSUB -rpn 128
#DSUB -R "cpu=128"
#DSUB -o pdgetrf_out_%J.log
#DSUB -e pdgetrf_err_%J.log
#DSUB -T '2h'

export HOSTFILE=hostfile.gmx
rm -f $HOSTFILE
touch $HOSTFILE
cat ${CCSCHEDULER_ALLOC_FILE} | sort > $HOSTFILE
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
source ./env.sh

ulimit -s unlimited

#### for 920B 128CORE-4NUMA
#{ time  -p mpirun  --hostfile $HOSTFILE -np 16 --allow-run-as-root --map-by ppr:4:numa:pe=8 -x OMP_PROC_BIND=close -x OMP_PLACES=cores -x KML_BLAS_THREAD_TYPE=OMP -x KML_BLAS_NOT_USE_HBM=1 -x OMP_NUM_THREADS=8 -x UCX_TLS=sm ./kscalapack_pdgetrf_cpp_open -nb 512 -grid 1x16 -size 120000 ; } 2>&1 | tee tee_kscalapack_pdgetrf_cpp_open.xlog


{ time  -p mpirun  --hostfile $HOSTFILE -np 16 --allow-run-as-root --bind-to cpulist:ordered -x OMP_PROC_BIND=close -x OMP_PLACES=cores  -x OMP_NUM_THREADS=8 -x UCX_TLS=sm ./kscalapack_pdgetrf_cpp_open -nb 512 -grid 1x16 -size 120000 ; } 2>&1 | tee tee_kscalapack_pdgetrf_cpp_open.xlog

