[SERVER]
11.11.11.11

[DOWNLOAD]
true

[DEPENDENCY]
set -e

module purge
module use $JARVIS_MODULES/modules
./jarvis -install cmake/3.28.2 any
module load cmake/3.28.2
./jarvis -install hpckit/2025.1.0.SPC001 any
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1/gccmodule
module load bisheng/compiler4.2.0.2/bishengmodule
module load bisheng/%#MYKMPIVER#%/release
./jarvis -install blas/3.8.0/clang bisheng 
module load blas-clang/3.8.0-%#MYKBSVER#%

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load cmake/3.28.2
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1/gccmodule
module load bisheng/compiler4.2.0.2/bishengmodule
module load bisheng/%#MYKMPIVER#%/release
module load blas-clang/3.8.0-%#MYKBSVER#%

[APP]
fake = 1
app_name = devblas
app_version = 3.8.0
compiler = bisheng
build_dir = ${JARVIS_DEV}/devblas/3.8.0
binary_dir = ${JARVIS_DEV}/devblas/3.8.0
case_dir = ${JARVIS_JOBSCRIPT}/blas/3.8.0/

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

####### build prepare
set +x && echo_info "build prepare!!!" && set -x

####### build start
set +x && echo_info "build start ..." && set -x

####### build done
set +x && echo_info "build done !!!" && set -x

####### Install jobscript
set +x && echo_info "Install ..." && set -x

JOB_DIR="${JARVIS_JOBSCRIPT}/blas/3.8.0/"
mkdir -p ${JOB_DIR}
${JARVIS_DEV}/devblas/3.8.0/env.sh_gen.sh ${JARVIS_JOBSCRIPT}/blas/3.8.0/env.sh
cat > ${JOB_DIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_cmake
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=1"
#DSUB -o cmake_out_%J.log
#DSUB -e cmake_err_%J.log
#DSUB -T '2h'

export HOSTFILE=hostfile.cmake
rm -f \$HOSTFILE
touch \$HOSTFILE
cat \${CCSCHEDULER_ALLOC_FILE} | sort > \$HOSTFILE
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
source ./env.sh

ulimit -s unlimited

{ time  -p mpirun  --hostfile $HOSTFILE -np 1 --allow-run-as-root --bind-to cpulist:ordered -x OMP_PROC_BIND=close -x OMP_PLACES=cores  -x OMP_NUM_THREADS=1 -x UCX_TLS=sm blas_level1 ; } 2>&1 | tee tee_blas.xlog
EOF

cat > ${JOB_DIR}/blas_level1.F90 << EOF
program blas_level1
    implicit none
    real(8), dimension(3) :: x = [1.0d0, 2.0d0, 3.0d0]
    real(8), dimension(3) :: y = [4.0d0, 5.0d0, 6.0d0]
    real(8) :: dot_product_result
    integer :: n = 3, incx = 1, incy = 1


    ! 向量缩放 (DSCAL)
    call dscal(n, 2.0d0, x, incx)
    print *, "Scaled x vector (DSCAL):", x

    ! 向量加法 (DAXPY): y = y + a*x
    call daxpy(n, 3.0d0, x, incx, y, incy)
    print *, "After DAXPY (y = y + 3x):", y
end program blas_level1
EOF

cat > ${JOB_DIR}/local_run.sh << EOF
#!/bin/bash
source ./env.sh
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
echo -e "\033[0;32m=============================\033[0m"
{ time  -p  mpirun --allow-run-as-root -np 1 --bind-to cpulist:ordered -x OMP_PROC_BIND=close -x OMP_PLACES=cores  -x OMP_NUM_THREADS=1 -x UCX_TLS=sm blas_level1 ; } 2>&1 | tee tee_blas.xlog
echo -e "\033[0;32m=============================\033[0m"
EOF

cat > ${JOB_DIR}/blas-3.8.0-run.sh << EOF
source ./env.sh
flang -o blas_level1 blas_level1.F90 -L\${BLAS_CLANG_PATH}/lib -lblas
./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF


chmod u+x ${JOB_DIR}/env.sh
chmod u+x ${JOB_DIR}/job_run.sh
chmod u+x ${JOB_DIR}/local_run.sh
chmod u+x ${JOB_DIR}/blas-3.8.0-run.sh

set +x && echo_info "Install done!!!" && set -x

[CLEAN]
echo "make clean"

[RUN]
run = mpirun --allow-run-as-root -x OMP_NUM_THREADS=1 -np 1 cmake --version
binary = cmake --version 
nodes = 1

[BATCH]
mpirun --allow-run-as-root -x OMP_NUM_THREADS=1 -np 1 cmake --version

[JOB]
#!/bin/bash
#DSUB -n case_cmake
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=1"
#DSUB -o cmake_out_%J.log
#DSUB -e cmake_err_%J.log
#DSUB -T '2h'

export HOSTFILE=hostfile.cmake
rm -f $HOSTFILE
touch $HOSTFILE
cat ${CCSCHEDULER_ALLOC_FILE} | sort > $HOSTFILE
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
source ./env.sh

ulimit -s unlimited

{ time  -p mpirun  --hostfile $HOSTFILE -np 1 --allow-run-as-root --bind-to cpulist:ordered -x OMP_PROC_BIND=close -x OMP_PLACES=cores  -x OMP_NUM_THREADS=1 -x UCX_TLS=sm mpirun --version ; } 2>&1 | tee tee_mpirun.xlog
