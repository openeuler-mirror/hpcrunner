[SERVER]
11.11.11.11

[DOWNLOAD]
sqlite/3.46.0 https://github.com/sqlite/sqlite/archive/refs/tags/version-3.46.0.tar.gz sqlite-version-3.46.0.tar.gz

[DEPENDENCY]
set -e

module purge
module use $JARVIS_MODULES/modules
./jarvis -install hpckit/2025.1.0.SPC001 any
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1

[APP]
app_name = sqlite
app_version = 3.46.0
compiler = gcc
build_dir = ${JARVIS_DEV}/sqlite/3.46.0-%#MYKGCCVER#%
binary_dir =
case_dir = ${JARVIS_JOBSCRIPT}/sqlite/3.46.0

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

set +x &&  check_rpms_installed tcl-devel tcl || exit 1
set -x
####### build prepare
set +x && echo_info "build prepare!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/sqlite/3.46.0


export CC=`which gcc`
export CXX=`which g++`
export FC=`which gfortran`


####### build start
set +x && echo_info "build start" && set -x

if false; then
tar -zxvf ${JARVIS_DOWNLOAD}/sqlite-version-3.46.0.tar.gz
cd sqlite-version-3.46.0
./configure --prefix=${PATH_INSTALL}
make -j32
make install
fi

####### build done
set +x && echo_info "build done!!!" && set -x


####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
mkdir -p ${JOBDIR}
${BUILD_DIR}/env.sh_gen.sh ${JOBDIR}/env.sh
echo "module load sqlite/3.46.0-%#MYKGCCVER#%" >> ${JOBDIR}/env.sh

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_wrf
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=256"
#DSUB -o pytorch_out_%J.log
#DSUB -e pytorch_err_%J.log
#DSUB -T '2h'

EOF

cat >${JOBDIR}/local_run.sh << EOF
#!/bin/bash
source ./env.sh
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1

DB_FILE="inventory.db"

# 1. 创建表
echo "创建表..."
sqlite3 "\$DB_FILE" "
CREATE TABLE IF NOT EXISTS categories (
    category_id INTEGER PRIMARY KEY AUTOINCREMENT,
    category_name TEXT UNIQUE NOT NULL
);

CREATE TABLE IF NOT EXISTS items (
    item_id INTEGER PRIMARY KEY AUTOINCREMENT,
    item_name TEXT NOT NULL,
    category_id INTEGER,
    quantity INTEGER DEFAULT 0,
    price REAL NOT NULL,
    last_updated DATETIME DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (category_id) REFERENCES categories(category_id)
);
"

# 2. 插入数据
echo "插入数据..."
sqlite3 "\$DB_FILE" "
INSERT OR IGNORE INTO categories (category_name) VALUES 
('食品'), ('饮料'), ('日用品');

INSERT INTO items (item_name, category_id, quantity, price) VALUES
('苹果', 1, 100, 5.50),
('牛奶', 2, 50, 3.20),
('洗发水', 3, 30, 25.80),
('面包', 1, 40, 8.00),
('可乐', 2, 80, 2.50);
"

# 3. 查询数据
echo "查询所有商品..."
sqlite3 -header -column "\$DB_FILE" "
SELECT i.item_id, i.item_name, c.category_name, i.quantity, i.price
FROM items i
JOIN categories c ON i.category_id = c.category_id
ORDER BY c.category_name, i.item_name;
"

# 4. 统计查询
echo "库存统计..."
sqlite3 -header -column "\$DB_FILE" "
SELECT 
    c.category_name,
    COUNT(i.item_id) as item_count,
    SUM(i.quantity) as total_quantity,
    SUM(i.quantity * i.price) as total_value
FROM categories c
LEFT JOIN items i ON c.category_id = i.category_id
GROUP BY c.category_name;
"
rm -f "\$DB_FILE"
EOF

cat > ${JOBDIR}/sqlite-3.46.0-run.sh << EOF
#!/bin/bash
./local_run.sh 2>&1 | tee tee_local_run.xlog
#dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/env.sh
chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/sqlite-3.46.0-run.sh

set +x && echo_info "Install done!!!" && set -x

[CLEAN]
make clean

[RUN]
run =
binary =
nodes = 1
