[SERVER]
11.11.11.11

[DOWNLOAD]
fasta/36.3.8 https://github.com/wrpearson/fasta36/archive/v36.3.8h_04-May-2020.tar.gz fasta36-36.3.8h_04-May-2020.tar.gz
sse2neon/master https://github.com/DLTcollab/sse2neon/archive/refs/heads/master.zip sse2neon-master.zip

[DEPENDENCY]
set -e
set -x
module use $JARVIS_MODULES/modules

./jarvis -install hpckit/2025.1.0.SPC001 any
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule

[APP]
app_name = fasta
app_version = 36.3.8
compiler = bisheng
build_dir = ${JARVIS_APP}/fasta/36.3.8-%#MYKBSVER#%
binary_dir =
case_dir = ${JARVIS_JOBSCRIPT}/fasta/36.3.8

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

####### build prepare
set +x && echo_info "build prepare!!!" && set -x

####### build prepare
install_path=$1
JOBDIR=${JARVIS_JOBSCRIPT}/fasta/36.3.8

####### build start
cd $install_path
if [ ! -d "sse2neon-master" ]; then
unzip ${JARVIS_DOWNLOAD}/sse2neon-master.zip
fi

if [ ! -d "fasta36-36.3.8h_04-May-2020" ]; then
tar --no-same-owner -zxvf ${JARVIS_DOWNLOAD}/fasta36-36.3.8h_04-May-2020.tar.gz
cp sse2neon-master/sse2neon.h fasta36-36.3.8h_04-May-2020/src
fi

if [ ! -f "fasta36-36.3.8h_04-May-2020/bin/fasta36" ]; then
cd fasta36-36.3.8h_04-May-2020

sed -i "15c CC = clang -g -O2" make/Makefile.linux64_sse2
sed -i "29s/$/ -I. /" make/Makefile.linux64_sse2
sed -i 's/emmintrin.h/sse2neon.h/g' src/smith_waterman_sse2.c
sed -i 's/emmintrin.h/sse2neon.h/g' src/global_sse2.c
sed -i 's/emmintrin.h/sse2neon.h/g' src/glocal_sse2.c

cd src
make -j64 -f ../make/Makefile.linux64_sse2
fi
####### build done

####### Install jobscript

if [ ! -d "${JOBDIR}" ]; then
mkdir -p ${JOBDIR}
fi

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash

EOF

cat >${JOBDIR}/local_run.sh << EOF
#!/bin/bash
module purge
module use $JARVIS_MODULES/modules
module load fasta/36.3.8-%#MYKBSVER#%

cd ${BUILD_DIR}/fasta36-36.3.8h_04-May-2020/data
time ../bin/fasta36 -q ../seq/titin_hum.seq ../seq/prot_test.lseg
EOF

cat > ${JOBDIR}/fasta-36.3.8-run.sh << EOF
#!/bin/bash
cd ${JOBDIR}
./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF


chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/fasta-36.3.8-run.sh

[RUN]
