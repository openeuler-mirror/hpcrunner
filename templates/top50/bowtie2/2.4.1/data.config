[SERVER]
11.11.11.11

[DOWNLOAD]
bowtie2/2.4.1  https://jaist.dl.sourceforge.net/project/bowtie-bio/bowtie2/2.4.1/bowtie2-2.4.1-source.zip
simde/master https://github.com/simd-everywhere/simde/archive/refs/heads/master.zip simde-master.zip
case1 http://hgdownload.cse.ucsc.edu/goldenPath/mm10/bigZips/chromFa.tar.gz

[DEPENDENCY]
set -e
set -x

module purge
module use $JARVIS_MODULES/modules
./jarvis -install hpckit/2025.1.0.SPC001 any
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule

unzip ${JARVIS_DOWNLOAD}/bowtie2-2.4.1-source.zip -d ${JARVIS_DEV}
echo "done"

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule

[APP]
fake = 0
app_name = bowtie2
app_version = 2.4.1
compiler = bisheng
build_dir = ${JARVIS_DEV}/bowtie2-2.4.1
binary_dir =
case_dir = ${JARVIS_JOBSCRIPT}/bowtie2/2.4.1
[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

set +x && check_install_path "${PATH_INSTALL}" && set -x
set +x && build_mod_check "${PATH_INSTALL}/bin/bowtie2" "prompt" && set -x
set +x && rm_file_from_base ${PATH_INSTALL}/bin bowtie2  && set -x
####### build prepare
set +x && echo_info "build prepare!!!" && set -x

####### build start
set +x && echo_info "build start" && set -x

export NO_TBB=1
export POPCNT_CAPABILITY=0

if [ ! -d "third_party/simde/simde/x86" ]; then
mkdir -p third_party/simde/simde/x86
fi

if [ -d "simde-master" ]; then
rm -rf simde-master
fi
unzip ${JARVIS_DOWNLOAD}/simde-master.zip
cp -a simde-master/simde third_party/simde
cp ${JARVIS_ROOT}/templates/top50/bowtie2/2.4.1/SSE2NEON.h third_party/simde/simde/x86
make all

if [ ! -d "$PATH_INSTALL/bin" ]; then
mkdir -p $PATH_INSTALL/bin
fi
cp bowtie2 $PATH_INSTALL/bin
cp bowtie2-build $PATH_INSTALL/bin
cp bowtie2-align-l $PATH_INSTALL/bin
cp bowtie2-align-s $PATH_INSTALL/bin
cp bowtie2-build-l $PATH_INSTALL/bin
cp bowtie2-build-s $PATH_INSTALL/bin
cp bowtie2-inspect $PATH_INSTALL/bin
cp bowtie2-inspect-l $PATH_INSTALL/bin
cp bowtie2-inspect-s $PATH_INSTALL/bin

set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/bowtie2/2.4.1
mkdir -p ${JOBDIR}

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_bma
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=128"
#DSUB -o pytorch_out_%J.log
#DSUB -e pytorch_err_%J.log
#DSUB -T '2h'
source env.sh
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1

EOF

cat >${JOBDIR}/local_run.sh << EOF
#!/bin/bash
module purge
module use $JARVIS_MODULES/modules
module load bowtie2/2.4.1-%#MYKBSVER#%

if [ -d "test" ]; then
rm -rf test
fi
mkdir test
cd test
tar --no-same-owner -zxvf ${JARVIS_DOWNLOAD}/chromFa.tar.gz
cp ${JARVIS_DEV}/bowtie2-2.4.1/example/reads/reads_1.fq .
cp ${JARVIS_DEV}/bowtie2-2.4.1/example/reads/reads_2.fq .
cat *.fa > mm10.fa
bowtie2-build mm10.fa mm10
time bowtie2 -p 6 -3 5 --local -x mm10 -1 reads_1.fq -2 reads_2.fq -S example.sam
EOF


cat > ${JOBDIR}/bowtie2-2.4.1-run.sh << EOF
#!/bin/bash
cd ${JOBDIR}

./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/bowtie2-2.4.1-run.sh

set +x && echo_info "Install done!!!" && set -x

[RUN]
