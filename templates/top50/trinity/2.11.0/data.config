[SERVER]
11.11.11.11

[DOWNLOAD]
trinity/2.11.0 https://github.com/trinityrnaseq/trinityrnaseq/releases/download/v2.11.0/trinityrnaseq-v2.11.0.FULL.tar.gz
case1 http://ftp.sra.ebi.ac.uk/vol1/fastq/SRR305/008/SRR3050898/SRR3050898_1.fastq.gz
case2 http://ftp.sra.ebi.ac.uk/vol1/fastq/SRR305/008/SRR3050898/SRR3050898_2.fastq.gz

[DEPENDENCY]
set -e
module purge
module use $JARVIS_MODULES/modules
./jarvis -install hpckit/2025.1.0.SPC001 any
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1/gccmodule

echo "done"

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1/gccmodule

[APP]
fake = 0
app_name = trinity
app_version = 2.11.0
compiler = gcc
build_dir = ${JARVIS_APP}/trinity/2.11.0-%#MYKGCCVER#%/project
binary_dir =
case_dir = ${JARVIS_JOBSCRIPT}/trinity/2.11.0

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

####### build prepare
set +x && echo_info "build prepare!!!" && set -x

####### build start
set +x && echo_info "build start" && set -x

tar --no-same-owner -zxvf ${JARVIS_DOWNLOAD}/trinityrnaseq-v2.11.0.FULL.tar.gz -C ./ --strip-components=1
cd trinity-plugins && tar -zxf ParaFly-0.1.0.tar.gz
cd ../
sed -i '/tar -zxvf ${PARAFLY_CODE}.tar.gz/d' trinity-plugins/Makefile
sed -i 's/\-m64/\-mabi=lp64/g' `grep -rl "\-m64" ./`
sed -i 's/cmake/cmake -DCMAKE_CXX_FLAGS="-O3 -march=armv8.2-a -mtune=tsv110"/g' ./Chrysalis/Makefile ./Inchworm/Makefile
sed -i 's/\-fopenmp/-O3 -march=armv8.2-a -mtune=tsv110 -fopenmp/g' ./trinity-plugins/Makefile

cd trinity-plugins/bamsifter/htslib
make clean
rm -rf build
cp /usr/share/libtool/build-aux/config.guess .
cp /usr/share/libtool/build-aux/config.sub .
cd ..
sed -i "5c#include <string>" sift_bam_max_cov.cpp
sed -i '9c\./configure --prefix=`pwd`/build/ --build=aarch64-unknown-linux-gnu --host=aarch64-unknown-linux-gnu' build_htslib.sh
cd ../..
make -j

cat > ${PATH_INSTALL}/module_tail.modulefile << EOF
prepend-path PATH \${prefix}/project
EOF

####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/trinity/2.11.0
mkdir -p ${JOBDIR}

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_bma
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=128"
#DSUB -o pytorch_out_%J.log
#DSUB -e pytorch_err_%J.log
#DSUB -T '2h'
source env.sh
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1

EOF

cat >${JOBDIR}/local_run.sh << EOF
#!/bin/bash
set -e
set -x
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1/gccmodule
module load trinity/2.11.0-%#MYKGCCVER#%
module load samtools/1.10-%#MYKBSVER#%
module load salmon/1.10.1-%#MYKGCCVER#%
module load jellyfish/2.2.10-%#MYKBSVER#%
module load bowtie2/2.4.1-%#MYKBSVER#%

if [ -d "test" ]; then
rm -rf test
fi
mkdir test
cd test

cp ${JARVIS_DOWNLOAD}/SRR3050898_1.fastq.gz .
cp ${JARVIS_DOWNLOAD}/SRR3050898_2.fastq.gz .
gzip -d SRR3050898_1.fastq.gz
gzip -d SRR3050898_2.fastq.gz

{ time Trinity --seqType fq --left SRR3050898_1.fastq --right SRR3050898_2.fastq --CPU 128 --max_memory 200G --bflyHeapSpaceMax "30G" --output trinity_kp_`date '+%Y%m%d%H%M%S'`; } 2>&1 | tee -a `hostname`_`date '+%Y%m%d%H%M%S'`.log
EOF

cat > ${JOBDIR}/trinity-2.11.0-run.sh << EOF
#!/bin/bash
cd ${JOBDIR}

./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/trinity-2.11.0-run.sh

set +x && echo_info "Install done!!!" && set -x

[RUN]
