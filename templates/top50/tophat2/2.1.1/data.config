[SERVER]
11.11.11.11

[DOWNLOAD]
tophat/2.1.1 https://ccb.jhu.edu/software/tophat/downloads/tophat-2.1.1.tar.gz
case1 http://opengene.org/data/R1.fq.gz
case2 http://opengene.org/data/R2.fq.gz
case3 http://ftp.ensembl.org/pub/release-84/fasta/drosophila_melanogaster/dna/Drosophila_melanogaster.BDGP6.dna.toplevel.fa.gz

[DEPENDENCY]
set -e
set -x

module purge
module use $JARVIS_MODULES/modules
./jarvis -install python2/2.7.16 any
module load python2/2.7.16

./jarvis -install hpckit/2025.1.0.SPC001 any
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule

./jarvis -install boost/1.72.0/clang clang
module load boost-clang/1.72.0-%#MYKBSVER#%

tar --no-same-owner -zxvf ${JARVIS_DOWNLOAD}/tophat-2.1.1.tar.gz -C ${JARVIS_DEV}
echo "done"

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule
module load boost-clang/1.72.0-%#MYKBSVER#%
module load python2/2.7.16

[APP]
fake = 0
app_name = tophat
app_version = 2.1.1
compiler = bisheng
build_dir = ${JARVIS_DEV}/tophat-2.1.1
binary_dir =
case_dir = ${JARVIS_JOBSCRIPT}/tophat/2.1.1
[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

set +x && check_install_path "${PATH_INSTALL}" && set -x
set +x && build_mod_check "${PATH_INSTALL}/bin/tophat2" "prompt" && set -x
set +x && rm_file_from_base ${PATH_INSTALL}/bin tophat2  && set -x
####### build prepare
set +x && echo_info "build prepare!!!" && set -x

####### build start
set +x && echo_info "build start" && set -x

sed -i "341s/<Junction, JunctionStats>//g" src/juncs_db.cpp
sed -i "2708s/<Junction, JunctionStats>//g" src/tophat_reports.cpp

./configure --prefix=$PATH_INSTALL --with-boost=$BOOST_CLANG_PATH CFLAGS="-std=c++14 -fPIC"
make
make install

set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/tophat/2.1.1
mkdir -p ${JOBDIR}

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_bma
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=128"
#DSUB -o pytorch_out_%J.log
#DSUB -e pytorch_err_%J.log
#DSUB -T '2h'
source env.sh
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1

EOF

cat >${JOBDIR}/local_run.sh << EOF
#!/bin/bash
module purge
module use $JARVIS_MODULES/modules
module load tophat/2.1.1-%#MYKBSVER#%
module load bowtie2/2.4.1-%#MYKBSVER#%

if [ -d "test" ]; then
rm -rf test
fi
mkdir test
cd test
gzip -dck ${JARVIS_DOWNLOAD}/Drosophila_melanogaster.BDGP6.dna.toplevel.fa.gz > Drosophila_melanogaster.BDGP6.dna.toplevel.fa
gzip -dck ${JARVIS_DOWNLOAD}/R1.fq.gz > R1.fq
gzip -dck ${JARVIS_DOWNLOAD}/R2.fq.gz > R2.fq
mv Drosophila_melanogaster.BDGP6.dna.toplevel.fa genome.fa
bowtie2-build genome.fa genome
time -p tophat2 -p 128 genome R1.fq R2.fq
EOF


cat > ${JOBDIR}/tophat-2.1.1-run.sh << EOF
#!/bin/bash
cd ${JOBDIR}

./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/tophat-2.1.1-run.sh

set +x && echo_info "Install done!!!" && set -x

[RUN]
