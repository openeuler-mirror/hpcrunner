[SERVER]
11.11.11.11

[DOWNLOAD]
featurecounts/2.0.3 https://sourceforge.net/projects/subread/files/subread-2.0.3/subread-2.0.3-source.tar.gz subread-2.0.3-source.tar.gz

[DEPENDENCY]
set -e
set -x

module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule

echo "done"

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule

[APP]
fake = 0
app_name = featurecounts
app_version = 2.0.3
compiler = bisheng
build_dir = ${JARVIS_APP}/featurecounts/2.0.3-%#MYKBSVER#%
binary_dir =
case_dir = ${JARVIS_JOBSCRIPT}/featurecounts/2.0.3

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

set +x && check_install_path "${PATH_INSTALL}" && set -x
set +x && build_mod_check "${PATH_INSTALL}/bin/featureCounts" "prompt" && set -x
set +x && rm_file_from_base ${PATH_INSTALL}/bin featureCounts  && set -x
####### build prepare
set +x && echo_info "build prepare!!!" && set -x

tar --no-same-owner -zxvf ${JARVIS_DOWNLOAD}/subread-2.0.3-source.tar.gz --strip-components 1 -C ${PATH_INSTALL}

####### build start
set +x && echo_info "build start" && set -x

cd src
sed -i "s|^CCFLAGS =|CCFLAGS = -fsigned-char|" Makefile.Linux longread-one/Makefile

sed -i "s|^CC_EXEC = gcc$|CC_EXEC = clang|" Makefile.Linux longread-one/Makefile

sed -i "s|\(-mtune=core2\)|-mcpu=hip11|" Makefile.Linux longread-one/Makefile

sed -i "s|-ggdb||" Makefile.Linux longread-one/Makefile

make -f Makefile.Linux

####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/featurecounts/2.0.3
mkdir -p ${JOBDIR}

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_bma
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=128"
#DSUB -o pytorch_out_%J.log
#DSUB -e pytorch_err_%J.log
#DSUB -T '2h'
source env.sh
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1

EOF

cat >${JOBDIR}/local_run.sh << EOF
#!/bin/bash
module purge
module use $JARVIS_MODULES/modules
module load featurecounts/2.0.3-%#MYKBSVER#%

cd $PATH_INSTALL/test/featureCounts
time bash ./featureCounts-test.sh
EOF


cat > ${JOBDIR}/featurecounts-2.0.3-run.sh << EOF
#!/bin/bash
cd ${JOBDIR}

./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/featurecounts-2.0.3-run.sh

set +x && echo_info "Install done!!!" && set -x

[RUN]
