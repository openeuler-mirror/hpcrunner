[SERVER]
11.11.11.11

[DOWNLOAD]
true

[DEPENDENCY]
set -e
set -x
module purge
module use $JARVIS_MODULES/modules
./jarvis -install cmake/3.28.2 any
module load cmake/3.28.2
./jarvis -install hpckit/2025.1.0.SPC001 any
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1/gccmodule
module load bisheng/compiler4.2.0.2/bishengmodule
export CC=clang
./jarvis -install metis/5.2.1 bisheng
module load metis/5.2.1-%#MYKBSVER#%

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load cmake/3.28.2
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1/gccmodule
module load bisheng/compiler4.2.0.2/bishengmodule
module load metis/5.2.1-%#MYKBSVER#%

[APP]
fake = 1
app_name = devmetis
app_version = 5.2.1
compiler = bisheng
build_dir = ${JARVIS_DEV}/devmetis/5.2.1-%#MYKBSVER#%
binary_dir =
case_dir = ${JARVIS_JOBSCRIPT}/metis/5.2.1

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

####### build prepare
set +x && echo_info "build prepare!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/metis/5.2.1

####### build start
set +x && echo_info "build start" && set -x


####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
mkdir -p ${JOBDIR}

${BUILD_DIR}/env.sh_gen.sh ${JOBDIR}/env.sh

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
EOF

cat >${JOBDIR}/local_run.sh << EOF
#!/bin/bash
source env.sh
# refer url https://github.com/KarypisLab/METIS/blob/master/manual/manual.pdf
cat > input_graph_file.txt << MYEOF
7 11 011
4 5 1 3 2 2 1
2 1 1 3 2 4 1
5 5 3 4 2 2 2 1 2
3 2 1 3 2 6 2 7 5
1 1 1 3 3 6 2
6 5 2 4 2 7 6
2 6 6 4 5
MYEOF
graphchk ./input_graph_file.txt
EOF

cat > ${JOBDIR}/metis-5.2.1-run.sh << EOF
#!/bin/bash
source env.sh
./local_run.sh 2>&1 | tee tee_local_run.xlog
EOF

chmod u+x ${JOBDIR}/env.sh
chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/metis-5.2.1-run.sh

[RUN]
