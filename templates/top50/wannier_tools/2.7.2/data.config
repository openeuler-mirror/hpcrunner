[SERVER]
11.11.11.11

[DOWNLOAD]
wannier_tools/2.7.2 https://github.com/quanshengwu/wannier_tools/archive/refs/tags/v2.7.2.tar.gz wannier_tools-2.7.2.tar.gz

[DEPENDENCY]
set -e
set -x
module purge
module use $JARVIS_MODULES/modules
./jarvis -install hpckit/2025.1.0.SPC001 any
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule
module load bisheng/%#MYKMPIVER#%/release
module load bisheng/kml25.1.0.SPC001/kml

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule
module load bisheng/%#MYKMPIVER#%/release
module load bisheng/kml25.1.0.SPC001/kml

[APP]
app_name = wannier_tools
app_version = 2.7.2
compiler = bisheng+mpi
build_dir = ${JARVIS_APP}/wannier_tools/2.7.2-%#MYKBSVER#%-%#MYKMPIVER#%/project
binary_dir =${JARVIS_APP}/wannier_tools/2.7.2-%#MYKBSVER#%-%#MYKMPIVER#%
case_dir = ${JARVIS_JOBSCRIPT}/wannier_tools/2.7.2

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

####### build prepare
set +x && echo_info "build prepare!!!" && set -x

set +x && build_mod_check "${BUILD_DIR}/wannier_tools-2.7.2/bin/wt.x" "prompt" && set -x
rm -rf wannier_tools-2.7.2
tar --no-same-owner -xvf ${JARVIS_DOWNLOAD}/wannier_tools-2.7.2.tar.gz 

####### build start
set +x && echo_info "build start" && set -x
cd wannier_tools-2.7.2/src

cp Makefile.gfortran-mpi Makefile

sed -i "12s|optic.o|optic.o orbital_hall.o|" Makefile
sed -i "23c\OFLAG = -O3" Makefile
sed -i "16c F90  = mpif90 -cpp -DMPI" Makefile
sed -i "18c INCLUDE = -I${OPENBLAS_CLANG_PATH}/include" Makefile
#sed -i "29c LIBS = -L${OPENBLAS_CLANG_PATH}/lib -lopenblas" Makefile
sed -i "29c LIBS = -L${HPCKIT_KML}/bisheng/lib -lkml_rt" Makefile

sed -i "1318,1322d" module.f90
sed -i "1318c character(10) , dimension(magnetic_number_max,angular_number):: orb_sign = reshape([character(10)::'','','','s','','','','','','py','pz','px','','','','dxy','dyz','dz2','dxz','dx2-y2','','fy(3x2-y2)','fxyz','fyz2','fz3','fxz2','fz(x2-y2)','fx(x2-3y2)'],[magnetic_number_max,angular_number])" module.f90

#sed -i '1285,1289d' module.f90
#sed -i "1285c character(10) , dimension(magnetic_number_max, angular_number) :: orb_sign = reshape([character(10) :: '','','','s','','','','','','py','pz','px','','','','dxy','dyz','dz2','dxz','dx2-y2','','fy(3x2-y2)','fxyz','fyz2','fz3','fxz2','fz(x2-y2)','fx(x2-3y2)'], [magnetic_number_max, angular_number])" module.f90

sed -i '234d' ham_bulk.f90
sed -i '237d' ham_bulk.f90
sed -i '237c\            pos_direct= irvec(:, iR)+ Origin_cell%wannier_centers_direct(:, i2)- Origin_cell%wannier_centers_direct(:, i1)' ham_bulk.f90
sed -i '239c\            pos_cart= pos_direct(1)*Origin_cell%lattice(:, 1)+ pos_direct(2)*Origin_cell%lattice(:, 2)+ pos_direct(3)*Origin_cell%lattice(:, 3)' ham_bulk.f90
make

mkdir -p ${PATH_INSTALL}/bin
rm  -f ${PATH_INSTALL}/bin/wt.x
ln -s ${BUILD_DIR}/wannier_tools-2.7.2/bin/wt.x ${PATH_INSTALL}/bin/wt.x


####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/wannier_tools/2.7.2
mkdir -p ${JOBDIR}

${BUILD_DIR}/env.sh_gen.sh ${JOBDIR}/env.sh
echo "module load wannier_tools/2.7.2-%#MYKBSVER#%-%#MYKMPIVER#%" >> ${JOBDIR}/env.sh

cp ${BUILD_DIR}/wannier_tools-2.7.2/examples ${JOBDIR}/ -ar


cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_nemo
#DSUB --job_type cosched:hmpi
#DSUB -N 32
#DSUB -nn 1
#DSUB -rpn 32
#DSUB -R "cpu=128"
#DSUB -o job_out_%J.log
#DSUB -e job_err_%J.log
#DSUB -T '2h'

export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
source ./env.sh
cd job_work
{ time   mpirun \$CCS_MPI_OPTIONS -np 32 --map-by ppr:32:node:pe=1  -map-by socket --rank-by core  --bind-to core  --mca btl ^vader,tcp,openib,uct --mca io romio321 --mca pml ucx -x UCX_TLS=sm,self -x UCX_WARN_UNUSED_ENV_VARS=n  -x PATH -x LD_LIBRARY_PATH wt.x ; } 2>&1 | tee tee_out.xlog
EOF

cat >${JOBDIR}/local_run.sh << EOF
#!/bin/bash
source ./env.sh
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
cd local_work/
{ time  mpirun -np 32 --map-by ppr:32:node:pe=1  -map-by socket --rank-by core  --bind-to core  --mca btl ^vader,tcp,openib,uct --mca io romio321 --mca pml ucx -x UCX_TLS=sm,self -x UCX_WARN_UNUSED_ENV_VARS=n  -x PATH -x LD_LIBRARY_PATH wt.x ; } 2>&1 | tee tee_out.xlog
EOF

cat > ${JOBDIR}/wannier_tools-2.7.2-run.sh << EOF
#!/bin/bash
mkdir -p local_work job_work
cp examples/Bi2Se3/.wt.in.travis examples/Bi2Se3/wt.in
if [ ! -d Bi2Se3_hr ]; then
        tar --no-same-owner -zxvf examples/Bi2Se3/Bi2Se3_hr.tar.gz -C examples/Bi2Se3/
fi
cp examples/Bi2Se3/* local_work/ -ar
cp examples/Bi2Se3/* job_work/ -ar
./local_run.sh
dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/env.sh
chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/wannier_tools-2.7.2-run.sh

set +x && echo_info "Install done!!!" && set -x


[RUN]
