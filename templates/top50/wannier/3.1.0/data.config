[SERVER]
11.11.11.11

[DOWNLOAD]
wannier90/3.10 https://codeload.github.com/wannier-developers/wannier90/tar.gz/refs/tags/v3.1.0 wannier90-3.1.0.tar.gz

[DEPENDENCY]
set -e
set -x
module purge
./jarvis -install hpckit/2025.1.0.SPC001 any
module use $JARVIS_MODULES/modules
set +x
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule
module load bisheng/%#MYKMPIVER#%/release
./jarvis -install openblas/0.3.18/clang bisheng
module load openblas-clang/0.3.18-%#MYKBSVER#%

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule
module load bisheng/%#MYKMPIVER#%/release
module load openblas-clang/0.3.18-%#MYKBSVER#%

[APP]
app_name = wannier90
app_version = 3.1.0
compiler = bisheng+mpi
build_dir = ${JARVIS_APP}/wannier90/3.1.0-%#MYKBSVER#%-%#MYKMPIVER#%/project
binary_dir =${JARVIS_JOBSCRIPT}/wannier90/3.1.0
case_dir = ${JARVIS_JOBSCRIPT}/wannier90/3.1.0

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

####### build prepare
set +x && echo_info "build prepare!!!" && set -x

set +x && build_mod_check "${PATH_INSTALL}/bin/wannier90.x" "prompt" && set -x
rm -rf wannier90-3.1.0
tar -xf ${JARVIS_DOWNLOAD}/wannier90-3.1.0.tar.gz

####### build start
set +x && echo_info "build start" && set -x

cd wannier90-3.1.0
cp config/make.inc.gfort make.inc
sed -i '4c F90=flang' make.inc
sed -i '8c MPIF90 = mpif90'  make.inc
sed -i '7c COMMS= mpi' make.inc
sed -i '$c LIBS = -L${OPENBLAS_CLANG_PATH}/lib -lopenblas' make.inc
make 
make install PREFIX=${PATH_INSTALL}

####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/wannier90/3.1.0
mkdir -p ${JOBDIR}

echo "Generating environment script..."
${BUILD_DIR}/env.sh_gen.sh ${JOBDIR}/env.sh
echo "module load wannier90/3.1.0-%#MYKBSVER#%-%#MYKMPIVER#%" >> ${JOBDIR}/env.sh
cp -r ${BUILD_DIR}/wannier90-3.1.0/examples ${JOBDIR}

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_wannier90
#DSUB --job_type cosched:hmpi
#DSUB -N 128
#DSUB -nn 1
#DSUB -rpn 128
#DSUB -R "cpu=128"
#DSUB -o out_%J.log
#DSUB -e err_%J.log
#DSUB -T '2h'

source ./env.sh
cd examples/example03
ulimit -s unlimited
{ time mpirun \$CCS_MPI_OPTIONS -np 128 --allow-run-as-root --bind-to cpulist:ordered -x OMP_PROC_BIND=close -x OMP_PLACES=cores -x UCX_TLS=sm,tcp  wannier90.x silicon.win ; } 2>&1 | tee tee_wannier90.xlog
cat silicon.wout
EOF

cat > ${JOBDIR}/local_run.sh << EOF
#!/bin/bash
source env.sh
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
cd examples/example03
{ time mpirun --allow-run-as-root -np 128 -mca pml ucx -mca btl tcp -x UCX_TLS=sm,tcp  wannier90.x silicon.win ; } 2>&1 | tee tee_wannier90.xlog
cat silicon.wout
EOF

cat > ${JOBDIR}/wannier90-3.1.0-run.sh << EOF
#!/bin/bash
./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/env.sh
chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/wannier90-3.1.0-run.sh

set +x && echo_info "Install done!!!" && set -x
[RUN]
run = export OMPI_ALLOW_RUN_AS_ROOT=1 && export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1 && make tests
binary = 
nodes = 1
