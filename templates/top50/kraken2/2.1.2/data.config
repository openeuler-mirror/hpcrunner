[SERVER]
11.11.11.11

[DOWNLOAD]
kraken2/2.1.2 https://github.com/DerrickWood/kraken2/archive/refs/tags/v2.1.2.tar.gz kraken2-2.1.2.tar.gz
case https://genome-idx.s3.amazonaws.com/kraken/k2_viral_20240904.tar.gz

[DEPENDENCY]
set -e
module purge
module use $JARVIS_MODULES/modules
./jarvis -install hpckit/2025.1.0.SPC001 any
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule

tar --no-same-owner -zxvf ${JARVIS_DOWNLOAD}/kraken2-2.1.2.tar.gz -C ${JARVIS_DEV}

echo "done"

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule

[APP]
fake = 0
app_name = kraken2
app_version = 2.1.2
compiler = bisheng
build_dir = ${JARVIS_DEV}/kraken2-2.1.2
binary_dir =
case_dir = ${JARVIS_JOBSCRIPT}/kraken2/2.1.2

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

set +x && check_install_path "${PATH_INSTALL}" && set -x
set +x && build_mod_check "${PATH_INSTALL}/bin/kraken2" "prompt" && set -x
set +x && rm_file_from_base ${PATH_INSTALL}/bin kraken2  && set -x
####### build prepare
set +x && echo_info "build prepare!!!" && set -x

####### build start
set +x && echo_info "build start" && set -x

if [ ! -d "$PATH_INSTALL/bin" ]; then
mkdir -p $PATH_INSTALL/bin
fi

sed -i "1c\CXX = clang++" src/Makefile
sed -i "2c\CXXFLAGS = -fopenmp -Wall -std=c++11 -O3 -fsigned-char" src/Makefile
bash install_kraken2.sh $PATH_INSTALL/bin

####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/kraken2/2.1.2
mkdir -p ${JOBDIR}

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_bma
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=128"
#DSUB -o pytorch_out_%J.log
#DSUB -e pytorch_err_%J.log
#DSUB -T '2h'
source env.sh
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1

EOF

cat >${JOBDIR}/local_run.sh << EOF
#!/bin/bash
module purge
module use $JARVIS_MODULES/modules
module load kraken2/2.1.2-%#MYKBSVER#%

if [ -d "test" ]; then
rm -rf test
fi
mkdir test
cd test

tar --no-same-owner -zxvf ${JARVIS_DOWNLOAD}/k2_viral_20240904.tar.gz
cp $BUILD_DIR/data/HIV_1.fa .
cp $BUILD_DIR/data/HIV_2.fa .
time kraken2 --db .  --threads 56  --report TEST.report --output TEST.output  --paired HIV_1.fa HIV_2.fa
EOF

cat > ${JOBDIR}/kraken2-2.1.2-run.sh << EOF
#!/bin/bash
cd ${JOBDIR}

./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/kraken2-2.1.2-run.sh

set +x && echo_info "Install done!!!" && set -x

[RUN]
