[SERVER]
11.11.11.11

[DOWNLOAD]
blastz/2004-12-27 https://www.bx.psu.edu/miller_lab/dist/blastz-2004-12-27.deprecated.tar.gz
case1 http://hgdownload.soe.ucsc.edu/goldenPath/hg38/chromosomes/chr4.fa.gz hg38.chr4.fa.gz
case2 http://hgdownload.soe.ucsc.edu/goldenPath/galGal3/chromosomes/chr4.fa.gz galGal3.chr4.fa.gz

[DEPENDENCY]
set -e
module purge
module use $JARVIS_MODULES/modules
./jarvis -install hpckit/2025.1.0.SPC001 any
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1/gccmodule

tar --no-same-owner -zxvf ${JARVIS_DOWNLOAD}/blastz-2004-12-27.deprecated.tar.gz -C ${JARVIS_DEV}
echo "done"

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1/gccmodule

[APP]
fake = 0
app_name = blastz
app_version = 2004-12-27
compiler = gcc
build_dir = ${JARVIS_DEV}/blastz-source
binary_dir =
case_dir = ${JARVIS_JOBSCRIPT}/blastz/2004-12-27

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

set +x && check_install_path "${PATH_INSTALL}" && set -x
set +x && build_mod_check "${PATH_INSTALL}/bin/blastz" "prompt" && set -x
set +x && rm_file_from_base ${PATH_INSTALL}/bin blastz  && set -x
####### build prepare
set +x && echo_info "build prepare!!!" && set -x

####### build start
set +x && echo_info "build start" && set -x

sed -i '6c\CFLAGS= -O3 -mcpu=hip11 -flto -Xlinker -zmuldefs' Makefile
sed -i '1c\#!/usr/bin/perl -w' primate.pl
sed -i '1c\#!/usr/bin/perl -w' rodent.pl
make

export PATH=$BUILD_DIR:$PATH
make test

if [ ! -d "$PATH_INSTALL/bin" ]; then
mkdir -p $PATH_INSTALL/bin
fi
cp blastz $PATH_INSTALL/bin

####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/blastz/2004-12-27
mkdir -p ${JOBDIR}

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_bma
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=128"
#DSUB -o pytorch_out_%J.log
#DSUB -e pytorch_err_%J.log
#DSUB -T '2h'
source env.sh
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1

EOF

cat >${JOBDIR}/local_run.sh << EOF
#!/bin/bash
module purge
module use $JARVIS_MODULES/modules
module load blastz/2004-12-27-%#MYKGCCVER#%

if [ -d "test" ]; then
rm -rf test
fi
mkdir test
cd test

gzip -dck ${JARVIS_DOWNLOAD}/hg38.chr4.fa.gz > hg38.chr4.fa
gzip -dck ${JARVIS_DOWNLOAD}/galGal3.chr4.fa.gz > galGal3.chr4.fa
time blastz hg38.chr4.fa galGal3.chr4.fa C=3 T=2 Z=10 > hg38_c4-vs-galGal3_c4-kp7265.out
EOF

cat > ${JOBDIR}/blastz-2004-12-27-run.sh << EOF
#!/bin/bash
cd ${JOBDIR}

./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/blastz-2004-12-27-run.sh

set +x && echo_info "Install done!!!" && set -x

[RUN]
