[SERVER]
11.11.11.11

[DOWNLOAD]
openmolcas/24.10 https://gitlab.com/Molcas/OpenMolcas/-/archive/v24.10/OpenMolcas-v24.10.tar.gz

[DEPENDENCY]
set -e
set -x

module purge
module use $JARVIS_MODULES/modules

./jarvis -install hpckit/2025.1.0.SPC001 any
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1/gccmodule
module load gcc/%#MYKMPIVER#%/hmpi/release

export INTERFACE64=1
./jarvis -install openblas/0.3.18 gcc
module load openblas/0.3.18-%#MYKGCCVER#%

./jarvis -install globalarrays/5.9.2 gcc+mpi
module load globalarrays/5.9.2-%#MYKGCCVER#%-%#MYKMPIVER#%

./jarvis -install libxc/6.2.2 gcc
module load libxc/6.2.2-%#MYKGCCVER#%

tar --no-same-owner -zxvf ${JARVIS_DOWNLOAD}/OpenMolcas-v24.10.tar.gz -C ${JARVIS_DEV}
echo "done"

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1/gccmodule
module load gcc/%#MYKMPIVER#%/hmpi
module load openblas/0.3.18-%#MYKGCCVER#%
module load globalarrays/5.9.2-%#MYKGCCVER#%-%#MYKMPIVER#%
module load libxc/6.2.2-%#MYKGCCVER#%

[APP]
fake = 0
app_name = openmolcas
app_version = 24.10
compiler = gcc+mpi
build_dir = ${JARVIS_DEV}/OpenMolcas-v24.10
binary_dir =
case_dir = ${JARVIS_JOBSCRIPT}/openmolcas/24.10

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

set +x && check_install_path "${PATH_INSTALL}" && set -x
set +x && build_mod_check "${PATH_INSTALL}/pymolcas" "prompt" && set -x
set +x && rm_file_from_base ${PATH_INSTALL} pymolcas  && set -x
####### build prepare
set +x && echo_info "build prepare!!!" && set -x

####### build start
set +x && echo_info "build start" && set -x

if [ -d "build" ]; then
rm -rf build
fi
mkdir build
cd build

export OPENBLASROOT=$OPENBLAS_PATH
export GAROOT=$GLOBALARRAYS_PATH

cmake .. -DCMAKE_BUILD_TYPE=Release \
         -DCMAKE_INSTALL_PREFIX=$PATH_INSTALL \
         -DLINALG=OpenBLAS -DMPI=ON -DGA=ON \
         -DEXTERNAL_LIBXC=$LIBXC_PATH \
         -DINSTALL_TESTS=ON

make -j16
make install

cat > ${PATH_INSTALL}/module_tail.modulefile << EOF
prepend-path PATH ${PATH_INSTALL}
EOF

####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/openmolcas/24.10
mkdir -p ${JOBDIR}

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_bma
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=128"
#DSUB -o pytorch_out_%J.log
#DSUB -e pytorch_err_%J.log
#DSUB -T '2h'
source env.sh
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1

EOF

cat >${JOBDIR}/local_run.sh << EOF
#!/bin/bash
module purge
module use $JARVIS_MODULES/modules
module load openmolcas/24.10-%#MYKGCCVER#%-hmpi25.0

if [ -d "test" ]; then
rm -rf test
fi
mkdir test
cd test
time pymolcas verify --path ./ 100
EOF


cat > ${JOBDIR}/openmolcas-24.10-run.sh << EOF
#!/bin/bash
cd ${JOBDIR}

./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/hmmer-3.4-run.sh

set +x && echo_info "Install done!!!" && set -x

[RUN]
