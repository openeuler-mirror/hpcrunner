[SERVER]
11.11.11.11

[DOWNLOAD]
scanpy/1.10.2 https://github.com/scverse/scanpy/archive/refs/tags/1.10.2.tar.gz scanpy-1.10.2.tar.gz
case1 https://s3-eu-west-1.amazonaws.com/pfigshare-u-files/40347877/s1d1_filtered_feature_bc_matrix.h5
case2 https://s3-eu-west-1.amazonaws.com/pfigshare-u-files/40347877/s1d3_filtered_feature_bc_matrix.h5
case3 https://figshare.com/ndownloader/files/45788454 adata.raw_compressed.h5ad

[DEPENDENCY]
set -e
module purge
module use $JARVIS_MODULES/modules
./jarvis -install hpckit/2025.1.0.SPC001 any
module load hpckit/2025.1.0.SPC001
./jarvis -install anaconda3/2024.10 any
module load anaconda3/2024.10
echo "done"

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule
module load anaconda3/2024.10

[APP]
fake = 1
app_name = scanpy
app_version = 1.10.2
compiler = bisheng
build_dir = ${JARVIS_APP}/scanpy/1.10.2-%#MYKBSVER#%/project
binary_dir =
case_dir = ${JARVIS_JOBSCRIPT}/scanpy/1.10.2

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

####### build prepare
set +x && echo_info "build prepare!!!" && set -x

####### build start
set +x && echo_info "build start" && set -x
source $CONDA_SH
set -x

SCANPY_ENV=${BUILD_DIR}/conda_env/scanpy
if [ ! -d "${SCANPY_ENV}" ]; then
conda create --prefix=${SCANPY_ENV} python=3.9 -y
fi
conda activate ${SCANPY_ENV}

if [ ! -d "scanpy-1.10.2" ]; then
git clone https://github.com/scverse/scanpy.git -b 1.10.2 scanpy-1.10.2
#tar --no-same-owner -zxvf ${JARVIS_DOWNLOAD}/scanpy-1.10.2.tar.gz
fi
cd scanpy-1.10.2

pip install . \
--trusted-host mirrors.huaweicloud.com -i https://mirrors.huaweicloud.com/repository/pypi/simple

####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/scanpy/1.10.2
mkdir -p ${JOBDIR}

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_bma
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=128"
#DSUB -o pytorch_out_%J.log
#DSUB -e pytorch_err_%J.log
#DSUB -T '2h'
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1

EOF

cat >${JOBDIR}/local_run.sh << EOF
#!/bin/bash
source $CONDA_SH
conda activate ${SCANPY_ENV}

conda install libmambapy conda -y
pip install asv \
--trusted-host mirrors.huaweicloud.com -i https://mirrors.huaweicloud.com/repository/pypi/simple

export JARVIS_DOWNLOAD=${JARVIS_DOWNLOAD}
cd ${BUILD_DIR}/scanpy-1.10.2/benchmarks
git checkout .
git apply ${JARVIS_ROOT}/templates/top50/scanpy/1.10.2/benchmarks.patch
asv machine --yes
asv run
EOF


cat > ${JOBDIR}/scanpy-1.10.2-run.sh << EOF
#!/bin/bash
cd ${JOBDIR}

./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/scanpy-1.10.2-run.sh

set +x && echo_info "Install done!!!" && set -x

[RUN]
