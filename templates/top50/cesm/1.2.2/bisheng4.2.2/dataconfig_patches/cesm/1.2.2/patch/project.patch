+      logical, optional,          intent(in)    :: vector 
+
+! !OUTPUT PARAMETERS: 
+
+      type(AttrVect),             intent(inout) :: aVout
+
+
+! !REVISION HISTORY:
+! 16Aug06 - R. Jacob <jacob@mcs.anl.gov> - initial version from breakup
+!           of Copy_.
+!
