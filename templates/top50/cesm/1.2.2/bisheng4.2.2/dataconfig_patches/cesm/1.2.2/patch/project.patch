+    
+    fh1 = abs(fh)
+
+    list_item=> top_file
+    
+    do while(associated(list_item%file) )
+       if(abs(list_item%file%fh) == fh1) then
+          file => list_item%file
+          exit
+       end if
+       list_item=>list_item%next
+    end do
