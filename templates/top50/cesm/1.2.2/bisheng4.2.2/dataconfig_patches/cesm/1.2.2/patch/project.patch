+
+}
+
+int MPI_Alltoallv(void *sendbuf, int *sendcounts,
+		  int *sdispls, MPI_Datatype sendtype,
+                  void *recvbuf, int *recvcounts,
+		  int *rdispls, MPI_Datatype recvtype,
+                  MPI_Comm comm) 
+
+{
+  int send_offset;
