+    ! -------------------------------------------------
+    ! Pull information about the IO decomposition
+    ! -------------------------------------------------
+    if(Debug) print *, __PIO_FILE__,__LINE__,iodesc%Write%elemTYPE, iodesc%Write%fileTYPE
