+    ! set the error return code
+    !--------------------------
+    iostat=ierr
+
+    !-----------------------------------------------------------------------
+    !EOC
+#ifdef TIMING
+    call t_stopf("pio_write_darray")
+#endif
+# 818 "piodarray.F90.in"
+  end subroutine write_darray_bin_double
