+    integer(kind=PIO_OFFSET) :: offset   ! local offset
+
+    integer :: fstatus(MPI_STATUS_SIZE)
+
+    integer(i4) :: cnt
+    logical, parameter :: Check = .TRUE.
+#ifdef TIMING
+    call t_startf("pio_write_mpiio_{TYPE}")
