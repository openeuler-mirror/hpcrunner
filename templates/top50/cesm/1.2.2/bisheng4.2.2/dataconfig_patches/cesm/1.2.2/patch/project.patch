+       else
+          print *,myrank,': alloc_trace_off: '
+       endif
+       call memmon_trace_off(myrank)
+       print *,''
+
+    endif
+
+#endif
+#endif
+
+  end subroutine alloc_trace_off
+
+
+end module alloc_mod
