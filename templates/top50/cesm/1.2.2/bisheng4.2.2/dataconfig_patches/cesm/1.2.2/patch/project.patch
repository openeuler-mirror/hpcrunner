+#endif
+#ifdef BGQ
+   numPsets = numpsets; 
+#endif
+    
+   if(rank == 0) { printf("number of IO nodes in block: %i \n",numIONodes);}
+   if(rank == 0) { printf("number of Psets in block : %i \n",numPsets);}
+   if(rank == 0) { printf("number of compute nodes in Pset: %i \n",numNodesInPset);}
+
+   int psetNum;
