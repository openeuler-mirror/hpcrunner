+   integer, parameter, public :: pio_msg_putvara_1d = 387
+   integer, parameter, public :: pio_msg_putvara_2d = 388
+   integer, parameter, public :: pio_msg_putvara_3d = 389
+   integer, parameter, public :: pio_msg_putvara_4d = 390
