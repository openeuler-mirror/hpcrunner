+     datarep   = 'native'
+     iotype    = File%iotype
+     glen      = iodesc%glen
+     offset    = iodesc%IOmap%start 
+
+     !-------------------------------
+     ! write the record control word
+     !-------------------------------
+
+     reclen=glen*c_sizeof(iobuf(1))
