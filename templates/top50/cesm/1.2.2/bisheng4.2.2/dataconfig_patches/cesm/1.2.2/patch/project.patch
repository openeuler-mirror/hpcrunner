+           amode = MPI_MODE_RDONLY
+           call MPI_file_open(File%iosystem%IO_comm,fname,amode,File%iosystem%info,File%fh,ierr)
+           if(Check) call CheckMPIreturn('open_mpiio: after call to MPI_file_open: ',ierr)
