+  
+!  ierr = pio_inq_vartype(ifh, ivid, itype)
+!  ierr = pio_inq_vartype(ofh, ovid, otype)
+
+  
+  if( ivid%type.ne.ovid%type) then
+     write(6,*) 'WARNING: copy_pio_var coercing type ', ivid%type, ' to ',ovid%type
+  end if
