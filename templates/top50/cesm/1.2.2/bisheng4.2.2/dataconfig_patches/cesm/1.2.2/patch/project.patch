+subroutine writedarray_handler(iosystem)
+  use pio
+  use pio_kinds
+  use pio_msg_mod
+  use pio_support, only : debugAsync
+#ifndef NO_MPIMOD
+  use mpi !_EXTERNAL
+#endif
+  implicit none
+#ifdef NO_MPIMOD
+  include 'mpif.h' !_EXTERNAL
+#endif
+  type(iosystem_desc_t) :: iosystem
+  type(file_desc_t), pointer :: file
+  type(var_desc_t) :: v
+  type(io_desc_t), pointer :: iodesc
+
