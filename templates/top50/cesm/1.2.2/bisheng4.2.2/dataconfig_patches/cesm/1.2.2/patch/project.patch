+
+! !INPUT PARAMETERS: 
+!
+      type(List),         intent(in)    :: iList2 
+
+! !INPUT/OUTPUT PARAMETERS: 
+!
+      type(List),         intent(inout) :: iList1
+
+! !REVISION HISTORY:
+!  6Aug02 - J. Larson - Initial version
+!EOP ___________________________________________________________________
+
