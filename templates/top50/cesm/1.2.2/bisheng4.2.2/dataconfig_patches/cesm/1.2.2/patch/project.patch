+
+! !REVISION HISTORY:
+! 12Feb03 - J. Larson <larson@mcs.anl.gov> Working refactored version  
+!EOP ___________________________________________________________________
+
+  character(len=*),parameter :: myname_=myname//'::test_indices_'
+  type(List)   :: tList
