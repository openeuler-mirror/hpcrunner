+  allocate(str(dims(1),dims(2)))
+#elif({DIMS} == 3)
+  allocate(str(dims(1),dims(2),dims(3)))
+#elif({DIMS} == 4)
+  allocate(str(dims(1),dims(2),dims(3),dims(4)))
+#elif({DIMS} == 5)
+  allocate(str(dims(1),dims(2),dims(3),dims(4),dims(5)))
+#endif
