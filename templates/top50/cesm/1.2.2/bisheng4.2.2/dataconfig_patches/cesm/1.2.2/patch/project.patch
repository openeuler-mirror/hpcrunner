+     ! increment the file  offset pointer
+     !-----------------------------------
+     File%Offset = File%Offset + reclen
+#else
+     call piodie(__PIO_FILE__,__LINE__,'PIO was not built with -DUSEMPIIO')
+     ierr=0
+#endif
+#ifdef TIMING
+    call t_stopf("pio_write_mpiio_{TYPE}")
+#endif
+
