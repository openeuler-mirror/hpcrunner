+my $iyear0  = `echo $RUN_STARTDATE | cut -c1-4  | sed -e 's/^0*//'`;
+$iyear0 =~ s/\n/ /g; # remove imbedded newline   
+$iyear0 = $iyear0+0;
+
+my $imonth0 = `echo $RUN_STARTDATE | cut -c6-7  | sed -e 's/^0*//'`;
+$imonth0 =~ s/\n/ /g; # remove imbedded newline   
+$imonth0 = $imonth0+0;
