[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1/gccmodule
module load gcc/%#MYKMPIVER#%/release
module load hdf5/1.8.20-%#MYKGCCVER#%-%#MYKMPIVER#%
module add pnetcdf/1.11.2-%#MYKGCCVER#%-%#MYKMPIVER#%
module add netcdf/4.7.4-%#MYKGCCVER#%-%#MYKMPIVER#%-hdf51.8.20-pnetcdf1.11.2
module add proj/5.2.0-%#MYKGCCVER#%
module add hdf4/4.2.15-%#MYKGCCVER#%-%#MYKMPIVER#%
module add jasper/1.900.2-%#MYKGCCVER#%
module add gdal/2.2.4-%#MYKGCCVER#%
module add jasper/1.900.2-%#MYKGCCVER#%
module add g2clib/1.6.0-%#MYKGCCVER#%
module add udunits/2.2.28-%#MYKGCCVER#%
module add gsl/2.6-%#MYKGCCVER#%
module add hdf-eos2/2.20-%#MYKGCCVER#%
module add hdf-eos5/1.16-%#MYKGCCVER#%
module add mesa/3.1-%#MYKGCCVER#%
module add vis5dplus/1.3.0-%#MYKGCCVER#%
module add szip/2.1.1-%#MYKGCCVER#%
module add $JARVIS_MODULES/lib/cdo/2.5.3-%#MYKGCCVER#%-%#MYKMPIVER#%
module add ImageMagick/7.1.0-%#MYKGCCVER#%
module add esmf/8.7.0-%#MYKGCCVER#%-%#MYKMPIVER#%

[APP]
app_name = ncl
app_version = 6.3.0
compiler = gcc+mpi
build_dir = ${JARVIS_APP}/ncl/6.3.0-%#MYKGCCVER#%-%#MYKMPIVER#%/project
binary_dir =
case_dir = ${JARVIS_JOBSCRIPT}/ncl/6.3.0

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

####### build prepare
set +x && echo_info "build prepare!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/ncl/6.3.0

export CC=gcc FC=gfortran CXX=g++
export GCC_PATH=${HPCKIT_COM_KGCC} HMPI_PATH=${HPCKIT_HMPI}/gcc/release/hmpi
### IF LOCAL
if true; then
set -x && build_mod_check "${PATH_INSTALL}/bin/ncl" "prompt" && set +x
rm -f ${PATH_INSTALL}/bin/ncl

rm -rf triangle
unzip -o ${JARVIS_DOWNLOAD}/triangle.zip -d triangle

rm -rf ncl_ncarg-6.3.0
tar -xvf ${JARVIS_DOWNLOAD}/ncl-6.3.0.tar.gz
cd ncl_ncarg-6.3.0

cp  ../triangle/triangle.c ni/src/lib/hlu
cp  ../triangle/triangle.h ni/src/lib/hlu
sed -i '21c #define CCompiler   gcc' config/LINUX
sed -i '22c #define FCompiler   gfortran' config/LINUX
sed -i '23c #define CtoFLibraries   -lgfortran -lmathlib -ltirpc' config/LINUX
sed -i '24c #define CtoFLibrariesUser   -lgfortran -lmathlib -ltirpc' config/LINUX
sed -i '25c #define CcOptions      -fno-asm -fPIC -fopenmp -std=c99 -fsigned-char -Xlinker -zmuldefs -Wl,--copy-dt-needed-entries' config/LINUX
sed -i '26c #define FcOptions      -fPIC -fno-second-underscore -fno-range-check -fopenmp -fallow-argument-mismatch -Wl,--copy-dt-needed-entries' config/LINUX

sed -i '40a void _swapshort (register char *bp, register unsigned n);' ncarview/src/lib/libncarg_ras/misc.c
sed -i '41a void _swaplong (register char *bp, register unsigned n);' ncarview/src/lib/libncarg_ras/misc.c
sed -i '46c #        @$(CAT) Copyright' ncarview/src/bin/ictrans/yMakefile
sed -i "168c CC_LD           = g\\\+\\\+" ni/src/ncl/yMakefile
sed -i "170c CC_LD           = g\\\+\\\+" ni/src/ncl/yMakefile
sed -i '61c EXCSRCS = bcopyswap.c logic32.c' common/src/libncarg_c/yMakefile
sed -i '62c EXFSRCS = gbytes.f sbytes.f' common/src/libncarg_c/yMakefile
sed -i '62a EXOBJS  = bcopyswap.o sbytes.o gbytes.o logic32.o ' common/src/libncarg_c/yMakefile
sed -i '943c                  long len1,len2,len3,len4;' ni/src/lib/hlu/Format.c
sed -i '1286c                  long len1,len2,len3,len4;' ni/src/lib/hlu/Format.c
sed -i "9660c IF ((CEX1(1:1).EQ.' ') .AND. (LCX1 .EQ. 1)) LCX1=0" ncarg2d/src/libncarg/conpack/CodeIftran
sed -i '9660s/^/        /' ncarg2d/src/libncarg/conpack/CodeIftran
sed -i "9662c IF ((CEX2(1:1).EQ.' ') .AND. (LCX2 .EQ. 1)) LCX2=0" ncarg2d/src/libncarg/conpack/CodeIftran
sed -i '9662s/^/        /' ncarg2d/src/libncarg/conpack/CodeIftran
sed -i "9664c IF ((CEX3(1:1).EQ.' ') .AND. (LCX3 .EQ. 1)) LCX3=0" ncarg2d/src/libncarg/conpack/CodeIftran
sed -i '9664s/^/        /' ncarg2d/src/libncarg/conpack/CodeIftran
sed -i "9669a DO (III=1,LBUF)\nCBUF(III:III)=' '\nEND DO" ncarg2d/src/libncarg/conpack/CodeIftran
sed -i '9670s/^/        /' ncarg2d/src/libncarg/conpack/CodeIftran
sed -i '9671s/^/        /' ncarg2d/src/libncarg/conpack/CodeIftran
sed -i '9672s/^/        /' ncarg2d/src/libncarg/conpack/CodeIftran
sed -i "9669c CBUF(1:LBUF)=' ' " ncarg2d/src/libncarg/conpack/CodeIftran
sed -i '9669s/^/        /' ncarg2d/src/libncarg/conpack/CodeIftran
sed -i "9794c CBUF(1:LBUF)='0' " ncarg2d/src/libncarg/conpack/CodeIftran
sed -i '9794s/^/            /' ncarg2d/src/libncarg/conpack/CodeIftran
sed -i "19s/\\(\=\\).*/\\1/" ncarg2d/src/libncarg_gks/bwi/argb2ci.f
sed -i "19s/\\(\=\\)/\\1 INT(Z'40000000'))/" ncarg2d/src/libncarg_gks/bwi/argb2ci.f
sed -i "20s/\\(\=\\).*/\\1/" ncarg2d/src/libncarg_gks/bwi/argb2ci.f
sed -i "20s/\\(\=\\)/\\1 INT(Z'00FF0000'))/" ncarg2d/src/libncarg_gks/bwi/argb2ci.f
sed -i "21s/\\(\=\\).*/\\1/" ncarg2d/src/libncarg_gks/bwi/argb2ci.f
sed -i "21s/\\(\=\\)/\\1 INT(Z'0000FF00'))/" ncarg2d/src/libncarg_gks/bwi/argb2ci.f
sed -i "22s/\\(\=\\).*/\\1/" ncarg2d/src/libncarg_gks/bwi/argb2ci.f
sed -i "22s/\\(\=\\)/\\1 INT(Z'000000FF'))/" ncarg2d/src/libncarg_gks/bwi/argb2ci.f
sed -i "34s/\\(\=\\).*/\\1/" ncarg2d/src/libncarg_gks/bwi/argb2ci.f
sed -i "34s/\\(\=\\)/\\1 (iand(index, RMASK) \/ INT(Z'0000FFFF')) \/ 255./" ncarg2d/src/libncarg_gks/bwi/argb2ci.f
sed -i "35s/\\(\=\\).*/\\1/" ncarg2d/src/libncarg_gks/bwi/argb2ci.f
sed -i "35s/\\(\=\\)/\\1 (iand(index, GMASK) \/ INT(Z'000000FF')) \/ 255./" ncarg2d/src/libncarg_gks/bwi/argb2ci.f
rm ./config/ymake-filter -f

printf "%s\n" "y" "" "y" "${PATH_INSTALL}" "" "y" "y" "y" "n" "y" "y" "y" "y" "y" "y" "y" "y" "y" "y" "/lib64 /usr/lib64 /usr/include/X11" "/usr/include /usr/include/freetype2 /usr/include/freetype2/freetype /usr/include/X11 /usr/include/tirpc" "" "" |while read -r line; do echo $line; sleep 1; done | ./Configure

rm config/Site.local -f
cp ${JARVIS_ROOT}/dataconfig_patches/ncl/6.3.0/Site.local config/ -f

sed -i "12c #define YmakeRoot ${PATH_INSTALL}" config/Site.local
sed -i "16c #define LibSearch -L$GCC_PATH/lib -L$GCC_PATH/lib64_public -L$GCC_PATH/lib64 -L$HMPI_PATH/lib -L$HDF5_PATH/lib -L$PNETCDF_PATH/lib -L$NETCDF_PATH/lib -L$HDF4_PATH/lib -L$PROJ_PATH/lib -L$SZIP_PATH/lib -L$GDAL_PATH/lib -L$JASPER_PATH/lib -L$G2CLIB_PATH/lib -L$UDUNITS_PATH/lib -L$GSL_PATH/lib -L$HDF_EOS2_PATH/lib -L$HDF_EOS5_PATH/lib -L$MESA_PATH/lib -L$VIS5DPLUS_PATH/lib -L/usr/lib64" config/Site.local
sed -i "17c #define IncSearch -I$GCC_PATH/include -I$HMPI_PATH/include -I$HDF5_PATH/include -I$PNETCDF_PATH/include -I$NETCDF_PATH/include -I$HDF4_PATH/include -I$PROJ_PATH/include -I$GDAL_PATH/include -I$JASPER_PATH/include -I$JASPER_PATH/include/jasper -I$G2CLIB_PATH/include -I$UDUNITS_PATH/include -I$GSL_PATH/include -I$GSL_PATH/include/gsl -I$HDF_EOS2_PATH/include -I$HDF_EOS5_PATH/include -I$MESA_PATH/include -I$MESA_PATH/include/GL -I$VIS5DPLUS_PATH/include -I$SZIP_PATH/include -I/usr/include -I/usr/include/freetype2 -I/usr/include/freetype2/freetype -I/usr/include/X11 -I/usr/include/tirpc" config/Site.local
sed -i "12c #define YmakeRoot ${PATH_INSTALL}" config/Site.local
sed -i "22c #define BuildTRIANGLE 1" config/Site.local
fi ### FI LOCAL

if true; then

make Everything 2>&1 |tee make.log

sed -i "385s/\-m{\$nbits}//" ${PATH_INSTALL}/bin/WRAPIT
sed -i "599s/\-m{\$nbits}//" ${PATH_INSTALL}/bin/WRAPIT
sed -i "784s/\-m{\$nbits}//" ${PATH_INSTALL}/bin/WRAPIT


ln -sf ${PATH_INSTALL}/share/ncarg/* ${PATH_INSTALL}/lib/ncarg/
fi

if true; then
cd ${PATH_INSTALL}
if [ -f ${JARVIS_DOWNLOAD}/share_ncarg_samples_251125.tar.gz ]; then
tar -zxvf  ${JARVIS_DOWNLOAD}/share_ncarg_samples_251125.tar.gz
fi

mkdir ${PATH_INSTALL}/share/ncarg/nclex/nug -p
mkdir ${PATH_INSTALL}/share/ncarg/data/nug -p

cd ${PATH_INSTALL}/share/ncarg/nclex/nug
base_url="https://www.ncl.ucar.edu/Document/Manuals/NCL_User_Guide/Scripts/" && echo "NCLLogoWeb.jpg,NCL_cdo_remap_bilinear_CMIP5_grid_to_1x1deg_grid.ksh,NUG.shtml,NUG_GrADS_binary_data.ncl,NUG_ICON_triangles_colored.ncl,NUG_axis_annotations.ncl,NUG_bar_chart.ncl,NUG_bar_chart_col_above_below.ncl,NUG_bar_chart_multi.ncl,NUG_bipolar_grid_MPI-ESM.ncl,NUG_bipolar_grid_MPI-ESM_subregion.ncl,NUG_cdo_remap_bilinear_CMIP5_grid_to_1x1deg_grid.ksh,NUG_color_Land_Ocean.ncl,NUG_color_country_user.ncl,NUG_colormaps.ncl,NUG_contour_dashpattern.ncl,NUG_contour_filled_map.ncl,NUG_contour_fillpattern.ncl,NUG_contour_labels.ncl,NUG_contour_map.ncl,NUG_contour_map_add_zonal_average.ncl,NUG_curvilinear_basic.ncl,NUG_curvilinear_contour_PyNGL.py,NUG_curvilinear_grid.ncl,NUG_date_format.ncl,NUG_function_procedure.ncl,NUG_globe_orography_grid_resolution.ncl,NUG_grid_resolution_comparison.ncl,NUG_histograms-transparent.ncl,NUG_histograms.ncl,NUG_insert_logo.ncl,NUG_labelbar_title.ncl,NUG_labelbars.ncl,NUG_legends.ncl,NUG_map_countries.ncl,NUG_map_default.ncl,NUG_map_grid_and_tickmark_settings.ncl,NUG_map_land_ocean_settings.ncl,NUG_map_resolutions.ncl,NUG_map_selected_countries.ncl,NUG_map_settings.ncl,NUG_masking.ncl,NUG_multi_timeseries.ncl,NUG_multiple_plots_along_y.ncl,NUG_panel_3x2_plot.ncl,NUG_panel_control.ncl,NUG_panel_plot.ncl,NUG_panel_plot_3x2.ncl,NUG_panel_vp.ncl,NUG_plot_in_5_steps.ncl,NUG_plot_rotated_grid.ncl,NUG_polar_NH.ncl,NUG_polyline_polygon_polymarker.ncl,NUG_polyline_polygon_polymarker_old.ncl,NUG_primitives.ncl,NUG_projections.ncl,NUG_projections_mollweide.ncl,NUG_projections_robinson.ncl,NUG_read_ASCII_1.ncl,NUG_read_ASCII_2.ncl,NUG_read_ASCII_3.ncl,NUG_read_Binary_1.ncl,NUG_read_Binary_GrADS.ncl,NUG_read_CSV_1.ncl,NUG_read_CSV_1_noloop.ncl,NUG_read_CSV_2.ncl,NUG_rectilinear_contour_PyNGL.py,NUG_rectilinear_slice_PyNGL.py,NUG_rectilinear_vector_PyNGL.py,NUG_regrid_bilinear_CMIP5_grid_to_1x1deg_grid.ncl,NUG_regrid_curvilinear_to_rectilinear_bilinear_weights_ESMF.ncl,NUG_regrid_curvilinear_to_rectilinear_bilinear_wgts_destgrid_ESMF.ncl,NUG_regrid_rectilinear_to_curvilinear_bilinear_wgts_destgrid_ESMF.ncl,NUG_regrid_unstructured_to_rectilinear_bilinear_wgts_ESMF.ncl,NUG_regrid_unstructured_to_rectilinear_bilinear_wgts_destgrid_ESMF.ncl,NUG_shapefile_plot.ncl,NUG_shapefile_plot_data.ncl,NUG_slice_plot.ncl,NUG_statistics_linear_regression.ncl,NUG_statistics_running_mean.ncl,NUG_strings.ncl,NUG_system_calls.ncl,NUG_template_script.ncl,NUG_text_settings.ncl,NUG_title_strings.ncl,NUG_transparent_filled_contour.ncl,NUG_transparent_land_sea_mask_Africa.ncl,NUG_triangular_grid_ICON.ncl,NUG_tripolar_grid_STORM.ncl,NUG_unstructured_ICON_triangles_PyNGL.py,NUG_unstructured_contour_cellfill_PyNGL.py,NUG_unstructured_grid.ncl,NUG_unstructured_grid_ICON.ncl,NUG_use_Fortran_subroutines.ksh,NUG_use_Fortran_subroutines.ncl,NUG_vector_curly.ncl,NUG_vector_default.ncl,NUG_vector_plot_colorized.ncl,NUG_vector_plot_overlay.ncl,NUG_wind_mag.ncl,NUG_write_ASCII_1.ncl,NUG_write_ASCII_2.ncl,NUG_write_ASCII_3.ncl,NUG_write_ASCII_4.ncl,NUG_write_ASCII_5.ncl,NUG_write_Binary_1.ncl,NUG_write_Binary_2.ncl,NUG_write_netCDF_1.ncl,NUG_write_netCDF_2.ncl,NUG_xy_plot.ncl,NUG_xy_plot_res.ncl,NUG_xy_plot_simple_PyNGL.py,NUG_xy_plot_timeseries.ncl,NUG_xy_plot_timeseries_2.ncl,generate_nug_table.py,gmt2ncl_coltab.ksh,grads2ncl_coltab.ksh,open_file.ncl" | tr ',' '\n' | while read filename; do if [[ -n $filename ]] && [[ ! -f $filename ]]; then wget --no-check-certificate "${base_url}${filename}"; elif [[ -n $filename ]]; then echo "文件已存在，跳过: $filename"; fi; done

cd ${PATH_INSTALL}/share/ncarg/data/nug


base_url="https://www.ncl.ucar.edu/Document/Manuals/NCL_User_Guide/Data/" && echo "dummy_file.bin,example.bin,topo.bin,asc1.txt,asc2.txt,asc3.txt,data_country_user.txt,GMT-BYR-03.cpt,multiple_columns.csv,ps_grads_model.ctl,ps_grads_model.dat,Test_6h.csv,atm_phy_mag0004_1985.nc,camse_unstructured_grid.nc,CNTASN_1m_200103_grid_T_curvilinear_grid.nc,FR-LAND_regional_model_0.11deg.nc,FR-LAND_regional_model_0.44deg.nc,HSURF_regional_model_0.11deg.nc,HSURF_regional_model_0.44deg.nc,MITgcm_rectilinear_grid_3D.nc,orog_mod1_rectilinear_grid_2D.nc,orog_mod2_rectilinear_grid_2D.nc,orog_mod3_rectilinear_grid_2D.nc,r2b4_amip.nc,rectilinear_grid_2D.nc,rectilinear_grid_3D.nc,sftlf_mod1_rectilinear_grid_2D.nc,sftlf_mod2_rectilinear_grid_2D.nc,sftlf_mod3_rectilinear_grid_2D.nc,T2M_ERAINT_rectilinear_grid_2D.nc,t_in_Celsius_1.nc,t_in_Celsius_2.nc,ta_ps_850.nc,tas_mod1_hist_rectilin_grid_2D.nc,tas_mod1_rcp45_rectilin_grid_2D.nc,tas_mod1_rcp85_rectilin_grid_2D.nc,tas_mod2_hist_rectilin_grid_2D.nc,tas_mod2_rcp45_rectilin_grid_2D.nc,tas_mod2_rcp85_rectilin_grid_2D.nc,tas_mod3_hist_rectilin_grid_2D.nc,tas_mod3_rcp45_rectilin_grid_2D.nc,tas_mod3_rcp85_rectilin_grid_2D.nc,tas_mod4_hist_rectilin_grid_2D.nc,tas_mod4_rcp45_rectilin_grid_2D.nc,tas_mod4_rcp85_rectilin_grid_2D.nc,tas_mon_1961-1990_rectilinear_grid_2D.nc,tas_rectilinear_grid_2D.nc,tas_rotated_grid_EUR11.nc,thetao_curvilinear_ocean.nc,tos_ocean_bipolar_grid.nc,triangular_grid_ICON.nc,tripolar_grid_STORM.nc,uas_rectilinear_grid_2D.nc,uv300.nc,vas_rectilinear_grid_2D.nc" | tr ',' '\n' | while read filename; do if [[ -n $filename ]] && [[ ! -f $filename ]]; then wget --no-check-certificate "${base_url}${filename}"; elif [[ -n $filename ]]; then echo "文件已存在，跳过: $filename"; fi; done

