source ${JARVIS_LIBSHELL}
check_rpms_installed tar byacc bison expat-devel expat libtirpc-devel libX11 libX11-devel libXmu libXmu-devel libXaw libXaw-devel flex flex-devel freetype-devel libpng-devel libpng libjpeg-turbo-devel libjpeg-turbo  libXi libSM-devel libXi-devel libXext-devel pkgconf curl libcurl-devel zlib-devel cairo cairo-devel pixman pixman-devel patch || exit 1
