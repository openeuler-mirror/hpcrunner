ln -sf ../../data/nug/* .
mkdir DEU_adm -p
cd DEU_adm
base_url="https://gitlab.dkrz.de/pythoncourse/material/-/raw/master/data/Shapefiles/DEU_adm/" && echo "DEU_adm0.cpg,DEU_adm0.csv,DEU_adm0.dbf,DEU_adm0.prj,DEU_adm0.shp,DEU_adm0.shx,DEU_adm1.cpg,DEU_adm1.csv,DEU_adm1.dbf,DEU_adm1.prj,DEU_adm1.shp,DEU_adm1.shx,license.txt,output.csv" | tr ',' '\n' | while read filename; do if [[ -n $filename ]] && [[ ! -f $filename ]]; then wget --no-check-certificate "${base_url}${filename}"; elif [[ -n $filename ]]; then echo "文件已存在，跳过: $filename"; fi; done
cd ..
fi

cat > ${PATH_INSTALL}/module_tail.modulefile << EOF
prepend-path PATH ${PATH_INSTALL}/bin
setenv NCARG_FONTCAPS ${PATH_INSTALL}/lib/ncarg/fontcaps
setenv NCARG_GRAPHCAPS ${PATH_INSTALL}/lib/ncarg/graphcaps
setenv NCARG_ROOT ${PATH_INSTALL}
setenv NCARG_DATABASE ${PATH_INSTALL}/lib/ncarg/database
setenv NCARG_LIB ${PATH_INSTALL}/lib
setenv NCARG_NCARG ${PATH_INSTALL}/lib/ncarg
setenv NCL_RESFILE_PATH ${PATH_INSTALL}/lib/ncarg/resfiles
EOF

echo "Creating job script directory: ${JOBDIR}"
mkdir -p ${JOBDIR}

echo "Copying files to job script directory..."
cp ${JARVIS_ROOT}/dataconfig_patches/ncl/6.3.0/ncl_test.sh ${JOBDIR}/ -f
cp ${PATH_INSTALL}/share/ncarg/nclex/nug/  ${JOBDIR}/ -r


####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
${BUILD_DIR}/env.sh_gen.sh ${JOBDIR}/env.sh
echo "Appending module load to env.sh..."
echo "module load ncl/6.3.0-%#MYKGCCVER#%-%#MYKMPIVER#%" >> ${JOBDIR}/env.sh
echo "export LD_LIBRARY_PATH=$GCC_PATH/lib64_public:\$LD_LIBRARY_PATH" >> ${JOBDIR}/env.sh

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_ncl
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=1"
#DSUB -o ncl_out_%J.log
#DSUB -e ncl_err_%J.log
#DSUB -T '2h'

export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
source ./env.sh

ulimit -s unlimited

EOF

cat > ${JOBDIR}/local_run.sh << EOF
source env.sh
./ncl_test.sh
EOF

cat > ${JOBDIR}/ncl-6.3.0-run.sh << EOF
./local_run.sh 2>&1 | tee tee_local_run.xlog
#dsub -s job_run.sh
EOF


chmod u+x ${JOBDIR}/env.sh
chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/ncl-6.3.0-run.sh

set +x && echo_info "Install done!!!" && set -x

[BATCH]
mpirun --allow-run-as-root -x OMP_NUM_THREADS=1 -np 1 ncl_test.sh

[RUN]
run = mpirun -v --allow-run-as-root -x OMP_NUM_THREADS=1 -np 1  ${JARVIS_JOBSCRIPT}/NCL/6.3.0/ncl_test.sh
binary = 
nodes = 1

[JOB]
#!/bin/bash
#DSUB -n case_ncl
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=1"
#DSUB -o ncl_out_%J.log
#DSUB -e ncl_err_%J.log
#DSUB -T '2h'

export HOSTFILE=hostfile.ncl
rm -f $HOSTFILE
touch $HOSTFILE
cat ${CCSCHEDULER_ALLOC_FILE} | sort > $HOSTFILE
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
source ./env.sh

ulimit -s unlimited

{ time  -p mpirun  --hostfile $HOSTFILE -np 1 --allow-run-as-root --bind-to cpulist:ordered -x OMP_PROC_BIND=close -x OMP_PLACES=cores  -x OMP_NUM_THREADS=1 -x UCX_TLS=sm sh tast.sh ; } 2>&1 | tee tee_ncl.xlog

