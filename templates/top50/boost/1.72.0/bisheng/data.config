[SERVER]
11.11.11.11

[DOWNLOAD]
true

[DEPENDENCY]
set -e
set -x

module purge
module use $JARVIS_MODULES/modules
./jarvis -install cmake/3.28.2 any
module load cmake/3.28.2
./jarvis -install hpckit/2025.1.0.SPC001 any
set +x
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1/gccmodule
module load bisheng/compiler4.2.0.2/bishengmodule
./jarvis -install boost/1.72.0/clang bisheng
set -x 
exit 0

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load cmake/3.28.2
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1/gccmodule
module load bisheng/compiler4.2.0.2/bishengmodule
module load boost-clang/1.72.0-%#MYKBSVER#%

[APP]
fake = 1
app_name = devboost
app_version = 1.72.0
compiler = bisheng
build_dir = ${JARVIS_DEV}/boost/1.72.0
binary_dir = ${JARVIS_DEV}/boost/1.72.0
case_dir = ${JARVIS_JOBSCRIPT}/boost/1.72.0

[BUILD]
set -e
set -x
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1

#### prepare
set +x && echo_info "build prepare!!!" && set -x

#### build
set +x && echo_info "build start..." && set -x

set +x && echo_info "build done!!!" && set -x

### install
set +x && echo_info "install..." && set -x

JOB_DIR="${JARVIS_JOBSCRIPT}/boost/1.72.0"
mkdir -p ${JOB_DIR}
${JARVIS_DEV}/boost/1.72.0/env.sh_gen.sh ${JOB_DIR}/env.sh
### ENV PRJ_URL_BOOST_01720 from module file:boost-clang/1.72.0-bisheng4.2.0.2
cp ${PRJ_URL_BOOST_01720} ${JOB_DIR}/ -ar
cp ${JARVIS_ROOT}/dataconfig_patches/boost_test.sh  ${JOB_DIR}/ -ar

cat > ${JOB_DIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_boost
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=1"
#DSUB -o cmake_out_%J.log
#DSUB -e cmake_err_%J.log
#DSUB -T '2h'

export HOSTFILE=hostfile.boost
rm -f \$HOSTFILE
touch \$HOSTFILE
cat \${CCSCHEDULER_ALLOC_FILE} | sort > \$HOSTFILE
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
source ./env.sh

ulimit -s unlimited

{ time  -p mpirun  --hostfile $HOSTFILE -np 1 --allow-run-as-root --bind-to cpulist:ordered -x OMP_PROC_BIND=close -x OMP_PLACES=cores  -x OMP_NUM_THREADS=1 -x UCX_TLS=sm sleep 30 ; } 2>&1 | tee tee_boost.xlog
EOF

cat > ${JOB_DIR}/local_run.sh << EOF
#!/bin/bash
source ./env.sh
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
echo -e "\033[0;32m=============================\033[0m"
{ time  -p  ./boost_test.sh ; } 2>&1 | tee tee_boost.xlog
echo -e "\033[0;32m=============================\033[0m"
EOF

cat > ${JOB_DIR}/boost-1.72.0-run.sh << EOF
#!/bin/bash
source ./env.sh
./local_run.sh 2>&1 | tee tee_local_run.xlog
#dsub -s job_run.sh
EOF


chmod u+x ${JOB_DIR}/env.sh
chmod u+x ${JOB_DIR}/job_run.sh
chmod u+x ${JOB_DIR}/local_run.sh
chmod u+x ${JOB_DIR}/boost-1.72.0-run.sh
chmod u+x ${JOB_DIR}/*.sh

set +x && echo_info "install done!!!" && set -x
exit 0

[CLEAN]
echo "make clean"

[RUN]
run = mpirun --allow-run-as-root -x OMP_NUM_THREADS=1 -np 1 cmake --version
binary = cmake --version 
nodes = 1

[BATCH]
mpirun --allow-run-as-root -x OMP_NUM_THREADS=1 -np 1 cmake --version

[JOB]
#!/bin/bash
#DSUB -n case_cmake
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=1"
#DSUB -o cmake_out_%J.log
#DSUB -e cmake_err_%J.log
#DSUB -T '2h'

export HOSTFILE=hostfile.cmake
rm -f $HOSTFILE
touch $HOSTFILE
cat ${CCSCHEDULER_ALLOC_FILE} | sort > $HOSTFILE
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
source ./env.sh

ulimit -s unlimited

{ time  -p mpirun  --hostfile $HOSTFILE -np 1 --allow-run-as-root --bind-to cpulist:ordered -x OMP_PROC_BIND=close -x OMP_PLACES=cores  -x OMP_NUM_THREADS=1 -x UCX_TLS=sm mpirun --version ; } 2>&1 | tee tee_mpirun.xlog
