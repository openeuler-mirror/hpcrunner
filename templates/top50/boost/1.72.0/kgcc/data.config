[SERVER]
11.11.11.11

[DOWNLOAD]
true

[DEPENDENCY]
set -e
set -x

module purge
module use $JARVIS_MODULES/modules
./jarvis -install cmake/3.28.2 any
module load cmake/3.28.2
./jarvis -install hpckit/2025.1.0.SPC001 any
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1/gccmodule
./jarvis -install boost/1.72.0 gcc

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load cmake/3.28.2
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1/gccmodule

[APP]
fake = 1
app_name = devboost
app_version = 1.72.0
compiler = gcc
build_dir = ${JARVIS_DEV}/boost/1.72.0
binary_dir = ${JARVIS_DEV}/boost/1.72.0
case_dir = ${JARVIS_JOBSCRIPT}/boost/1.72.0

[BUILD]
set -e
set -x

####  build
echo "build start"
echo "build done!!!"

#### install jobsript for case test
echo "Install start"
JOB_DIR="${JARVIS_JOBSCRIPT}/boost/1.72.0"
mkdir -p ${JOB_DIR}
${JARVIS_DEV}/boost/1.72.0/env.sh_gen.sh ${JOB_DIR}/env.sh
echo "module load boost/1.72.0-%#MYKGCCVER#%" >> ${JOB_DIR}/env.sh
cat > ${JOB_DIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_cmake
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=1"
#DSUB -o cmake_out_%J.log
#DSUB -e cmake_err_%J.log
#DSUB -T '2h'

export HOSTFILE=hostfile.cmake
rm -f \$HOSTFILE
touch \$HOSTFILE
cat \${CCSCHEDULER_ALLOC_FILE} | sort > \$HOSTFILE
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
source ./env.sh

ulimit -s unlimited

{ time  -p mpirun  --hostfile $HOSTFILE -np 1 --allow-run-as-root --bind-to cpulist:ordered -x OMP_PROC_BIND=close -x OMP_PLACES=cores  -x OMP_NUM_THREADS=1 -x UCX_TLS=sm HelloWorld ; } 2>&1 | tee tee_hmpi.xlog
EOF

cat > ${JOB_DIR}/local_run.sh << EOF
#!/bin/bash
source ./env.sh
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
echo -e "\033[0;32m=============================\033[0m"
{ time  -p  ./HelloWorld ; } 2>&1 | tee tee_hmpi.xlog
echo -e "\033[0;32m=============================\033[0m"
EOF

cat > ${JOB_DIR}/HelloWorld.cpp <<'EOF'
#include <boost/date_time/posix_time/posix_time.hpp>
#include <iostream>
#include <unistd.h> // for sleep()
#include <boost/filesystem.hpp>
int main() {
    using namespace boost::posix_time;
    
    // 开始计时
    ptime start_time = microsec_clock::local_time();
    
    // 模拟耗时操作
    sleep(2); // 休眠2秒
    
    // 结束计时
    ptime end_time = microsec_clock::local_time();
    
    // 计算耗时
    time_duration elapsed = end_time - start_time;
    std::cout << "耗时: " << elapsed.total_milliseconds() << " 毫秒" << std::endl;
   
    boost::filesystem::path p("test.txt");
    if (boost::filesystem::exists(p)) {
        std::cout << p << " exists\n";
        std::cout << "File size: " << boost::filesystem::file_size(p) << " bytes\n";
    } else {
        std::cout << p << " does not exist\n";
    } 
    return 0;
}

EOF
cat > ${JOB_DIR}/boost-1.72.0-%#MYKGCCVER#%-run.sh << EOF
#!/bin/bash
source ./env.sh
echo "file size" > test.txt
g++ -std=c++11 -o HelloWorld HelloWorld.cpp -I\${BOOST_PATH}/include -L\${BOOST_PATH}/lib -lboost_system -lboost_filesystem
./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF


chmod u+x ${JOB_DIR}/env.sh
chmod u+x ${JOB_DIR}/job_run.sh
chmod u+x ${JOB_DIR}/local_run.sh
chmod u+x ${JOB_DIR}/boost-1.72.0-%#MYKGCCVER#%-run.sh

echo "Install done!!!"

[CLEAN]
echo "make clean"

[RUN]
run = mpirun --allow-run-as-root -x OMP_NUM_THREADS=1 -np 1 cmake --version
binary = cmake --version 
nodes = 1

[BATCH]
mpirun --allow-run-as-root -x OMP_NUM_THREADS=1 -np 1 cmake --version

[JOB]
#!/bin/bash
#DSUB -n case_cmake
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=1"
#DSUB -o cmake_out_%J.log
#DSUB -e cmake_err_%J.log
#DSUB -T '2h'

export HOSTFILE=hostfile.cmake
rm -f $HOSTFILE
touch $HOSTFILE
cat ${CCSCHEDULER_ALLOC_FILE} | sort > $HOSTFILE
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
source ./env.sh

ulimit -s unlimited

{ time  -p mpirun  --hostfile $HOSTFILE -np 1 --allow-run-as-root --bind-to cpulist:ordered -x OMP_PROC_BIND=close -x OMP_PLACES=cores  -x OMP_NUM_THREADS=1 -x UCX_TLS=sm mpirun --version ; } 2>&1 | tee tee_mpirun.xlog
