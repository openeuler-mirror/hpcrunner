[SERVER]
11.11.11.11

[DOWNLOAD]
wtdbg2/2.5 https://github.com/ruanjue/wtdbg2/archive/refs/tags/v2.5.tar.gz wtdbg2-2.5.tar.gz
case1 http://www.cbcb.umd.edu/software/PBcR/data/selfSampleData.tar.gz

[DEPENDENCY]
set -e
module purge
module use $JARVIS_MODULES/modules
./jarvis -install hpckit/2025.1.0.SPC001 any
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1/gccmodule

echo "done"

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1/gccmodule

[APP]
fake = 0
app_name = wtdbg2
app_version = 2.5
compiler = gcc
build_dir = ${JARVIS_DEV}/wtdbg2-2.5
binary_dir =
case_dir = ${JARVIS_JOBSCRIPT}/wtdbg2/2.5

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

set +x && check_install_path "${PATH_INSTALL}" && set -x
set +x && build_mod_check "${PATH_INSTALL}/bin/wtdbg2" "prompt" && set -x
set +x && rm_file_from_base ${PATH_INSTALL}/bin wtdbg2  && set -x
####### build prepare
set +x && echo_info "build prepare!!!" && set -x

####### build start
set +x && echo_info "build start" && set -x

tar --no-same-owner -zxvf ${JARVIS_DOWNLOAD}/wtdbg2-2.5.tar.gz -C ${JARVIS_DEV}

cp ${JARVIS_ROOT}/templates/top50/wtdbg2/2.5/SSE2NEON.h ./sse2neon.h

sed -i "5c\BIN := ${PATH_INSTALL}/bin" Makefile
sed -i '12s|-mpopcnt -msse4.2|-march=armv8-a|' Makefile
sed -i '14s|-mpopcnt -msse4.2|-march=armv8-a|' Makefile
sed -i '18s|$| sse2neon.h|' Makefile
sed -i 's|^#include <emmintrin.h>|//&|' ksw.c
sed -i '29i #include "sse2neon.h"' ksw.c
sed -i 's|^#include <emmintrin.h>|//&|' poacns.h
sed -i 's|^#include <tmmintrin.h>|//&|' poacns.h
sed -i '30i #include "sse2neon.h"' poacns.h
sed -i '1198s|^|//|' poacns.h
sed -i '1201s|^|//|' poacns.h

if [ ! -d "${PATH_INSTALL}/bin" ]; then
mkdir -p ${PATH_INSTALL}/bin
fi

make
make install

####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/wtdbg2/2.5
mkdir -p ${JOBDIR}

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_bma
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=128"
#DSUB -o pytorch_out_%J.log
#DSUB -e pytorch_err_%J.log
#DSUB -T '2h'
source env.sh
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1

EOF

cat >${JOBDIR}/local_run.sh << EOF
#!/bin/bash
module purge
module use $JARVIS_MODULES/modules
module load wtdbg2/2.5-%#MYKGCCVER#%

if [ -d "selfSampleData" ]; then
rm -rf selfSampleData
fi
tar --no-same-owner -zxvf ${JARVIS_DOWNLOAD}/selfSampleData.tar.gz
cd selfSampleData
cp ${JARVIS_DEV}/wtdbg2-2.5/scripts/fq2fa.pl .
./fq2fa.pl pacbio_filtered.fastq > pacbio_filtered.fasta
wtdbg2 -x rs -g 4.6m -t 16 -i pacbio_filtered.fasta -fo pacbio
wtpoa-cns -t 16 -i pacbio.ctg.lay.gz -fo pacbio.ctg.fa
EOF

cat > ${JOBDIR}/wtdbg2-2.5-run.sh << EOF
#!/bin/bash
cd ${JOBDIR}

./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/wtdbg2-2.5-run.sh

set +x && echo_info "Install done!!!" && set -x

[RUN]
