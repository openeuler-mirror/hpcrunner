[SERVER]
11.11.11.11

[DOWNLOAD]
true

[DEPENDENCY]
set -e

module purge
module use $JARVIS_MODULES/modules
./jarvis -install hpckit/2025.1.0.SPC001 any
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0
export CC=clang CXX=clang++
./jarvis -install snappy/1.2.0 bisheng
module load snappy/1.2.0-%#MYKBSVER#%

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0
module load snappy/1.2.0-%#MYKBSVER#%

[APP]
fake = 1
app_name = devsnappy
app_version = 1.2.0
compiler = gcc
build_dir = ${JARVIS_DEV}/devsnappy/1.2.0-%#MYKBSVER#%
binary_dir =
case_dir = ${JARVIS_JOBSCRIPT}/snappy/1.2.0

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

#set +x &&  check_rpms_installed tcl-devel tcl || exit 1
#set -x
####### build prepare
set +x && echo_info "build prepare!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/snappy/1.2.0


####### build start
set +x && echo_info "build start" && set -x


####### build done
set +x && echo_info "build done!!!" && set -x


####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
mkdir -p ${JOBDIR}
${BUILD_DIR}/env.sh_gen.sh ${JOBDIR}/env.sh

cp ${JARVIS_DOWNLOAD}/snappy-1.2.0.tar.gz ${JOBDIR}/

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_snappy
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=256"
#DSUB -o job_out_%J.log
#DSUB -e job_err_%J.log
#DSUB -T '2h'

EOF

cat >${JOBDIR}/local_run.sh << EOF
#!/bin/bash
source ./env.sh
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
if [ ! -f snappy-1.2.0 ]; then
	tar -zxvf snappy-1.2.0.tar.gz 
fi
cp snappy-1.2.0/testdata . -ar
snappy_benchmark
EOF

cat > ${JOBDIR}/snappy-1.2.0-run.sh << EOF
#!/bin/bash
./local_run.sh 2>&1 | tee tee_local_run.xlog
#dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/env.sh
chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/snappy-1.2.0-run.sh

set +x && echo_info "Install done!!!" && set -x

[CLEAN]
make clean

[RUN]
run =
binary =
nodes = 1
