[SERVER]
11.11.11.11

[DOWNLOAD]
deepmd-kit/3.0.1 https://codeload.github.com/deepmodeling/deepmd-kit/tar.gz/refs/tags/v3.0.1 deepmd-kit-3.0.1.tar.gz
lammps/stable_29Aug2024_update1 https://github.com/lammps/lammps/archive/stable_29Aug2024_update1.tar.gz stable_29Aug2024_update1.tar.gz

[DEPENDENCY]
set -e
set -x

module purge
module use $JARVIS_MODULES/modules
./jarvis -install anaconda3/2023.3 any
./jarvis -install hpckit/2025.1.0.SPC001 any
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1/gccmodule
module load gcc/%#MYKMPIVER#%/release

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load anaconda3/2023.3
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1/gccmodule
module load gcc/%#MYKMPIVER#%/release
source ${CONDA_SH}


[APP]
app_name = deepmd-kit
app_version = 3.0.1
compiler = gcc+mpi
build_dir = ${JARVIS_APP}/deepmd-kit/3.0.1-%#MYKGCCVER#%-%#MYKMPIVER#%/project
binary_dir =
mod_exc_dir = jax-jax-v0.4.30;conda_env/jax
case_dir = ${JARVIS_JOBSCRIPT}/deepmd-kit/3.0.1

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

####### build prepare
set +x && echo_info "build prepare!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/deepmd-kit/3.0.1
CONDA_DEEPMD_ENV=${BUILD_DIR}/conda_env/dpmd

set +x && build_mod_check "${BUILD_DIR}/lammps-stable_29Aug2024_update1/bin/lmp_mpi" "prompt" && set -x
rm -rf stable_29Aug2024_update1 
rm -f ${BUILD_DIR}/lammps-stable_29Aug2024_update1/bin/lmp_mpi
tar -xzf ${JARVIS_DOWNLOAD}/stable_29Aug2024_update1.tar.gz 
conda create --prefix=${CONDA_DEEPMD_ENV} python=3.9
source ${CONDA_SH}
conda activate ${CONDA_DEEPMD_ENV}

export CC=gcc CXX=g++ FC=gfortran 
export DP_VARIANT=cpu
export DP_ENABLE_TENSORFLOW=1
#pip install tensorflow-aarch64==2.9.3 -i http://cmc-cd-mirror.rnd.huawei.com/pypi/simple/ --trusted-host=cmc-cd-mirror.rnd.huawei.com
pip install tensorflow-aarch64==2.9.3 -i https://mirrors.huaweicloud.com/repository/pypi/simple --trusted-host mirrors.huaweicloud.com
rm -rf deepmd-kit-3.0.1
tar -xvf ${JARVIS_DOWNLOAD}/deepmd-kit-3.0.1.tar.gz 

pip install -U cmake


cd deepmd-kit-3.0.1
pip install .
pip uninstall numpy  # 先卸载当前版本
pip install numpy==1.23.5  # 安装兼容版本

cd source
rm -rf build
mkdir build && cd build
cmake .. -DENABLE_TENSORFLOW=TRUE -DUSE_TF_PYTHON_LIBS=TRUE  -DCMAKE_VERBOSE_MAKEFILE=1 -DCMAKE_INSTALL_PREFIX=$1   -DLAMMPS_SOURCE_ROOT=${BUILD_DIR}/lammps-stable_29Aug2024_update1
make -j  16 
make install
echo “install lammps!!!!”
make lammps
cd ${JARVIS_DEV}/deepmd-kit/3.0.1-conda2023.3/lammps-stable_29Aug2024_update1/src/
cp -r ${JARVIS_DEV}/deepmd-kit/3.0.1-conda2023.3/deepmd-kit-3.0.1/source/build/USER-DEEPMD .
cd ../
mkdir build
cd build
cmake -D PKG_KSPACE=ON -D PKG_EXTRA-FIX=ON -D PKG_KSPACE=ON -D PKG_USER-DEEPMD=ON -D PKG_Obj_mpi=ON -D LAMMPS_INSTALL_RPATH=ON -D BUILD_SHARED_LIBS=yes  -D CMAKE_INSTALL_PREFIX=$1 -D CMAKE_INSTALL_LIBDIR=lib -D CMAKE_INSTALL_FULL_LIBDIR=$1/lib ../cmake
make -j12
make install 
cp -r ${JARVIS_DEV}/deepmd-kit/3.0.1-conda2023.3/lammps-stable_29Aug2024_update1/ $1
conda deactivate
echo "Install done!!!"
JOBDIR=${JARVIS_JOBSCRIPT}/deepmd-kit/3.0.1
echo "Creating job script directory: ${JARVIS_JOBSCRIPT}/deepmd-kit/3.0.1/"
mkdir -p ${JARVIS_JOBSCRIPT}/deepmd-kit/3.0.1

echo "Copying files to job script directory..."
cp -ar ${BUILD_DIR}/deepmd-kit-3.0.1/examples/water/  ${JOBDIR}/water_org


cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_dpmd
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=1"
#DSUB -o job_out_%J.log
#DSUB -e job_err_%J.log
#DSUB -T '2h'

export HOSTFILE=hostfile.dpmd
source env.sh
conda activate ${CONDA_DEEPMD_ENV}
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM
export OMP_NUM_THREADS=16
export DP_INTRA_OP_PARALLELISM_THREADS=16
export DP_INTER_OP_PARALLELISM_THREADS=8
rm -rf ./water
cp water_org water -ar
cd water/se_e2_a
dp --tf train input.json
dp --pt compress -i model.pb -o model-compress.pb
cd ../lmp
ln -sf ../se_e2_a/model-compress.pb .

{ time  -p lmp_mpi -i in.lammps ; } 2>&1 | tee tee_deepmd.xlog

conda deactivate
EOF

cat > ${JOBDIR}/local_run.sh << EOF
#!/bin/bash
source env.sh
conda activate ${CONDA_DEEPMD_ENV}
export OMP_NUM_THREADS=16
export DP_INTRA_OP_PARALLELISM_THREADS=16
export DP_INTER_OP_PARALLELISM_THREADS=8
rm -rf ./water
cp water_org water -a
cd water/se_e2_a
dp --tf train input.json
dp --pt compress -i model.pb -o model-compress.pb
cd ../lmp
ln -sf ../se_e2_a/model-compress.pb .
{ time  -p lmp_mpi -i in.lammps ; } 2>&1 | tee tee_deepmd.xlog
conda deactivate
EOF
cat > ${JOBDIR}/deepmd-3.0.1-run.sh << EOF
#!/bin/bash
./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF


chmod u+x ${JOBDIR}/env.sh
chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/deepmd-3.0.1-run.sh

set +x && echo_info "Install done!!!" && set -x

[CLEAN]
echo "make clean"

[RUN]
run = mpirun --allow-run-as-root -x OMP_NUM_THREADS=1 -np 1  bash -c " conda init bash"
binary = 
nodes = 1

[BATCH]
conda init bash
source ~/.bashrc
conda activate base

[JOB]
#!/bin/bash
#DSUB -n case_cmake
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=1"
#DSUB -o cmake_out_%J.log
#DSUB -e cmake_err_%J.log
#DSUB -T '2h'

export HOSTFILE=hostfile.cmake
rm -f $HOSTFILE
touch $HOSTFILE
cat ${CCSCHEDULER_ALLOC_FILE} | sort > $HOSTFILE
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
source ./env.sh

ulimit -s unlimited

{ time  -p mpirun  --hostfile $HOSTFILE -np 1 --allow-run-as-root --bind-to cpulist:ordered -x OMP_PROC_BIND=close -x OMP_PLACES=cores  -x OMP_NUM_THREADS=1 -x UCX_TLS=sm conda activate base ; } 2>&1 | tee tee_Anaconda3.xlog

