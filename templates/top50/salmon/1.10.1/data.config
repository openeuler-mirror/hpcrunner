[SERVER]
11.11.11.11

[DOWNLOAD]
salmon/1.10.1 https://github.com/COMBINE-lab/salmon/archive/refs/tags/v1.10.1.tar.gz salmon-1.10.1.tar.gz
pufferfish/1.10.1 https://github.com/COMBINE-lab/pufferfish/archive/refs/tags/salmon-v1.10.1.zip pufferfish-salmon-v1.10.1.zip
rapmap/0.14.1 https://github.com/COMBINE-lab/RapMap/archive/refs/tags/salmon-v0.14.1.zip RapMap-salmon-v0.14.1.zip
cereal/1.3.2 https://github.com/USCiLab/cereal/archive/refs/tags/v1.3.2.tar.gz cereal-1.3.2.tar.gz
onetbb/2021.5.0 https://github.com/oneapi-src/oneTBB/archive/refs/tags/v2021.5.0.tar.gz oneTBB-2021.5.0.tar.gz
libgff/2.0.0 https://github.com/COMBINE-lab/libgff/archive/v2.0.0.tar.gz libgff-2.0.0.tar.gz
stadenio/1.14.15 https://github.com/jkbonfield/io_lib/releases/download/io_lib-1-14-15/io_lib-1.14.15.tar.gz io_lib-1.14.15.tar.gz
case1 ftp://ftp.ebi.ac.uk/pub/databases/gencode/Gencode_mouse/release_M23/gencode.vM23.transcripts.fa.gz
case2 ftp://ftp.ebi.ac.uk/pub/databases/gencode/Gencode_mouse/release_M23/GRCm38.primary_assembly.genome.fa.gz

[DEPENDENCY]
set -e
module purge
module use $JARVIS_MODULES/modules
./jarvis -install hpckit/2025.1.0.SPC001 any
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1/gccmodule

./jarvis -install cmake/3.28.2 any
module load cmake/3.28.2

./jarvis -install boost/1.72.0 gcc
module load boost/1.72.0-%#MYKGCCVER#%

tar --no-same-owner -zxvf ${JARVIS_DOWNLOAD}/salmon-1.10.1.tar.gz -C ${JARVIS_DEV}
echo "done"

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1/gccmodule
module load cmake/3.28.2
module load boost/1.72.0-%#MYKGCCVER#%

[APP]
fake = 0
app_name = salmon
app_version = 1.10.1
compiler = gcc
build_dir = ${JARVIS_DEV}/salmon-1.10.1
binary_dir =
case_dir = ${JARVIS_JOBSCRIPT}/salmon/1.10.1

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

set +x && check_install_path "${PATH_INSTALL}" && set -x
set +x && build_mod_check "${PATH_INSTALL}/bin/salmon" "prompt" && set -x
set +x && rm_file_from_base ${PATH_INSTALL}/bin salmon  && set -x
####### build prepare
set +x && echo_info "build prepare!!!" && set -x

check_rpms_installed jemalloc jemalloc-devel

####### build start
set +x && echo_info "build start" && set -x

sed -i '33c\cp ${JARVIS_DOWNLOAD}/pufferfish-salmon-v1.10.1.zip  ${EXTERNAL_DIR}/pufferfish.zip' scripts/fetchPufferfish.sh
sed -i '33c\cp ${JARVIS_DOWNLOAD}/RapMap-salmon-v0.14.1.zip ${EXTERNAL_DIR}/rapmap.zip' scripts/fetchRapMap.sh
sed -i '590c\    DOWNLOAD_COMMAND cp $ENV{JARVIS_DOWNLOAD}/cereal-1.3.2.tar.gz cereal-v1.3.2.tar.gz &&' CMakeLists.txt
sed -i '658c\    DOWNLOAD_COMMAND cp $ENV{JARVIS_DOWNLOAD}/oneTBB-2021.5.0.tar.gz v2021.5.tar.gz &&' CMakeLists.txt
sed -i '753c\    DOWNLOAD_COMMAND cp $ENV{JARVIS_DOWNLOAD}/libgff-2.0.0.tar.gz libgff.tgz &&' CMakeLists.txt
sed -i '796c\    DOWNLOAD_COMMAND cp $ENV{JARVIS_DOWNLOAD}/io_lib-1.14.15.tar.gz staden-io_lib-v1.14.15.tar.gz &&' CMakeLists.txt

if [ -d "build" ]; then
rm -rf build
fi
mkdir build
cd build
cmake .. -DCMAKE_INSTALL_PREFIX=${PATH_INSTALL} \
        -DNO_IPO=TRUE -DBOOST_ROOT=$BOOST_PATH
make -j
make install

####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/salmon/1.10.1
mkdir -p ${JOBDIR}

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_bma
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=128"
#DSUB -o pytorch_out_%J.log
#DSUB -e pytorch_err_%J.log
#DSUB -T '2h'
source env.sh
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1

EOF

cat >${JOBDIR}/local_run.sh << EOF
#!/bin/bash
module purge
module use $JARVIS_MODULES/modules
module load salmon/1.10.1-%#MYKGCCVER#%

if [ -d "test" ]; then
rm -rf test
fi
mkdir test
cd test
cp ${JARVIS_DOWNLOAD}/GRCm38.primary_assembly.genome.fa.gz .
cp ${JARVIS_DOWNLOAD}/gencode.vM23.transcripts.fa.gz .

grep "^>" <(gunzip -c GRCm38.primary_assembly.genome.fa.gz) | cut -d " " -f 1 > decoys.txt
sed -i.bak -e 's/>//g' decoys.txt
cat gencode.vM23.transcripts.fa.gz GRCm38.primary_assembly.genome.fa.gz > gentrome.fa.gz
time salmon index -t gentrome.fa.gz -d decoys.txt -p 32 -i salmon_index --gencode
EOF

cat > ${JOBDIR}/salmon-1.10.1-run.sh << EOF
#!/bin/bash
cd ${JOBDIR}

./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/salmon-1.10.1-run.sh

set +x && echo_info "Install done!!!" && set -x

[RUN]
