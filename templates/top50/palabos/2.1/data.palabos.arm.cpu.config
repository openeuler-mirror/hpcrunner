[SERVER]
11.11.11.11

[DOWNLOAD]
palabos/2.1 https://gitlab.com/unigespc/palabos/-/archive/v2.1r0/palabos-v2.1r0.zip palabos-v2.1r0.zip


[DEPENDENCY]

module purge
./jarvis -install hpckit/2025.1.0.SPC001 any
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule
module load bisheng/%#MYKMPIVER#%/release

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule
module load bisheng/%#MYKMPIVER#%/release

[APP]
app_name = palabos
app_version = 2.1
compiler = bisheng+mpi
build_dir = ${JARVIS_APP}/palabos/2.1-%#MYKBSVER#%-%#MYKMPIVER#%/project
binary_dir =  ${JARVIS_JOBSCRIPT}/palabos/2.1
mod_exc_dir = 
case_dir = ${JARVIS_JOBSCRIPT}/palabos/2.1

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

####### build prepare
set +x && echo_info "build prepare!!!" && set -x

set +x && build_mod_check "${BUILD_DIR}/palabos-v2.1r0/examples/showCases/cavity3d/cavity3d" "prompt" && set -x
if [ ! -f /usr/bin/magick ]; then
	echo "ERROR: yum install ImageMagick for /usr/bin/magick"
fi

####### build start
set +x && echo_info "build start" && set -x
export CC=clang CXX=clang++ FC=flang
rm -rf palabos-v2.1r0
unzip ${JARVIS_DOWNLOAD}/palabos-v2.1r0.zip
cd palabos-v2.1r0
cd examples/showCases/cavity2d
make -j 16
cd ${BUILD_DIR}/palabos-v2.1r0/examples/showCases/cavity3d
sed -n  "s|std::max( (plint)3|std::max( (plint)1000|p" ./cavity3d.cpp
sed -i  "s|std::max( (plint)3|std::max( (plint)1000|" ./cavity3d.cpp
make -j 128
mkdir -p ${PATH_INSTALL}/bin
rm -f ${PATH_INSTALL}/bin/cavity3d
ln -s ${BUILD_DIR}/palabos-v2.1r0/examples/showCases/cavity3d/cavity3d ${PATH_INSTALL}/bin/cavity3d

echo "Generating environment script..."
####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/palabos/2.1
mkdir -p ${JOBDIR}
${BUILD_DIR}/env.sh_gen.sh ${JOBDIR}/env.sh
cp -ar ${BUILD_DIR}/palabos-v2.1r0/examples/showCases/cavity3d  ${JOBDIR}/

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_palabos
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=1"
#DSUB -o ncl_out_%J.log
#DSUB -e ncl_err_%J.log
#DSUB -T '2h'

export HOSTFILE=hostfile.palabos
rm -f \$HOSTFILE
touch \$HOSTFILE
cat \${CCSCHEDULER_ALLOC_FILE} | sort > \$HOSTFILE
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
source ./env.sh
cd cavity3d
ulimit -s unlimited

{ time  -p mpirun  --hostfile $HOSTFILE -np 128 --allow-run-as-root --bind-to cpulist:ordered -x OMP_PROC_BIND=close -x OMP_PLACES=cores  -x OMP_NUM_THREADS=1 -x UCX_TLS=sm ./cavity3d 600 ; } 2>&1 | tee tee_palabos.xlog
EOF

cat > ${JARVIS_JOBSCRIPT}/palabos/2.1/local_run.sh << EOF
#!/bin/bash
if [ ! -f /usr/bin/magick ]; then
        echo "ERROR: yum install ImageMagick for /usr/bin/magick"
fi
source env.sh
cd cavity3d
{ time mpirun  -mca pml ucx -mca btl tcp -x UCX_TLS=sm,tcp --allow-run-as-root -np 128 ./cavity3d 600 ; } 2>&1 | tee tee_palabos.xlog
EOF

cat > ${JOBDIR}/palabos-2.1-run.sh << EOF
#!/bin/bash
./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/env.sh
chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/palabos-2.1-run.sh

set +x && echo_info "Install done!!!" && set -x

[RUN]
run =  
binary =
nodes = 1
