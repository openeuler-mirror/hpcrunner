[SERVER]
11.11.11.11

[DOWNLOAD]
bwa/0.7.17 https://sourceforge.net/projects/bio-bwa/files/bwa-0.7.17.tar.bz2 bwa-0.7.17.tar.bz2
case1 https://ftp.sra.ebi.ac.uk/vol1/fastq/ERR104/008/ERR1044518/ERR1044518_1.fastq.gz ERR1044518_1.fastq.gz
case2 https://ftp.sra.ebi.ac.uk/vol1/fastq/ERR104/008/ERR1044518/ERR1044518_2.fastq.gz ERR1044518_2.fastq.gz
case3 https://ftp.ncbi.nlm.nih.gov/genomes/all/GCA/000/001/405/GCA_000001405.15_GRCh38/seqs_for_alignment_pipelines.ucsc_ids/GCA_000001405.15_GRCh38_full_analysis_set.fna.gz GCA_000001405.15_GRCh38_full_analysis_set.fna.gz

[DEPENDENCY]
set -e
set -x
module purge
module use $JARVIS_MODULES/modules
./jarvis -install hpckit/2025.1.0.SPC001 any
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule
./jarvis -install libdivsufsort/2.0.1 bisheng
module load libdivsufsort/2.0.1-%#MYKBSVER#%

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule
module load libdivsufsort/2.0.1-%#MYKBSVER#%

[APP]
app_name = bwa
app_version = 0.7.17
compiler = bisheng
build_dir = ${JARVIS_APP}/bwa/0.7.17-%#MYKBSVER#%/project
case_dir = ${JARVIS_JOBSCRIPT}/bwa/0.7.17

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

####### build prepare
set +x && echo_info "build prepare!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/bwa/0.7.17
patch=${JARVIS_ROOT}/dataconfig_patches/bwa/0.7.17/bwt.c.patch
patch1=${JARVIS_ROOT}/dataconfig_patches/bwa/0.7.17/bwt.h.patch
patch2=${JARVIS_ROOT}/dataconfig_patches/bwa/0.7.17/bwt_gen.c.patch
patch3=${JARVIS_ROOT}/dataconfig_patches/bwa/0.7.17/ksw.c.patch
patch4=${JARVIS_ROOT}/dataconfig_patches/bwa/0.7.17/rle.h.patch

set +x && build_mod_check "${PATH_INSTALL}/bin/bwa" "prompt" && set -x
set +x && rm_file_from_base ${PATH_INSTALL}/bin bwa  && set -x

[ -z "${LIBDIVSUFSORT_PATH}" ] && echo "ERRROR: Invalid ENV:LIBDIVSUFSORT_PATH" && exit 1

rm -rf bwa-0.7.17
tar --no-same-owner -jxvf ${JARVIS_DOWNLOAD}/bwa-0.7.17.tar.bz2 
cd bwa-0.7.17
patch -p0 < $patch
patch -p0 < $patch1
patch -p0 < $patch2
patch -p0 < $patch3
patch -p0 < $patch4

cp ${JARVIS_ROOT}/dataconfig_patches/bwa/0.7.17/SSE2NEON.h ./ -ar
sed -i '29c #include "SSE2NEON.h"' ksw.c
sed -i "1s/gcc/clang/g" Makefile
sed -i "/CFLAGS=/s/-g -Wall -Wno-unused-function -O2/-Wall -Wno-unused-function -O3 -ffast-math -fcommon -fvectorize -funroll-loops -march=armv8-a -mcpu=tsv110 -fuse-ld=lld -flto=full/g" Makefile
sed -i "/INCLUDES=/s%$%-I${LIBDIVSUFSORT_PATH}/include -I.%g" Makefile
sed -i "/LIBS=/s%$% -L${LIBDIVSUFSORT_PATH}/lib -ldivsufsort64%g" Makefile
make
mkdir -p $PATH_INSTALL/bin
cp *.pl bwa $PATH_INSTALL/bin -ar


####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
mkdir -p ${JOBDIR}
${BUILD_DIR}/env.sh_gen.sh ${JOBDIR}/env.sh
echo "module load bwa/0.7.17-%#MYKBSVER#%" >> ${JOBDIR}/env.sh

[ ! -f ${JOBDIR}/ERR1044518_1.fastq.gz ] && cp ${JARVIS_DOWNLOAD}/ERR1044518_1.fastq.gz ${JOBDIR}/ -ar
[ ! -f ${JOBDIR}/ERR1044518_2.fastq.gz ] && cp ${JARVIS_DOWNLOAD}/ERR1044518_2.fastq.gz ${JOBDIR}/ -ar
[ ! -f ${JOBDIR}/GCA_000001405.15_GRCh38_full_analysis_set.fna.gz ] && cp ${JARVIS_DOWNLOAD}/GCA_000001405.15_GRCh38_full_analysis_set.fna.gz ${JOBDIR}/ -ar

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_bma
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=128"
#DSUB -o pytorch_out_%J.log
#DSUB -e pytorch_err_%J.log
#DSUB -T '2h'
source env.sh
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
{ export OMP_NUM_THREADS=48;time -p bwa index -a bwtsw hs38DH.fasta ; } 2>&1 | tee tee_index.xlog
{ time -p bwa mem -t 128 hs38DH.fasta ERR1044518_1.fastq ERR1044518_2.fastq > bwa.sam; } 2>&1 |tee tee_mem.xlog
mkdir -p ${JARVIS_JOBSCRIPT}/caseshare/bwaoutput
cp bwa.sam ${JARVIS_JOBSCRIPT}/caseshare/bwaoutput/ -ar
EOF

cat >${JOBDIR}/local_run.sh << EOF
#!/bin/bash
source env.sh
{ export OMP_NUM_THREADS=48;time -p bwa index -a bwtsw hs38DH.fasta ; } 2>&1 | tee tee_index.xlog
{ time -p bwa mem -t 128 hs38DH.fasta ERR1044518_1.fastq ERR1044518_2.fastq > bwa.sam; } 2>&1 |tee tee_mem.xlog
mkdir -p ${JARVIS_JOBSCRIPT}/caseshare/bwaoutput
cp bwa.sam ${JARVIS_JOBSCRIPT}/caseshare/bwaoutput/ -ar
EOF

cat > ${JOBDIR}/bwa-0.7.17-run.sh << EOF
#!/bin/bash
if [ ! -f "ERR1044518_1.fastq" ]; then
gzip -dck ./ERR1044518_1.fastq.gz > ERR1044518_1.fastq
fi

if [ ! -f "ERR1044518_2.fastq" ]; then
gzip -dck ./ERR1044518_2.fastq.gz > ERR1044518_2.fastq
fi

if [ ! -f "hs38DH.fasta" ]; then
gzip -dck ./GCA_000001405.15_GRCh38_full_analysis_set.fna.gz > hs38DH.fasta
fi

./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/env.sh
chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/bwa-0.7.17-run.sh

set +x && echo_info "Install done!!!" && set -

[RUN]
