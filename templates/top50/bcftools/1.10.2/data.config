[SERVER]
11.11.11.11

[DOWNLOAD]
bcftools/1.10.2 https://github.com/samtools/bcftools/releases/download/1.10.2/bcftools-1.10.2.tar.bz2


[DEPENDENCY]
set -e
set -x

yum install zlib-devel bzip2 bzip2-devel xz-devel libcurl-devel -y

module purge
module use $JARVIS_MODULES/modules

./jarvis -install hpckit/2025.1.0.SPC001 any
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule

tar --no-same-owner -jxvf ${JARVIS_DOWNLOAD}/bcftools-1.10.2.tar.bz2 -C ${JARVIS_DEV}

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule


[APP]
app_name = bcftools
app_version = 1.10.2
compiler = bisheng
build_dir = ${JARVIS_DEV}/bcftools-1.10.2
binary_dir =
case_dir = ${JARVIS_JOBSCRIPT}/bcftools/1.10.2

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

####### build prepare
install_path=$1
JOBDIR=${JARVIS_JOBSCRIPT}/bcftools/1.10.2

####### build start

if [ ! -f "$install_path/bin/bcftools" ]; then
cd ${JARVIS_DEV}/bcftools-1.10.2
./configure --prefix=$install_path CFLAGS="-O3 -march=armv8.2-a"
make -j 32
make install
fi

####### build done

####### Install jobscript

if [ ! -d "${JOBDIR}" ]; then
mkdir -p ${JOBDIR}
fi

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash

EOF

cat >${JOBDIR}/local_run.sh << EOF
#!/bin/bash
module use $JARVIS_MODULES/modules
module load bcftools/1.10.2-%#MYKBSVER#%

cd ${BUILD_DIR}
time make test
EOF

cat > ${JOBDIR}/bcftools-1.10.2-run.sh << EOF
#!/bin/bash
cd ${JOBDIR}
./local_run.sh 2>&1 | tee tee_local_run.xlog
EOF


chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/bcftools-1.10.2-run.sh

[RUN]
