[SERVER]
11.11.11.11

[DOWNLOAD]
daimond/2.0.4 https://github.com/bbuchfink/diamond/archive/v2.0.4.tar.gz diamond-2.0.4.tar.gz
case1 http://ftp.ncbi.nlm.nih.gov/blast/db/FASTA/swissprot.gz
case2 http://ftp.1000genomes.ebi.ac.uk/vol1/ftp/technical/reference/human_g1k_v37.fasta.gz

[DEPENDENCY]
set -e
set -x

module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule

./jarvis -install cmake/3.28.2 any
module load cmake/3.28.2

tar --no-same-owner -zxvf ${JARVIS_DOWNLOAD}/diamond-2.0.4.tar.gz -C ${JARVIS_DEV}

echo "done"

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule
module load cmake/3.28.2

[APP]
fake = 0
app_name = diamond
app_version = 2.0.4
compiler = bisheng
build_dir = ${JARVIS_DEV}/diamond-2.0.4
binary_dir =
case_dir = ${JARVIS_JOBSCRIPT}/diamond/2.0.4

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

set +x && check_install_path "${PATH_INSTALL}" && set -x
set +x && build_mod_check "${PATH_INSTALL}/bin/diamond" "prompt" && set -x
set +x && rm_file_from_base ${PATH_INSTALL}/bin diamond  && set -x
####### build prepare
set +x && echo_info "build prepare!!!" && set -x

####### build start
set +x && echo_info "build start" && set -x

if [ -d "build" ]; then
rm -rf build
fi
mkdir build
cd build
cmake .. -DCMAKE_INSTALL_PREFIX=$PATH_INSTALL
make -j 16
make install

####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/diamond/2.0.4
mkdir -p ${JOBDIR}

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_bma
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=128"
#DSUB -o pytorch_out_%J.log
#DSUB -e pytorch_err_%J.log
#DSUB -T '2h'
source env.sh
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1

EOF

cat >${JOBDIR}/local_run.sh << EOF
#!/bin/bash
module purge
module use $JARVIS_MODULES/modules
module load diamond/2.0.4-%#MYKBSVER#%

if [ -d "test" ]; then
rm -rf test
fi
mkdir test
cd test
gunzip -dck ${JARVIS_DOWNLOAD}/human_g1k_v37.fasta.gz > human_g1k_v37.fasta
gunzip -dck ${JARVIS_DOWNLOAD}/swissprot.gz > swissprot
time -p diamond blastp -p 64 -q human_g1k_v37.fasta -d swissprot -o out.tsv --very-sensitive
EOF


cat > ${JOBDIR}/diamond-2.0.4-run.sh << EOF
#!/bin/bash
cd ${JOBDIR}

./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/diamond-2.0.4-run.sh

set +x && echo_info "Install done!!!" && set -x

[RUN]
