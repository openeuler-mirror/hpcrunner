[SERVER]
11.11.11.11

[DOWNLOAD]
nemo/4.2.2 https://forge.nemo-ocean.eu/nemo/nemo/-/archive/4.2.2/nemo-4.2.2.tar.gz nemo-4.2.2.tar.gz

[DEPENDENCY]
set -e
#set -x

module purge
module use $JARVIS_MODULES/modules
./jarvis -install hpckit/2025.1.0.SPC001 any
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule
module load bisheng/%#MYKMPIVER#%/release

./jarvis -install boost/1.72.0/clang bisheng
module load boost-clang/1.72.0-%#MYKBSVER#%

./jarvis -install blitz/1.0.1 bisheng
module load blitz/1.0.1-%#MYKBSVER#%

./jarvis -install hdf5/1.12.0/clang bisheng+mpi
module load hdf5-clang/1.12.0-%#MYKBSVER#%-%#MYKMPIVER#%

./jarvis -install pnetcdf/1.11.2/clang bisheng+mpi
module load pnetcdf-clang/1.11.2-%#MYKBSVER#%-%#MYKMPIVER#%

./jarvis -install netcdf/4.7.4/clang bisheng+mpi
module load netcdf-clang/4.7.4-%#MYKBSVER#%-%#MYKMPIVER#%-hdf51.12.0-pnetcdf1.11.2

echo "done"

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule
module load bisheng/%#MYKMPIVER#%/release
module load hdf5-clang/1.12.1-%#MYKBSVER#%-%#MYKMPIVER#%
module load pnetcdf-clang/1.11.2-%#MYKBSVER#%-%#MYKMPIVER#%
module load netcdf-clang/4.7.4-%#MYKBSVER#%-%#MYKMPIVER#%-hdf51.12.0-pnetcdf1.11.2

[APP]
fake = 0
app_name = nemo
app_version = 4.2.2
compiler = bisheng+mpi
build_dir = ${JARVIS_APP}/nemo/4.2.2-%#MYKBSVER#%-%#MYKMPIVER#%
binary_dir = ${JARVIS_APP}/nemo/4.2.2-%#MYKBSVER#%-%#MYKMPIVER#%
mod_exc_dir = nemo-4.2.2;nemo-4.2.2_bisheng
case_dir = ${JARVIS_JOBSCRIPT}/nemo/4.2.2

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

####### build prepare
set +x && echo_info "build prepare!!!" && set -x

install_path=$1
cd ${install_path}

build_mod_check "${PATH_INSTALL}/nemo-4.2.2/cfgs/MY_GYRE/EXP00/nemo" "prompt"
####### build start
set +x && echo_info "build start" && set -x


if true; then
rm -rf nemo-4.2.2
if [ ! -d "nemo-4.2.2" ]; then
tar --no-same-owner -zxvf ${JARVIS_DOWNLOAD}/nemo-4.2.2.tar.gz -C ${install_path}
fi
cd nemo-4.2.2

export NETCDF_DIR=${NETCDF_CLANG_PATH}
export HDF_DIR=${HDF5_CLANG_PATH}
export PROJ_DIR=${BUILD_DIR}/nemo-4.2.2

PATCHS_PATH=${JARVIS_ROOT}/templates/top50/nemo/4.2.2/patches
cp ${PATCHS_PATH}/Makefile .
patch Makefile < ${PATCHS_PATH}/Makefile.patch

cp ${PATCHS_PATH}/arch-bisheng.fcm ./arch/arch-bisheng.fcm

cd ${PROJ_DIR}/src
if [ ! -d "MY" ]; then
  mkdir MY
  echo "Directory 'MY' has been created."
else
  echo "Directory 'MY' already exists."
fi
cd ./MY
patch -p1 interfaceCpp.cpp < ${PATCHS_PATH}/interfaceCpp.cpp.patch

cd ${PROJ_DIR}/mk
patch bldxag.cfg < ${PATCHS_PATH}/bldxag.cfg.patch

cd ${PROJ_DIR}/src/OCE/LBC
patch lib_mpp.F90 < ${PATCHS_PATH}/lib_mpp.F90.patch

cd ${PROJ_DIR}/src/OCE/TRA
patch traadv_fct.F90 < ${PATCHS_PATH}/traadv_fct.F90.patch
patch traldf_iso.F90 < ${PATCHS_PATH}/traldf_iso.F90.patch

cd ${PROJ_DIR}/src/TOP/PISCES/P2Z
patch p2zopt.F90 < ${PATCHS_PATH}/p2zopt.F90.patch

cd ${PROJ_DIR}

make

cd ${BUILD_DIR}
mkdir -p bin
cd bin
rm -f nemo
ln -s ../nemo-4.2.2/cfgs/MY_GYRE/EXP00/nemo nemo
cd ${BUILD_DIR}
fi

####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/nemo/4.2.2
mkdir -p ${JOBDIR}

${BUILD_DIR}/env.sh_gen.sh ${JOBDIR}/env.sh
echo "module load nemo/4.2.2-%#MYKBSVER#%-%#MYKMPIVER#%" >> ${JOBDIR}/env.sh

cp ${BUILD_DIR}/nemo-4.2.2/cfgs/MY_GYRE/EXP00 ${JOBDIR}/ -Lr
rm -f ${JOBDIR}/EXP00/nemo

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_nemo
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=128"
#DSUB -o pytorch_out_%J.log
#DSUB -e pytorch_err_%J.log
#DSUB -T '2h'

export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
source ./env.sh
cd EXP00
{ time   mpirun \$CCS_MPI_OPTIONS -np 128 --allow-run-as-root --bind-to cpulist:ordered -x OMP_PROC_BIND=close -x OMP_PLACES=cores
 -x OMP_NUM_THREADS=1 -x UCX_TLS=sm nemo ; } 2>&1 | tee tee_out.xlog
EOF

cat >${JOBDIR}/local_run.sh << EOF
#!/bin/bash
source ./env.sh
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
cd EXP00

sed -i 's/nn_itend *= *4320/nn_itend = 720/' namelist_cfg
sed -i 's/^\(\s*nn_stock\s*=\s*\)4320/\1-1/' namelist_cfg
sed -i 's/^\(\s*nn_write\s*=\s*\)60/\1-1/' namelist_cfg
sed -i 's/^\(\s*nn_GYRE\s*=\s*\)1/\130/' namelist_cfg
sed -i 's/^\(\s*ln_bench\s*=\s*\).false./\1.true./' namelist_cfg
sed -i 's/^\(\s*jpkglo\s*=\s*\)31/\1128/' namelist_cfg
sed -i 's/^\(\s*rn_Dt\s*=\s*\)7200/\11200/' namelist_cfg
sed -i 's/ln_meshmask *= *.true./ln_meshmask = .false./' namelist_ref

time mpirun -np 352 --allow-run-as-root --map-by ppr:22:NUMA:pe=1 -x LD_LIBRARY_PATH -x PATH --bind-to core -x UCX_TLS=self,sm -x UCX_WARN_UNUSED_ENV_VARS=n nemo 
EOF

cat > ${JOBDIR}/nemo-4.2.2-run.sh << EOF
#!/bin/bash
source env.sh
./local_run.sh
dsub -s job_run.sh

#time mpirun --allow-run-as-root -np 16 --mca btl ^openib,tcp,vader ./nemo

EOF

chmod u+x ${JOBDIR}/env.sh
chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/nemo-4.2.2-run.sh

echo "Install done!!!"

[RUN]
