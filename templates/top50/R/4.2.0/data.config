[SERVER]
11.11.11.11

[DOWNLOAD]
true

[DEPENDENCY]
set -e
set -x
module purge
module use $JARVIS_MODULES/modules
./jarvis -install cmake/3.28.2 any
module load cmake/3.28.2
./jarvis -install hpckit/2025.1.0.SPC001 any
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1/gccmodule
./jarvis -install R/4.2.0 gcc
module load R/4.2.0-%#MYKGCCVER#%

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1/gccmodule
module load cmake/3.28.2
module load R/4.2.0-%#MYKGCCVER#%

[APP]
fake = 1
app_name = devR
app_version = 4.2.0
compiler = gcc
build_dir = ${JARVIS_DEV}/devR-4.2.0-%#MYKGCCVER#%
binary_dir =
case_dir = ${JARVIS_JOBSCRIPT}/R/4.2.0

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

####### build prepare
set +x && echo_info "build prepare!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/R/4.2.0

####### build start
set +x && echo_info "build start" && set -x


####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
mkdir -p ${JOBDIR}

${BUILD_DIR}/env.sh_gen.sh ${JOBDIR}/env.sh


cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash

EOF

cat >${JOBDIR}/local_run.sh << EOF
#!/bin/bash
source env.sh
Rscript ./HelloWorld.R
EOF

cat > ${JOBDIR}/HelloWorld.R << EOF 
# My first R script
# This is a comment, it won't be executed

print("Hello, World!")

message("This is a message for the user.")
cat("This is output from cat().\n")
EOF 
cat > ${JOBDIR}/r-4.2.0-run.sh << EOF
#!/bin/bash
source env.sh
./local_run.sh 2>&1 | tee tee_local_run.xlog
EOF

chmod u+x ${JOBDIR}/env.sh
chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/r-4.2.0-run.sh

[RUN]
