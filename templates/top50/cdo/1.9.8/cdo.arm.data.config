[SERVER]
11.11.11.11

[DOWNLOAD]
cdo/1.9.8 https://code.mpimet.mpg.de/attachments/download/20826/cdo-1.9.8.tar.gz

[DEPENDENCY]
module purge
./jarvis -install hpckit/2025.1.0.SPC001 any
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule
module load bisheng/%#MYKMPIVER#%/release


./jarvis -install hdf5/1.12.0/clang bisheng+mpi
module load hdf5-clang/1.12.0-%#MYKBSVER#%-%#MYKMPIVER#%
./jarvis -install pnetcdf/1.11.2/clang bisheng+mpi
module load pnetcdf-clang/1.11.2-%#MYKBSVER#%-%#MYKMPIVER#%
./jarvis -install netcdf/4.7.4/clang bisheng+mpi
module load netcdf-clang/4.7.4-%#MYKBSVER#%-%#MYKMPIVER#%-hdf51.12.0-pnetcdf1.11.2
./jarvis -install grib_api/1.21.0 bisheng+mpi
module load grib_api/1.21.0-%#MYKBSVER#%-%#MYKMPIVER#%


[ENV]
module purge
module use $JARVIS_MODULES/modules

module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule
module load bisheng/%#MYKMPIVER#%/release
module load hdf5-clang/1.12.0-%#MYKBSVER#%-%#MYKMPIVER#%
module load pnetcdf-clang/1.11.2-%#MYKBSVER#%-%#MYKMPIVER#%
module load netcdf-clang/4.7.4-%#MYKBSVER#%-%#MYKMPIVER#%-hdf51.12.0-pnetcdf1.11.2
module load grib_api/1.21.0-%#MYKBSVER#%-%#MYKMPIVER#%


[APP]
app_name = cdo
app_version = 1.9.8
compiler = bisheng+mpi
build_dir = ${JARVIS_DEV}/cdo/1.9.8-%#MYKBSVER#%-%#MYKMPIVER#%
binary_dir =  ${JARVIS_JOBSCRIPT}/cdo/1.9.8
case_dir =

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

####### build prepare
set +x && echo_info "build prepare!!!" && set -x

tar xf ${JARVIS_DOWNLOAD}/cdo-1.9.8.tar.gz
cd cdo-1.9.8/
./configure --prefix=$1 --with-netcdf=${NETCDF_CLANG_PATH} --with-hdf5=${HDF5_CLANG_PATH} --with-grib_api=${GRIB_API_PATH} CC=mpicc CXX=mpicxx FC=mpifort
make -j
make install

#### install jobsript for case test
echo "Install start"
JOBDIR=${JARVIS_JOBSCRIPT}/cdo/1.9.8
mkdir -p ${JOBDIR}
${BUILD_DIR}/env.sh_gen.sh ${JOBDIR}/env.sh

echo "Appending module load to env.sh..."
echo "module load cdo/1.9.8-%#MYKBSVER#%-%#MYKMPIVER#%" >> ${JOBDIR}/env.sh

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_cmake
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=1"
#DSUB -o job_out_%J.log
#DSUB -e job_err_%J.log
#DSUB -T '2h'

export HOSTFILE=hostfile.cmake
rm -f \$HOSTFILE
touch \$HOSTFILE
cat \${CCSCHEDULER_ALLOC_FILE} | sort > \$HOSTFILE
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
source ./env.sh

ulimit -s unlimited

{ time  -p mpirun  --hostfile $HOSTFILE -np 1 --allow-run-as-root --bind-to cpulist:ordered -x OMP_PROC_BIND=close -x OMP_PLACES=cores  -x OMP_NUM_THREADS=1 -x UCX_TLS=sm cdo info wrfout_d01_2019-11-26_12:00:00 ; } 2>&1 | tee tee_cdo.xlog
EOF

cat > ${JOBDIR}/local_run.sh << EOF
#!/bin/bash
source ./env.sh
cd ${BUILD_DIR}/cdo-1.9.8/test
echo 3 > /proc/sys/vm/drop_caches
rm -f test.log error.log result.log
touch test.log error.log result.log
for i in *.test; do
        echo "Testing \${i}..." 2>&1 | tee -a test.log
        ./\${i} >> test.log 2>> error.log
        ret=$?
        if [ \$ret -ne 0 ]; then
                echo "ERROR: TEST \${i} FAILED! STOP TEST." 2>&1 | tee -a error.log
                exit 2
        else
                echo "TEST \${i} PASSED." 2>&1 | tee -a result.log
        fi
done
cd -
EOF

cat > ${JOBDIR}/cdo-1.9.8-run.sh << EOF
#!/bin/bash
./local_run.sh 2>&1 | tee tee_local_run.xlog
#dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/env.sh
chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/cdo-1.9.8-run.sh

set +x && echo_info "Install done!!!" && set -x

[CLEAN]
rm -rf $JARVIS_ROOT/software/apps/bisheng4.1.0-hmpi2.4.3/cdo-1.9.8

[RUN]
run =   
binary = $JARVIS_ROOT/software/apps/bisheng4.1.0-hmpi2.4.3/
nodes = 1

[BATCH]
#定义日志文件
LOG_FILE="cdo-proformance.log"

>"$LOG_FILE"

$RUN_TOOL "cdo" "mpirun --allow-run-as-root -np 64 cdo XXXX" $LOG_FILE
#mpirun --allow-run-as-root -np 64 cdo XXXXX

echo "All commands executed. Performance log saved to $LOG_FILE"

[JOB]
#!/bin/sh
#DSUB -n cdo_test
#DSUB --mpi hmpi
#DSUB -q default
#DSUB -N 1
#DSUB -R cpu=128
#DSUB -oo cdo.%J.out
#DSUB -oe cdo.%J.err

LOG_FILE="cdo-proformance.log"

>"$LOG_FILE"

$RUN_TOOL "cdo" "mpirun --allow-run-as-root -np 64 cdo XXXX" $LOG_FILE

echo "ALL commands executed. Performance log saved to $LOG_FILE"

