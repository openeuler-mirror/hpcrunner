[SERVER]
11.11.11.11

[DOWNLOAD]
kallisto/0.46.2 https://github.com/pachterlab/kallisto/archive/refs/tags/v0.46.2.tar.gz kallisto-0.46.2.tar.gz

[DEPENDENCY]
set -e
set -x
module purge
module use $JARVIS_MODULES/modules

./jarvis -install cmake/3.28.2 any
module load cmake/3.28.2

./jarvis -install hpckit/2025.1.0.SPC001 any
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule
module load bisheng/%#MYKMPIVER#%/release

./jarvis -install hdf5/1.10.1/clang bisheng+mpi
module load hdf5-clang/1.10.1-%#MYKBSVER#%-%#MYKMPIVER#%

tar --no-same-owner -zxvf ${JARVIS_DOWNLOAD}/kallisto-0.46.2.tar.gz -C ${JARVIS_DEV}

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule
module load bisheng/%#MYKMPIVER#%/release
module load cmake/3.28.2
module load hdf5-clang/1.10.1-%#MYKBSVER#%-%#MYKMPIVER#%

[APP]
app_name = kallisto
app_version = 0.46.2
compiler = bisheng
build_dir = ${JARVIS_DEV}/kallisto-0.46.2
binary_dir =
case_dir = ${JARVIS_JOBSCRIPT}/kallisto/0.46.2

[BUILD]
set -e
set -x

####### build start
install_path=$1
export JOBDIR=${JARVIS_JOBSCRIPT}/kallisto/0.46.2

if [ ! -f "$install_path/bin/kallisto" ]; then
found='$(sed -n "50p" CMakeLists.txt | grep -o "arm-linux")'
  if [ "$found" != "arm-linux" ]; then
    sed -i "50s%configure%configure --host=arm-linux%g"     CMakeLists.txt
    sed -i "50s%autoconf%autoreconf -i%g"                   CMakeLists.txt
  fi

  if [-d "build" ]; then
    rm -rf build
  fi
mkdir build
cd build
cmake .. -DCMAKE_INSTALL_PREFIX=$install_path -DUSE_HDF5=ON -DCMAKE_CXX_COMPILER=mpicxx
make VERBOSE=1
make install
fi
####### build done

####### Install jobscript

if [ ! -d "${JOBDIR}" ]; then
mkdir -p ${JOBDIR}
fi

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash

EOF

cat >${JOBDIR}/local_run.sh << EOF
#!/bin/bash
module use $JARVIS_MODULES/modules
module load kallisto/0.46.2-%#MYKBSVER#%

if [ -d "test" ]; then
rm -rf test
fi
cp -r ${JARVIS_DEV}/kallisto-0.46.2/test .
cd test
time  kallisto index -i transcripts.idx transcripts.fasta.gz
time  kallisto quant -i transcripts.idx -o output -b 100 reads_1.fastq.gz reads_2.fastq.gz
time  kallisto quant -i transcripts.idx -o output -b 100 --single -l 180 -s 20 reads_1.fastq.gz

EOF

cat > ${JOBDIR}/kallisto-0.46.2-run.sh << EOF
#!/bin/bash
cd ${JOBDIR}

./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/kallisto-0.46.2-run.sh

[RUN]
