[SERVER]
11.11.11.11

[DOWNLOAD]


[DEPENDENCY]
set -e
module purge
./jarvis -install hpckit/2025.1.0.SPC001 any
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule
module load bisheng/%#MYKMPIVER#%/release


[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule
module load bisheng/%#MYKMPIVER#%/release
module list

[APP]
fake = 0
app_name = OpenFOAM
app_version =2412
compiler = bisheng+mpi
build_dir = ${JARVIS_DEV}/OpenFOAM/2412-%#MYKBSVER#%-%#MYKMPIVER#%
binary_dir =  
case_dir = ${JARVIS_JOBSCRIPT}/OpenFOAM/2412-%#MYKBSVER#%-%#MYKMPIVER#%

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

####### build prepare
set +x && echo_info "build prepare!!!" && set -x

build_mod_check  ${BUILD_DIR}/OpenFOAM-v2412/platforms/linuxARM64ClangDPInt32Opt/bin/simpleFoam "prompt"
cd ${PATH_INSTALL}
tar -xzf $JARVIS_DOWNLOAD/OpenFOAM-optimized-flat.tar.gz --strip-components=1
(
set --
set +e
source etc/bashrc WM_COMPILER=Clang
set -e
####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/OpenFOAM/2412
mkdir -p ${JOBDIR}
export UCX_RC_VERBS_TX_MIN_SGE=2 ; export  UCX_UD_VERBS_TX_MIN_SGE=1 ;export KML_BLAS_NOT_USE_HBM=1 
echo "Copying files to job script directory..."
echo "Generating environment script..."
${BUILD_DIR}/env.sh_gen.sh ${JOBDIR}/env.sh
echo "module load OpenFOAM/2412-%#MYKBSVER#%-%#MYKMPIVER#%" >> ${JOBDIR}/env.sh
echo "source ${PATH_INSTALL}/etc/bashrc  WM_COMPILER=Clang" >> ${JOBDIR}/env.sh
cp $JARVIS_DOWNLOAD/polyMesh_65M.tar.gz   ${JOBDIR}/ -ar
cp $JARVIS_DOWNLOAD/DrivAer_65M_flat.tar.gz ${JOBDIR}/ -ar

cd ${JOBDIR}
tar -xzf DrivAer_65M_flat.tar.gz
cd /pacific_ext/zhaoying/share/software/jobscript/OpenFOAM/2412/DrivAer_65M_flat
cd ./constant
tar -xzf ${JOBDIR}/polyMesh_65M.tar.gz
cd ..
./Allrun-pre
echo "pre-run end ..."
)
cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_ncl
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=1"
#DSUB -o ncl_out_%J.log
#DSUB -e ncl_err_%J.log
#DSUB -T '2h'

export HOSTFILE=hostfile.ncl
rm -f \$HOSTFILE
touch \$HOSTFILE
cat \${CCSCHEDULER_ALLOC_FILE} | sort > \$HOSTFILE
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
source ./env.sh
export UCX_RC_VERBS_TX_MIN_SGE=2 ; export  UCX_UD_VERBS_TX_MIN_SGE=1 ;export KML_BLAS_NOT_USE_HBM=1
ulimit -s unlimited
cd DrivAer_65M_flat
{ time  -p mpirun  --hostfile $HOSTFILE -np 1 --allow-run-as-root --bind-to cpulist:ordered -x OMP_PROC_BIND=close -x OMP_PLACES=cores  -x OMP_NUM_THREADS=1 -x UCX_TLS=sm ./Allrun-solve ; } 2>&1 | tee tee_openfoam.xlog

EOF

cat > ${JOBDIR}/local_run.sh << EOF
source ./env.sh
cd DrivAer_65M_flat
export UCX_RC_VERBS_TX_MIN_SGE=2 ; export  UCX_UD_VERBS_TX_MIN_SGE=1 ;export KML_BLAS_NOT_USE_HBM=1 
{ time  ./Allrun-solve ; } 2>&1 | tee tee_openfoam.xlog
EOF

cat > ${JOBDIR}/openfoam-2412-run.sh << EOF
./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF

chmod u+x ${JARVIS_JOBSCRIPT}/OpenFOAM/2412/env.sh
chmod u+x ${JARVIS_JOBSCRIPT}/OpenFOAM/2412/job_run.sh
chmod u+x ${JARVIS_JOBSCRIPT}/OpenFOAM/2412/local_run.sh
chmod u+x ${JARVIS_JOBSCRIPT}/OpenFOAM/2412/openfoam-2412-run.sh

set +x && echo_info "Install done!!!" && set -x
[CLEAN]
rm -rf build

[RUN]
run = 
binary = 
nodes = 1
