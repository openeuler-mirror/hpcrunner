[SERVER]
11.11.11.11

[DOWNLOAD]
modeller/10.5 https://www.salilab.org/modeller/10.5/modeller-10.5.tar.gz
soap https://salilab.org/SOAP/soap_protein_od.hdf5

[DEPENDENCY]
set -e
set -x

module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1/gccmodule

tar --no-same-owner -zxvf ${JARVIS_DOWNLOAD}/modeller-10.5.tar.gz -C ${JARVIS_DEV}

echo "done"

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load gcc/compiler12.3.1/gccmodule

[APP]
fake = 0
app_name = modeller
app_version = 10.5
compiler = gcc
build_dir = ${JARVIS_DEV}/modeller-10.5
binary_dir =
case_dir = ${JARVIS_JOBSCRIPT}/modeller/10.5

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

set +x && check_install_path "${PATH_INSTALL}" && set -x
set +x && build_mod_check "${PATH_INSTALL}/bin/modpy.sh" "prompt" && set -x
set +x && rm_file_from_base ${PATH_INSTALL}/bin modpy.sh  && set -x
####### build prepare
set +x && echo_info "build prepare!!!" && set -x

####### build start
set +x && echo_info "build start" && set -x

echo -e "\n${PATH_INSTALL}\nMODELIRANJE\n\n" | ./Install

cp -a ${JARVIS_DOWNLOAD}/soap_protein_od.hdf5 ${PATH_INSTALL}/modlib

cat > ${PATH_INSTALL}/module_tail.modulefile << EOF
prepend-path LD_LIBRARY_PATH ${PATH_INSTALL}/lib/armv8-gnu
EOF

####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/modeller/10.5
mkdir -p ${JOBDIR}

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_bma
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=128"
#DSUB -o pytorch_out_%J.log
#DSUB -e pytorch_err_%J.log
#DSUB -T '2h'
source env.sh
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1

EOF

cat >${JOBDIR}/local_run.sh << EOF
#!/bin/bash
module purge
module use $JARVIS_MODULES/modules
module load modeller/10.5-%#MYKGCCVER#%

cd $PATH_INSTALL/examples
time ./run_tests
EOF


cat > ${JOBDIR}/modeller-10.5-run.sh << EOF
#!/bin/bash
cd ${JOBDIR}

./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/modeller-10.5-run.sh

set +x && echo_info "Install done!!!" && set -x

[RUN]
