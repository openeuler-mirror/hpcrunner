[SERVER]
11.11.11.11

[DOWNLOAD]
megahit/1.2.9 https://github.com/voutcn/megahit/archive/refs/tags/v1.2.9.tar.gz   megahit-1.2.9.tar.gz
megahit/SRR1976948 https://s3-us-west-1.amazonaws.com/dib-training.ucdavis.edu/metagenomics-scripps-2016-10-12/SRR1976948.abundtrim.subset.pe.fq.gz SRR1976948.abundtrim.subset.pe.fq.gz
megahit/SRR1977249 https://s3-us-west-1.amazonaws.com/dib-training.ucdavis.edu/metagenomics-scripps-2016-10-12/SRR1977249.abundtrim.subset.pe.fq.gz SRR1977249.abundtrim.subset.pe.fq.gz


[DEPENDENCY]
set -e
source ${JARVIS_LIBSHELL}
set -x

module purge
module use $JARVIS_MODULES/modules
module load cmake/3.28.2
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule
echo "done"

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load cmake/3.28.2
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule
module load bisheng/%#MYKMPIVER#%/release


[APP]
fake = 0
app_name = megahit
app_version = 1.2.9
compiler = bisheng
build_dir = ${JARVIS_APP}/megahit/1.2.9-%#MYKBSVER#%/project
binary_dir = ${JARVIS_APP}/megahit/1.2.9-%#MYKBSVER#%/project
case_dir = ${JARVIS_JOBSCRIPT}/megahit/1.2.9

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

####### build prepare
set +x && echo_info "build prepare!!!" && set -x
build_mod_check "${PATH_INSTALL}/bin/megahit" "prompt"
rm -f ${PATH_INSTALL}/bin/Chaste

rm -rf megahit-1.2.9
tar --no-same-owner -zxvf ${JARVIS_DOWNLOAD}/megahit-1.2.9.tar.gz
#diff -u
rm -rf megahit-1.2.9_org
cp megahit-1.2.9 megahit-1.2.9_org -ar
cp ${JARVIS_ROOT}/dataconfig_patches/megahit-1.2.9/src/kmlib/kmrns.h megahit-1.2.9/src/kmlib/ -ar
cp ${JARVIS_ROOT}/dataconfig_patches/megahit-1.2.9/src/utils/cpu_dispatch.h megahit-1.2.9/src/utils/ -ar
cp ${JARVIS_ROOT}/dataconfig_patches/megahit-1.2.9/src/utils/KunpengTrans.h megahit-1.2.9/src/utils/ -ar
cp ${JARVIS_ROOT}/dataconfig_patches/megahit-1.2.9/src/sorting/base_engine.cpp  megahit-1.2.9/src/sorting/ -ar

if true; then
diff -ruN megahit-1.2.9_org/ megahit-1.2.9/ > megahit-1.2.9.patch || { [[ $? -ne 1 ]] && echo "Error: diff!!!" && exit 1; }
rm -rf megahit-1.2.9_org
fi

cd megahit-1.2.9
mkdir build -p
cd build
cmake ../ -DCMAKE_INSTALL_PREFIX=${PATH_INSTALL} -DCMAKE_C_FLAGS="-fsigned-char" -DCMAKE_CXX_FLAGS="-fsigned-char" -DCMAKE_BUILD_TYPE=Release 2>&1 | tee tee_cmake.xlog
make verbose=1 -j128 2>&1 | tee tee_make.xlog
make install

####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/megahit/1.2.9
mkdir -p ${JOBDIR}

${BUILD_DIR}/env.sh_gen.sh ${JOBDIR}/env.sh
echo "module load megahit/1.2.9-%#MYKBSVER#%" >> ${JOBDIR}/env.sh
cp ${JARVIS_DOWNLOAD}/SRR1976948.abundtrim.subset.pe.fq.gz ${JOBDIR}/ -ar
cp ${JARVIS_DOWNLOAD}/SRR1977249.abundtrim.subset.pe.fq.gz ${JOBDIR}/ -ar

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_megahit
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=128"
#DSUB -o job_out_%J.log
#DSUB -e job_err_%J.log
#DSUB -T '2h'

export HOSTFILE=hostfile.job
source ./env.sh
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
{ time  mpirun --hostfile $HOSTFILE -np 1 --mca btl ^openib,tcp,vader,uct -x UCX_TLS=sm,rc -mca pml ucx megahit -t 128 --12 SRR1976948.abundtrim.subset.pe.fq.gz SRR1977249.abundtrim.subset.pe.fq.gz ; } 2>&1 | tee tee_job_mpi.xlog
EOF

cat > ${JOBDIR}/local_run.sh << EOF
#!/bin/bash
source ./env.sh
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
{ time mpirun -np 1 --mca btl ^openib,tcp,vader,uct -x UCX_TLS=sm,rc -mca pml ucx megahit -t 128 --12 SRR1976948.abundtrim.subset.pe.fq.gz SRR1977249.abundtrim.subset.pe.fq.gz ; } 2>&1 | tee tee_local_mpi.xlog
EOF


cat > ${JOBDIR}/megahit-1.2.9-run.sh << EOF
source env.sh
echo "megahit project:${BUILD_DIR}/megahit-1.2.9"
./local_run.sh 2>&1 | tee tee_local.xlog
dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/env.sh
chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/megahit-1.2.9-run.sh

set +x && echo_info "Install done!!!" && set -x

[RUN]
