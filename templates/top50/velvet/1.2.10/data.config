[SERVER]
11.11.11.11

[DOWNLOAD]
velvet/1.2.10 https://codeload.github.com/dzerbino/velvet/tar.gz/v1.2.10 velvet-1.2.10.tar.gz

[DEPENDENCY]
set -e
set -x

module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule

tar --no-same-owner -zxvf ${JARVIS_DOWNLOAD}/velvet-1.2.10.tar.gz -C ${JARVIS_DEV}
echo "done"

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule

[APP]
fake = 0
app_name = velvet
app_version = 1.2.10
compiler = bisheng
build_dir = ${JARVIS_DEV}/velvet-1.2.10
binary_dir =
case_dir = ${JARVIS_JOBSCRIPT}/velvet/1.2.10
[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

set +x && check_install_path "${PATH_INSTALL}" && set -x
set +x && build_mod_check "${PATH_INSTALL}/bin/velveth" "prompt" && set -x
set +x && rm_file_from_base ${PATH_INSTALL}/bin velveth  && set -x
####### build prepare
set +x && echo_info "build prepare!!!" && set -x

####### build start
set +x && echo_info "build start" && set -x

sed -ri 's/\-m64/\-mabi=lp64/g' Makefile
make CC=clang CFLAGS="-fsigned-char -Wall -mabi=lp64" 'GATEGORIES=10' 'MAXKMERLENGTH=57' 'LONGSEQUENCES=1' 'OPENMP=1' 'BUNDLEDZLIB=1'

if [ ! -d "${PATH_INSTALL}/bin" ]; then
mkdir -p ${PATH_INSTALL}/bin
fi
cp velveth ${PATH_INSTALL}/bin
cp velvetg ${PATH_INSTALL}/bin

set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/velvet/1.2.10
mkdir -p ${JOBDIR}

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_bma
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=128"
#DSUB -o pytorch_out_%J.log
#DSUB -e pytorch_err_%J.log
#DSUB -T '2h'
source env.sh
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1

EOF

cat >${JOBDIR}/local_run.sh << EOF
#!/bin/bash
module purge
module use $JARVIS_MODULES/modules
module load velvet/1.2.10-%#MYKBSVER#%

if [ -d "tests" ]; then
rm -rf tests
fi
cp -r ${JARVIS_DEV}/velvet-1.2.10/tests .
cd tests
export OMP_NUM_THREADS=1
time velveth ./output 31 -shortPaired -fastq.gz read1.fq.gz -shortPaired -fastq.gz read2.fq.gz
export OMP_NUM_THREADS=8
time velvetg ./output/ -min_contig_lgth 100
EOF


cat > ${JOBDIR}/velvet-1.2.10-run.sh << EOF
#!/bin/bash
cd ${JOBDIR}

./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/velvet-1.2.10-run.sh

set +x && echo_info "Install done!!!" && set -x

[RUN]
