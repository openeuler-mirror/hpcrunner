[SERVER]
11.11.11.11

[DOWNLOAD]
pyrosetta/4.0 https://west.rosettacommons.org/pyrosetta/release/release/PyRosetta4.Release.python39.aarch64.wheel/pyrosetta-2023.11+release.fe5f8333f1c-cp39-cp39-linux_aarch64.whl
case1 https://github.com/RosettaCommons/rosetta/archive/refs/tags/v2023.11-dev61985.tar.gz rosetta-v2023.11-dev61985.tar.gz

[DEPENDENCY]
set -e
module purge
module use $JARVIS_MODULES/modules
./jarvis -install hpckit/2025.1.0.SPC001 any
module load hpckit/2025.1.0.SPC001
./jarvis -install anaconda3/2024.10 any
module load anaconda3/2024.10
echo "done"

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule
module load anaconda3/2024.10

[APP]
fake = 1
app_name = pyrosetta
app_version = 4.0
compiler = bisheng
build_dir = ${JARVIS_APP}/pyrosetta/4.0-%#MYKBSVER#%/project
binary_dir =
case_dir = ${JARVIS_JOBSCRIPT}/pyrosetta/4.0

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

####### build prepare
set +x && echo_info "build prepare!!!" && set -x

####### build start
set +x && echo_info "build start" && set -x
source $CONDA_SH
set -x

PYROSETTA_ENV=${BUILD_DIR}/conda_env/pyrosetta
if [ ! -d "${PYROSETTA_ENV}" ]; then
conda create --prefix=${PYROSETTA_ENV} python=3.9 -y
fi
conda activate ${PYROSETTA_ENV}

pip install ${JARVIS_DOWNLOAD}/pyrosetta-2023.11+release.fe5f8333f1c-cp39-cp39-linux_aarch64.whl \
--trusted-host mirrors.huaweicloud.com -i https://mirrors.huaweicloud.com/repository/pypi/simple

####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/pyrosetta/4.0
mkdir -p ${JOBDIR}

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_bma
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=128"
#DSUB -o pytorch_out_%J.log
#DSUB -e pytorch_err_%J.log
#DSUB -T '2h'
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1

EOF

cat >${JOBDIR}/local_run.sh << EOF
#!/bin/bash
source $CONDA_SH
conda activate ${PYROSETTA_ENV}

if [ -d "test" ]; then
rm -rf test
fi
mkdir test
cd test
tar --no-same-owner -zxvf ${JARVIS_DOWNLOAD}/rosetta-v2023.11-dev61985.tar.gz
cd rosetta-2023.11-dev61985/source/src/python/PyRosetta/src
sed -i "86s/export PYTHONPATH=\\\`pwd\\\` && //g" self-test.py
time python self-test.py
EOF


cat > ${JOBDIR}/pyrosetta-4.0-run.sh << EOF
#!/bin/bash
cd ${JOBDIR}

./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/pyrosetta-4.0-run.sh

set +x && echo_info "Install done!!!" && set -x

[RUN]
