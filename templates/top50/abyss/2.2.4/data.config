[SERVER]
11.11.11.11

[DOWNLOAD]
abyss/2.2.4 https://github.com/bcgsc/abyss/archive/2.2.4.tar.gz abyss-2.2.4.tar.gz
boost/1.56.0 http://downloads.sourceforge.net/project/boost/boost/1.56.0/boost_1_56_0.tar.bz2
test-data https://www.bcgsc.ca/platform/bioinfo/software/abyss/releases/1.3.4/test-data.tar.gz

[DEPENDENCY]
set -e
set -x

module purge
module use $JARVIS_MODULES/modules

./jarvis -install hpckit/2025.1.0.SPC001 any
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule
module load bisheng/%#MYKMPIVER#%/release

tar --no-same-owner -zxvf ${JARVIS_DOWNLOAD}/abyss-2.2.4.tar.gz -C ${JARVIS_DEV}
tar --no-same-owner -jxvf ${JARVIS_DOWNLOAD}/boost_1_56_0.tar.bz2 -C ${JARVIS_DEV}

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule
module load bisheng/%#MYKMPIVER#%/release

[APP]
app_name = abyss
app_version = 2.2.4
compiler = bisheng+mpi
build_dir = ${JARVIS_DEV}/abyss-2.2.4
binary_dir =
case_dir = ${JARVIS_JOBSCRIPT}/abyss/2.2.4

[BUILD]
set -e
set -x

####### build prepare
install_path=$1
JOBDIR=${JARVIS_JOBSCRIPT}/abyss/2.2.4

####### build start

if [ ! -f "$install_path/bin/abyss-pe" ]; then
cd ${JARVIS_DEV}/abyss-2.2.4

./autogen.sh

./configure --prefix=$install_path \
--with-boost=${JARVIS_DEV}/boost_1_56_0 \
--without-sparsehash --with-mpi=$OPAL_PREFIX
make -j 32 AM_CXXFLAGS=-Wall
make install AM_CXXFLAGS=-Wall
fi

####### build done

####### Install jobscript

if [ ! -d "${JOBDIR}" ]; then
mkdir -p ${JOBDIR}
fi

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_abyss
#DSUB --mpi hmpi
#DSUB -N 96
#DSUB -nn 1
#DSUB -rpn 96
#DSUB -o abyss_out_%J.log
#DSUB -e abyss_err_%J.log

module use $JARVIS_MODULES/modules
module load abyss/2.2.4-%#MYKBSVER#%-%#MYKMPIVER#%

if [ -d "test-data" ]; then
rm -rf test-data
fi
tar --no-same-owner -zxvf ${JARVIS_DOWNLOAD}/test-data.tar.gz
cd test-data

abyss-pe np=96 k=25 name=test in='reads1.fastq reads2.fastq'
EOF

cat >${JOBDIR}/local_run.sh << EOF
#!/bin/bash
module use $JARVIS_MODULES/modules
module load abyss/2.2.4-%#MYKBSVER#%-%#MYKMPIVER#%

if [ -d "test-data" ]; then
rm -rf test-data
fi
tar --no-same-owner -zxvf ${JARVIS_DOWNLOAD}/test-data.tar.gz
cd test-data

export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1

time abyss-pe np=96 k=25 name=test in='reads1.fastq reads2.fastq'
EOF

cat > ${JOBDIR}/abyss-2.2.4-run.sh << EOF
#!/bin/bash
cd ${JOBDIR}
./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF


chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/abyss-2.2.4-run.sh

[RUN]
