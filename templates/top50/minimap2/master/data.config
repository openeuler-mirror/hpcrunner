[SERVER]
11.11.11.11

[DOWNLOAD]
minimap2/master https://github.com/lh3/minimap2/archive/master.zip minimap2-master.zip
case1 http://ftp.ensembl.org/pub/release-97/fasta/homo_sapiens/dna/Homo_sapiens.GRCh38.dna.chromosome.1.fa.gz
case2 http://ftp.ensembl.org/pub/release-97/fasta/homo_sapiens/dna/Homo_sapiens.GRCh38.dna.chromosome.2.fa.gz

[DEPENDENCY]
set -e
set -x

module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule

unzip ${JARVIS_DOWNLOAD}/minimap2-master.zip -d ${JARVIS_DEV}

echo "done"

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule

[APP]
fake = 0
app_name = minimap2
app_version = master
compiler = bisheng
build_dir = ${JARVIS_DEV}/minimap2-master
binary_dir =
case_dir = ${JARVIS_JOBSCRIPT}/minimap2/master

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

set +x && check_install_path "${PATH_INSTALL}" && set -x
set +x && build_mod_check "${PATH_INSTALL}/bin/minimap2" "prompt" && set -x
set +x && rm_file_from_base ${PATH_INSTALL}/bin minimap2  && set -x
####### build prepare
set +x && echo_info "build prepare!!!" && set -x

####### build start
set +x && echo_info "build start" && set -x

make arm_neon=1 aarch64=1
if [ ! -d "$PATH_INSTALL/bin" ]; then
mkdir -p $PATH_INSTALL/bin
fi
cp minimap2 $PATH_INSTALL/bin

####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/minimap2/master
mkdir -p ${JOBDIR}

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_bma
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=128"
#DSUB -o pytorch_out_%J.log
#DSUB -e pytorch_err_%J.log
#DSUB -T '2h'
source env.sh
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1

EOF

cat >${JOBDIR}/local_run.sh << EOF
#!/bin/bash
module purge
module use $JARVIS_MODULES/modules
module load minimap2/master-%#MYKBSVER#%

if [ -d "test" ]; then
rm -rf test
fi
mkdir test
cd test
gunzip -dck ${JARVIS_DOWNLOAD}/Homo_sapiens.GRCh38.dna.chromosome.1.fa.gz > Homo_sapiens.GRCh38.dna.chromosome.1.fa
gunzip -dck ${JARVIS_DOWNLOAD}/Homo_sapiens.GRCh38.dna.chromosome.2.fa.gz > Homo_sapiens.GRCh38.dna.chromosome.2.fa
time -p minimap2 -t 128 -x asm10 Homo_sapiens.GRCh38.dna.chromosome.1.fa Homo_sapiens.GRCh38.dna.chromosome.2.fa > Homo_sapiens.GRCh38.dna.chromosome.paf
EOF


cat > ${JOBDIR}/minimap2-master-run.sh << EOF
#!/bin/bash
cd ${JOBDIR}

./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/minimap2-master-run.sh

set +x && echo_info "Install done!!!" && set -x

[RUN]
