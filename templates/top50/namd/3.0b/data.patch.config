[SERVER]
11.11.11.11

[DOWNLOAD]
namd/3.0b6 https://www.ks.uiuc.edu/Research/namd/3.0b6/download/120834/NAMD_3.0b6_Source.tar.gz NAMD_3.0b6_Source.tar.gz
tcl/8.5   http://www.ks.uiuc.edu/Research/namd/libraries/tcl8.5.9-linux-arm64-threaded.tar.gz tcl8.5.9-linux-arm64-threaded.tar.gz
charm/7.0.0 https://charm.cs.illinois.edu/distrib/charm-7.0.0.tar.gz charm-7.0.0.tar.gz
namd/stmv_sc14	https://www.ks.uiuc.edu/Research/namd/utilities/stmv_sc14.tar.gz stmv_sc14.tar.gz

[DEPENDENCY]
module purge
module use $JARVIS_MODULES/modules
./jarvis -install hpckit/2025.1.0.SPC001 any
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule
module load bisheng/%#MYKMPIVER#%/release

export CC=mpicc FC=mpifort CXX=mpicxx

./jarvis -install package/fftw/3.3.10 bisheng+mpi
module load fftw/3.3.10-%#MYKBSVER#%-%#MYKMPIVER#%



[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.1.0.SPC001
module load bisheng/compiler4.2.0.2/bishengmodule
module load bisheng/%#MYKMPIVER#%/release
module load fftw/3.3.10-%#MYKBSVER#%-%#MYKMPIVER#%
export CURRENT_COMPILER_DIR=${HPCKIT_COM_BS}

export CC=${CURRENT_COMPILER_DIR}/bin/clang
export CXX=${CURRENT_COMPILER_DIR}/bin/clang++
export FC=${CURRENT_COMPILER_DIR}/bin/flang
export VERBOSE=1
export CHARM_USE_THREADING=1

fftw_dir=${FFTW_PATH}
gxx_loc=`which g++`

[APP]
app_name = namd
app_version =3.0b6
compiler = bisheng+mpi
build_dir = $JARVIS_APP/namd/3.0b6-%#MYKBSVER#%-%#MYKMPIVER#%/project
binary_dir = $JARVIS_APP/namd/3.0b6-%#MYKBSVER#%-%#MYKMPIVER#%/Linux-ARM64-mpicxx
mod_exc_dir = project/NAMD_3.0b6_Source;project/tcl_install
case_dir = ${JARVIS_JOBSCRIPT}/namd/3.0b6

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"
log_file=tee_install_$(date +%Y%m%d%H%M%S).xlog
SOURCE_FILE=$(readlink -f "${BASH_SOURCE}")
export CURRENT_WORK_PATH=$(dirname ${SOURCE_FILE})

export CURRENT_COMPILER_DIR=${HPCKIT_COM_BS}

export CC=${CURRENT_COMPILER_DIR}/bin/clang
export CXX=${CURRENT_COMPILER_DIR}/bin/clang++
export FC=${CURRENT_COMPILER_DIR}/bin/flang
export VERBOSE=1
export CHARM_USE_THREADING=1

fftw_dir=${FFTW_PATH}
gxx_loc=`which g++`

build_mod_check "${BUILD_DIR}/NAMD_3.0b6_Source/Linux-ARM64-mpicxx/namd3" "prompt"
{
####### build prepare
set +x && echo_info "build prepare!!!" && set -x

####### build start
set +x && echo_info "build start" && set -x
if false; then
    rm -rf ${BUILD_DIR}/NAMD_3.0b6_Source
    cd ${BUILD_DIR}
    tar -xf ${JARVIS_DOWNLOAD}/NAMD_3.0b6_Source.tar.gz
    cd NAMD_3.0b6_Source
    tar -xvf charm-7.0.0.tar
    cd ../
    tar -zxvf ${JARVIS_ROOT}/dataconfig_patches/namd/patch.tar.gz

    # 配置路径（请根据实际情况修改）
    DIR1="./NAMD_3.0b6_Source" # 要修改的源目录（直接在此目录上操作）
    PATCH_DIR="./patch"        # 补丁文件目录（包含差异.patch和原dir2独有文件）

    # 警告：此操作会直接修改DIR1的内容，请确保已备份
    # 检查必要目录是否存在
    if [ ! -d "$DIR1" ]; then
        echo "错误：目录 $DIR1 不存在！"
        exit 1
    fi
    if [ ! -d "$PATCH_DIR" ]; then
        echo "错误：补丁目录 $PATCH_DIR 不存在！"
        exit 1
    fi

    # 1. 应用所有.patch文件（将dir1的文件更新为原dir2的状态）
    echo "正在应用补丁文件..."
    find "$PATCH_DIR" -name "*.patch" | while read -r patch_file; do
        # 计算补丁对应的目标文件路径（直接在dir1中操作）
        # 例如：patch_dir/a/b/file.txt.patch → dir1/a/b/file.txt
        target_file="${patch_file#$PATCH_DIR/}"   # 移除补丁目录前缀
        target_file="$DIR1/${target_file%.patch}" # 移除.patch后缀，得到目标文件路径
        # 确保目标文件的父目录存在（应对原dir1中可能缺失的目录）
        target_dir=$(dirname "$target_file")
        mkdir -p "$target_dir"
        # 正向应用补丁（将dir1的文件更新为原dir2的状态）
        echo "应用补丁：$patch_file → $target_file"
        patch -p0 "$target_file" < "$patch_file"
    done

    # 2. 复制原dir2独有的文件到dir1（这些文件在原dir1中不存在）
    echo "正在补充原dir2独有的文件..."
    find "$PATCH_DIR" -type f ! -name "*.patch" | while read -r unique_file; do
        # 计算目标路径（保持目录结构，直接放入dir1）
        # 例如：patch_dir/c/d/unique.txt → dir1/c/d/unique.txt
        target_file="${unique_file#$PATCH_DIR/}"
        target_file="$DIR1/$target_file"
        # 确保目标目录存在
        target_dir=$(dirname "$target_file")
        mkdir -p "$target_dir"
        # 复制独有文件到目标位置
        echo "复制独有文件：$unique_file → $target_file"
        cp -f "$unique_file" "$target_file"
    done

    export installdir=${PATH_INSTALL}
    export sourcedir=${BUILD_DIR}/NAMD_3.0b6_Source
    cd ${BUILD_DIR}/NAMD_3.0b6_Source
    tar -xvf ${JARVIS_DOWNLOAD}/tcl8.5.9-linux-arm64-threaded.tar.gz
    cd ../
    tar -zxvf ${JARVIS_DOWNLOAD}/stmv_sc14.tar.gz
    tar -zxvf ${JARVIS_DOWNLOAD}/stmv.tar.gz
    mv stmv/* stmv_sc14/
    rm -rf stmv/
    cd NAMD_3.0b6_Source/charm-v7.0.0
    ./build charm++ mpi-linux-arm8 clang smp --with-production --force -j
    cd ../
    rm -rf Linux-ARM64-clang++
    ./config Linux-ARM64-clang++ --charm-arch mpi-linux-arm8-smp-clang --with-fftw --with-tcl
    cd Linux-ARM64-clang++
    make -j32
    cd ${BUILD_DIR}/stmv_sc14
    ${BUILD_DIR}/NAMD_3.0b6_Source/Linux-ARM64-clang++/psfgen make_5x2x2stmv.pgn
    ${BUILD_DIR}/NAMD_3.0b6_Source/Linux-ARM64-clang++/namd3 compress_20stmv.namd
    cd ${BUILD_DIR}
    sed -i '19s/1200/600/' ${BUILD_DIR}/stmv_sc14/20stmv2fs.namd
    sed -i '26s/^/#/' ${BUILD_DIR}/stmv_sc14/20stmv2fs.namd
    sed -i '26a maxSelfPart 512' ${BUILD_DIR}/stmv_sc14/20stmv2fs.namd
    sed -i '27a maxPairPart 256' ${BUILD_DIR}/stmv_sc14/20stmv2fs.namd
    sed -i '28a ldBalancer none' ${BUILD_DIR}/stmv_sc14/20stmv2fs.namd
    sed -i '29a hybridGroupSize 401' ${BUILD_DIR}/stmv_sc14/20stmv2fs.namd
    sed -i '30a ldbStrategy comprehensive' ${BUILD_DIR}/stmv_sc14/20stmv2fs.namd
    sed -i '101a binaryOutput         no' ${BUILD_DIR}/stmv_sc14/20stmv2fs.namd
    sed -i '102a margin               2.0' ${BUILD_DIR}/stmv_sc14/20stmv2fs.namd

    if [ ! -d ./namd_cases ]; then
        mkdir namd_cases
    fi
    rm -rf ${BUILD_DIR}/namd_cases/*
    mv ${BUILD_DIR}/stmv_sc14 ${BUILD_DIR}/namd_cases/

    cd ${BUILD_DIR}/NAMD_3.0b6_Source/charm-v7.0.0
    ./build charm++ mpi-linux-arm8 clang smp --with-production --force -j
    cd ../
    rm -rf Linux-ARM64-clang++
    ./config Linux-ARM64-clang++ --charm-arch mpi-linux-arm8-smp-clang --with-fftw --with-tcl --with-memopt
    cd Linux-ARM64-clang++
    make -j32
    cd ${PATH_INSTALL}
    mkdir -p bin
    cd bin
    rm -rf namd3
    ln -s ../project/NAMD_3.0b6_Source/Linux-ARM64-clang++/namd3 .
fi


####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/namd/3.0b6 
mkdir -p ${JOBDIR}
${BUILD_DIR}/env.sh_gen.sh ${JOBDIR}/env.sh
echo "module load namd/3.0b6-%#MYKBSVER#%-%#MYKMPIVER#%" >> ${JOBDIR}/env.sh
cp ${BUILD_DIR}/namd_cases  ${JOBDIR}/ -ar
cp ${JARVIS_ROOT}/dataconfig_patches/ncopy.sh  ${JOBDIR}/ -ar
cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_namd
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=128"
#DSUB -o out_%J.log
#DSUB -e err_%J.log
#DSUB -T '2h'

export HOSTFILE=hostfile.namd
rm -f \$HOSTFILE
touch \$HOSTFILE
cat \${CCSCHEDULER_ALLOC_FILE} | sort > \$HOSTFILE
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
source ./env.sh
ulimit -s unlimited
echo 3 > /proc/sys/vm/drop_caches
chmod 755 ncopy.sh
benchmark=./namd_cases/stmv_sc14/20stmv2fs.namd
{ time  -p mpirun --hostfile $HOSTFILE -np 2 -N 2  --bind-to cpulist:ordered -x OMP_PROC_BIND=close -x OMP_PLACES=cores  -x UCX_TLS=sm ./ncopy.sh ${PATH_INSTALL}/bin/namd3 $benchmark ; } 2>&1 | tee tee_jax.xlog
EOF

cat >${JOBDIR}/local_run.sh << EOF
#!/bin/bash
source ./env.sh
ulimit -s unlimited
echo 3 > /proc/sys/vm/drop_caches
chmod 755 ncopy.sh
benchmark=./namd_cases/stmv_sc14/20stmv2fs.namd
for i in $(seq 0 15)
do
    echo 10240 > /sys/devices/system/node/node${i}/hugepages/hugepages-2048kB/nr_hugepages
done
export GLIBC_TUNABLES=glibc.malloc.hugetlb=2
{ time -p mpirun --allow-run-as-root -np 32  -x UCX_TLS=sm --bind-to cpulist:ordered -mca pml ucx -mca btl ^vader,tcp,openib,uct -x OMP_NUM_THREADS=19   ./ncopy.sh ${PATH_INSTALL}/bin/namd3 $benchmark; } 2>&1 | tee $
tee tee_namd2.xlog
for i in $(seq 0 15)
do
    echo 0 > /sys/devices/system/node/node${i}/hugepages/hugepages-2048kB/nr_hugepages
done

EOF

cat > ${JOBDIR}/namd-3.0b6-run.sh << EOF
#!/bin/bash

./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/env.sh
chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/namd-3.0b6-run.sh

set +x && echo_info "Install done!!!" && set -x
} 2>&1 | tee ${log_file}
res=${PIPESTATUS[0]}
exit ${res}
[CLEAN]
rm -rf $JARVIS_ROOT/software/apps/bisheng4.1.0-hmpi2.4.3/namd

[RUN]
run =   
binary = 
nodes = 

[BATCH]
#定义日志文件
LOG_FILE="namd-run.log"

>"$LOG_FILE"
$RUN_TOOL "namd " "time -p mpirun --allow-run-as-root -np 1 namd2 +ppn 127 ${test_name}.namd +setcpuaffinity" $LOG_FILE
#time -p mpirun --allow-run-as-root -np 1 namd2 +ppn 127 ${test_name}.namd +setcpuaffinity)

echo "All commands executed. Performance log saved to $LOG_FILE"

[JOB]
#!/bin/sh
#DSUB -n namd_test
#DSUB --mpi hmpi
#DSUB -q default
#DSUB -N 1
#DSUB -R cpu=128
#DSUB -oo roms.%J.out
#DSUB -oe roms.%J.err

LOG_FILE="namd-run.log"

>"$LOG_FILE"
$RUN_TOOL "namd" "time -p mpirun --allow-run-as-root -np 1 namd2 +ppn 127 ${test_name}.namd +setcpuaffinity" $LOG_FILE

echo "ALL commands executed. Performance log saved to $LOG_FILE"

