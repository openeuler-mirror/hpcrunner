[SERVER]
11.11.11.11

[DOWNLOAD]
hpcg/3.1

[DEPENDENCY]
module purge
./jarvis -install hpckit/${HPCKIT_VERSION} any
module use $JARVIS_ROOT/software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles
module load bisheng/compiler${BISHENG_VERSION}/bishengmodule
module load bisheng/hmpi${HPCKIT_VERSION}/release
export CC=`which clang`
export CXX=`which clang++`i
export FC=`which flang`
cd $JARVIS_ROOT/tmp
if [ ! -d "hpcg" ]; then
   git config --global http.sslVerify false
   git clone --depth=1 https://github.com/hpcg-benchmark/hpcg.git 
fi


[ENV]
module purge
module use $JARVIS_ROOT/software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles
module load bisheng/compiler${BISHENG_VERSION}/bishengmodule
module load bisheng/hmpi${HPCKIT_VERSION}/release
export CC=mpicc CXX=mpic++ FC=mpifort
export HPCG_HOME=$JARVIS_ROOT/tmp/hpcg

[APP]
app_name = hpcg
build_dir = $HPCG_HOME
binary_dir = $JARVIS_ROOT/software/apps/bisheng${BISHENG_VERSION}-hmpi${HMPI_VERSION}/hpcg/bin
case_dir =

[BUILD]
cat << \EOF > setup/Make.MPI_GCC_OMP
SHELL        = /bin/sh
CD           = cd
CP           = cp
LN_S         = ln -s -f
MKDIR        = mkdir -p
RM           = /bin/rm -f
TOUCH        = touch
TOPdir       = .
SRCdir       = $(TOPdir)/src
INCdir       = $(TOPdir)/src
BINdir       = $(TOPdir)/bin
HPCG_INCLUDES = -I$(INCdir) -I$(INCdir)/$(arch) $(MPinc)
HPCG_LIBS     =
HPCG_OPTS     =
HPCG_DEFS     = $(HPCG_OPTS) $(HPCG_INCLUDES)
CXX          = mpicxx
CXXFLAGS     = $(HPCG_DEFS) -O3 -ffast-math -ftree-vectorize -fopenmp -march=native
LINKER       = $(CXX)
LINKFLAGS    = $(CXXFLAGS)
ARCHIVER     = ar
ARFLAGS      = r
RANLIB       = echo
EOF
mkdir -p src/MPI_GCC_OMP
make -j
echo "check if SVE exists"
if [ -f bin/xhpcg ]; then
    echo "编译成功！"
    echo "二进制文件信息:"
    file bin/xhpcg
    
    # 检查SVE支持
    echo -e "\n检查SVE支持:"
    if objdump -d bin/xhpcg 2>/dev/null | grep -q "p0\b\|sve"; then
        echo "✓ 二进制文件中包含SVE指令"
    elif readelf -A bin/xhpcg 2>/dev/null | grep -q "SVE"; then
        echo "✓ 二进制文件标记了SVE支持"
    else
        echo "⚠ 未检测到SVE指令，但程序已编译完成"
    fi
else
    echo "编译失败，bin/xhpcg不存在"
    exit 1
fi
mkdir -p $JARVIS_ROOT/software/apps/bisheng${BISHENG_VERSION}-hmpi${HMPI_VERSION}/hpcg
cp -r bin $JARVIS_ROOT/software/apps/bisheng${BISHENG_VERSION}-hmpi${HMPI_VERSION}/hpcg
[CLEAN]
make clean

[RUN]
run = mpirun --allow-run-as-root -np 32 
binary = xhpcg 104 104 104
nodes = 1 
