[SERVER]
11.11.11.11

[DOWNLOAD]
swmm/5.2.4 https://github.com/USEPA/Stormwater-Management-Model/archive/refs/heads/develop.zip swmm-5.2.4.zip

[DEPENDENCY]
set -e
set -x

./jarvis -install gcc/13.3.0 com
module purge 
module use ${JARVIS_ROOT}/software/modulefiles
module load gcc/13.3.0
export CC=`which gcc`
export CXX=`which g++`
export FC=`which gfortran`

[ENV]
module purge
module use ${JARVIS_ROOT}/software/modulefiles
module load gcc/13.3.0
export PATH=${JARVIS_ROOT}/software/apps/gcc-13.3.0/swmm/5.2.4bin:$PATH
export LD_LIBRARY_PATH=${JARVIS_ROOT}/software/apps/gcc-13.3.0/swmm/5.2.4/bin:$LD_LIBRARY_PATH

[APP]
app_name = SWMM 
build_dir = ${JARVIS_ROOT}/tmp/Stormwater-Management-Model-develop
binary_dir = ${JARVIS_ROOT}/software/apps/gcc-13.3.0/swmm/5.2.4/bin
case_dir = 

[BUILD]
cd ${JARVIS_ROOT}/tmp
unzip ${JARVIS_DOWNLOAD}/swmm-5.2.4.zip
cd Stormwater-Management-Model-develop

mkdir build
cd build
cmake .. -DCMAKE_INSTALL_PREFIX=${JARVIS_ROOT}/software/apps/gcc-13.3.0/swmm/5.2.4
make -j64
make install

[CLEAN]
make clean

[RUN]
run =
binary = runswmm --version
nodes = 1
