[SERVER]
11.11.11.11

[DOWNLOAD]
STAR/2.7.1a https://gitee.com/kp-hpc-mod/hpc-src/raw/master/STAR-2.7.1a.tar.gz STAR-2.7.1a.tar.gz

[DOWNLOADORI]
STAR/2.7.1a https://github.com/alexdobin/STAR/archive/refs/tags/2.7.1a.tar.gz STAR-2.7.1a.tar.gz

[DEPENDENCY]
./jarvis -install hpckit/${HPCKIT_VERSION} any

module use ${JARVIS_ROOT}/software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles
module load gcc/compiler12.3.1/gccmodule

mkdir -p ${JARVIS_ROOT}/software/apps
tar -zxvf $JARVIS_DOWNLOAD/STAR-2.7.1a.tar.gz -C ${JARVIS_ROOT}/software/apps

[ENV]
module use ${JARVIS_ROOT}/software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles
module load gcc/compiler12.3.1/gccmodule

[APP]
app_name = STAR
build_dir = ${JARVIS_ROOT}/software/apps/STAR-2.7.1a/source
# binary_dir = ${JARVIS_ROOT}/software/apps/STAR-2.7.1a/source
binary_dir =
case_dir = 



[BUILD]
set -x
set -e

sed -i 's/\?\=/\?= \-flto \-march=native \-mcpu=tsv110/g' Makefile
make STAR


[CLEAN]
./clean_build

[RUN]
run =
binary =
nodes = 1
