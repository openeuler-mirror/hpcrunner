[SERVER]
11.11.11.11

[DOWNLOAD]

[DEPENDENCY]
set -e
set -x
module purge
./jarvis -install hpckit/${HPCKIT_VERSION} any
module use ${JARVIS_ROOT}/software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles
module add bisheng/compiler${BISHENG_VERSION}/bishengmodule
export CC=`which clang`
export CXX=`which clang++`
export FC=`which flang`
if [ -d "${JARVIS_ROOT}/software/utils/spack/1.0.0/bisheng" ]; then
rm -rf ${JARVIS_ROOT}/software/utils/spack/1.0.0/bisheng
fi
./jarvis -install spack/1.0.0 any
mkdir -p ${JARVIS_ROOT}/software/utils/spack/1.0.0/bisheng
cp -r ${JARVIS_ROOT}/tmp/spack  ${JARVIS_ROOT}/software/utils/spack/1.0.0/bisheng
source ${JARVIS_ROOT}/software/utils/spack/1.0.0/bisheng/spack/share/spack/setup-env.sh

[ENV]
module purge
module use ${JARVIS_ROOT}/software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles
module add bisheng/compiler${BISHENG_VERSION}/bishengmodule
export CC=`which clang`
export CXX=`which clang++`
export FC=`which flang`
source ${JARVIS_ROOT}/software/utils/spack/1.0.0/bisheng/spack/share/spack/setup-env.sh

[APP]
app_name = memkind
build_dir = ${JARVIS_ROOT}/software/utils/spack/1.0.0/bisheng/spack
binary_dir =
case_dir =

[BUILD]
source ${JARVIS_ROOT}/software/utils/spack/1.0.0/bisheng/spack/share/spack/setup-env.sh
spack -V
spack compiler find
spack compilers
spack -k install memkind%clang

[CLEAN]
make clean

[RUN]
run = spack -V && spack load memkind && man memkind | cat
binary =
nodes = 1

[PERF]
perf=
nsys=
ncu=--target-processes all