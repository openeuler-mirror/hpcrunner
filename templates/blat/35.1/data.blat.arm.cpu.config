[SERVER]
11.11.11.11

[DOWNLOAD]
blat/35.1 https://codeload.github.com/djhshih/blat/tar.gz/v35.1 blat-35.1.tar.gz

[DEPENDENCY]
yum -y install libpng-devel
module purge
./jarvis -install hpckit/${HPCKIT_VERSION} any
module use ${JARVIS_ROOT}/software/modulefiles
GCC_VERSION=`ls software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles/gcc|grep compiler|awk -F "compiler" '{print $2}'`
module load hpckit${HPCKIT_VERSION}/gcc/compiler${GCC_VERSION}/gccmodule

[ENV]
module purge
module use ${JARVIS_ROOT}/software/modulefiles
GCC_VERSION=`ls software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles/gcc|grep compiler|awk -F "compiler" '{print $2}'`
module load hpckit${HPCKIT_VERSION}/gcc/compiler${GCC_VERSION}/gccmodule

[APP]
app_name = blat
build_dir = ${JARVIS_TMP}
binary_dir = ${JARVIS_ROOT}/software/apps/gcc${GCC_VERSION}/blat/35.1/bin
case_dir =



[BUILD]
set -x
set -e

rm -rf blat-35.1
tar -zxvf $JARVIS_DOWNLOAD/blat-35.1.tar.gz
cd ${JARVIS_TMP}/blat-35.1/
sed -i 's/jmp_buf htmlRecover/\/\/jmp_buf htmlRecover/g' src/inc/htmshell.h
export MACHTYPE=aarch64
make DESTDIR=${JARVIS_ROOT}/software/apps/gcc${GCC_VERSION}/blat/35.1



[CLEAN]
./clean_build

[RUN]
run =
binary =blat | cat
nodes = 1

