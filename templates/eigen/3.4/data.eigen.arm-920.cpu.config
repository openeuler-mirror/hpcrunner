[SERVER]
11.11.11.11

[DOWNLOAD]
eigen/3.4 https://gitlab.com/libeigen/eigen/-/archive/3.4/eigen-3.4.tar.gz

[DEPENDENCY]

module purge
./jarvis -install hpckit/${HPCKIT_VERSION} any
module use ./software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles
module load bisheng/compiler${BISHENG_VERSION}/bishengmodule

export CC=clang CXX=clang++ FC=flang

cd ${JARVIS_TMP_DOWNLOAD}
rm -rf eigen-3.4
tar -xzvf ${JARVIS_DOWNLOAD}/eigen-3.4.tar.gz

[ENV]
module purge
module use ./software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles
module load bisheng/compiler${BISHENG_VERSION}/bishengmodule
export PKG_CONFIG_PATH=${JARVIS_ROOT}/software/apps/bisheng${BISHENG_VERSION}/eigen/3.4/share/pkgconfig:$PKG_CONFIG_PATH

[APP]
app_name = eigen
build_dir = ${JARVIS_TMP_DOWNLOAD}/eigen-3.4/
binary_dir =
case_dir =

[BUILD]
mkdir build
cd build
cmake -DCMAKE_INSTALL_PREFIX=${JARVIS_ROOT}/software/apps/bisheng${BISHENG_VERSION}/eigen/3.4/ ..
make -j
make install

[CLEAN]
cd build
make clean

[RUN]
run = pkg-config --modversion eigen3
binary =
nodes = 1

[PERF]
perf=
nsys=
ncu=
