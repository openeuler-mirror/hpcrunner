[SERVER]
11.11.11.11

[DOWNLOAD]
sqlite/3.46.0 https://github.com/sqlite/sqlite/archive/refs/tags/version-3.46.0.zip sqlite-3.46.0.zip

[DEPENDENCY]
set -e
set -x

./jarvis -install hpckit/${HPCKIT_VERSION} any
module use software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles
module load gcc/compiler12.3.1/gccmodule
rm -rf ${JARVIS_TMP_DOWNLOAD}/sqlite-version-3.46.0
unzip ${JARVIS_DOWNLOAD}/sqlite-3.46.0.zip -d ${JARVIS_TMP_DOWNLOAD}

[ENV]
module use software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles
module load gcc/compiler12.3.1/gccmodule
export CC=`which gcc`
export CXX=`which g++`
export FC=`which gfortran`
export PATH=${JARVIS_ROOT}/software/apps/sqlite-3.46.0/bin:$PATH

[APP]
app_name = sqlite3
build_dir = ${JARVIS_TMP_DOWNLOAD}/sqlite-version-3.46.0
binary_dir = 
case_dir = ${JARVIS_ROOT}/software/apps/sqlite-3.46.0/bin

[BUILD]
./configure --prefix=${JARVIS_ROOT}/software/apps/sqlite-3.46.0
make -j32
make install

[CLEAN]
make clean

[RUN]
run = sqlite3 --version
binary =
nodes = 1

