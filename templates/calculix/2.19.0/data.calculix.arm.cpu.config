[SERVER]
11.11.11.11

[DOWNLOAD]
calculix/2.19.0 $JARVIS_PROXY/precice/calculix-adapter/archive/refs/heads/master.tar.gz calculix-adapter-master.tar.gz
ccx/2.19 http://www.dhondt.de/ccx_2.19.src.tar.bz2
precice/3.12 $JARVIS_PROXY/precice/precice/archive/refs/tags/v3.1.2.tar.gz

[DEPENDENCY]
yum install lapack-devel blas-devel openblas-devel libxml2-devel -y
#yum install python3-devel -y
yum install arpack arpack-devel -y
#python3 -m pip install numpy
./jarvis -install package/anaconda3/2024.10 com
source ${JARVIS_ROOT}/software/compiler/anaconda3/2024.10/etc/profile.d/conda.sh
module purge
./jarvis -install bisheng/2.1.0 com
module use ./software/modulefiles
module load bisheng/2.1.0
export CC=clang CXX=clang++ FC=flang
./jarvis -install hmpi/1.1.1 clang
module load hmpi/1.1.1
./jarvis -install spooles/2.2/clang clang
./jarvis -install cmake/3.23.1 clang
module load cmake/3.23.1
./jarvis -install yaml-cpp/0.6.2 clang
module load yaml-cpp/0.6.2
./jarvis -install eigen3/3.4.0 clang
module load eigen3/3.4.0
./jarvis -install boost/1.72.0 clang
module load boost/1.72.0
./jarvis -install petsc/3.18.1 clang+mpi
module use ./software/moduledeps/bisheng2.1.0-hmpi1.1.1
module load petsc/3.18.1
cd ${JARVIS_TMP}
rm -rf precice-3.1.2 calculix-adapter-master CalculiX
tar xvf ${JARVIS_DOWNLOAD}/v3.1.2.tar.gz
tar xvf ${JARVIS_DOWNLOAD}/ccx_2.19.src.tar.bz2
tar xvf ${JARVIS_DOWNLOAD}/calculix-adapter-master.tar.gz

[ENV]
module purge
module use ./software/modulefiles
module load bisheng/2.1.0
export CC=clang CXX=clang++ FC=flang
module load hmpi/1.1.1
module load cmake/3.23.1
module load yaml-cpp/0.6.2
module load eigen3/3.4.0
module load boost/1.72.0
module use ./software/moduledeps/bisheng2.1.0-hmpi1.1.1
module load petsc/3.18.1
export Eigen3_ROOT=${JARVIS_ROOT}/software/libs/bisheng2.1.0/eigen3/3.4.0
export PKG_CONFIG_PATH=${JARVIS_TMP}/precice-3.1.2/precice-install/lib64/pkgconfig:$PKG_CONFIG_PATH
export CPATH=${JARVIS_TMP}/precice-3.1.2/precice-install/include:$CPATH
export PETSC_DIR=${JARVIS_ROOT}/software/libs/bisheng2.1.0-hmpi1.1.1/petsc/3.18.1
export PETSC_ARCH=arch-linux-c-opt
export LD_LIBRARY_PATH=${JARVIS_TMP}/precice-3.1.2/precice-install/lib64:$LD_LIBRARY_PATH

[APP]
app_name = calculix
build_dir = ${JARVIS_ROOT}
binary_dir = 
case_dir = ${JARVIS_TMP}/calculix-adapter-master/bin

[BUILD]
set -e
source ${JARVIS_ROOT}/software/compiler/anaconda3/2024.10/etc/profile.d/conda.sh
conda create -n calculix python=3.9.7 -y
conda activate calculix
python3 -m pip install numpy
cd ${JARVIS_TMP}/precice-3.1.2
rm -rf build precice-install
mkdir precice-install
mkdir build
cd build
cmake .. -DBUILD_TESTING=OFF -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=${JARVIS_TMP}/precice-3.1.2/precice-install -DPRECICE_PETScMapping=OFF -DPRECICE_PythonActions=OFF -DBUILD_SHARED_LIBS=ON -DPETSC_DIR=${PETSC_DIR} -DPETSC_ARCH=${PETSC_ARCH} -DCMAKE_PREFIX_PATH=${PETSC_DIR}
make -j
make install


cd ${JARVIS_TMP}/calculix-adapter-master
sed -i "6c\CCX = ${JARVIS_TMP}/CalculiX/ccx_2.19/src" Makefile
sed -i "10c\SPOOLES_INCLUDE = -I/${JARVIS_TMP}/SPOOLES.2.2" Makefile
sed -i "12c\SPOOLES_LIBS = ${JARVIS_TMP}/SPOOLES.2.2/spooles.a" Makefile
sed -i '15c\ARPACK_INCLUDE = -I/usr/include' Makefile
sed -i '17c\ARPACK_LIBS = /usr/lib64/libarpack.so' Makefile
sed -i "20c\YAML_INCLUDE = -I/${JARVIS_TMP}/yaml-cpp-yaml-cpp-0.6.2/include" Makefile
sed -i "22c\YAML_LIBS = -L/${JARVIS_TMP}/yaml-cpp-yaml-cpp-0.6.2/build -lyaml-cpp" Makefile
sed -i '55c\CFLAGS = -Wall -O3 -fopenmp $(INCLUDES) -DARCH="Linux" -DSPOOLES -DARPACK -DMATRIXSTORAGE' Makefile
sed -i '60c\CC = clang' Makefile
sed -i '62c\CC = clang' Makefile
sed -i '67c\FC = flang' Makefile
sed -i '2857s/,\s*jobnamef//' nonlingeo_precice.c
sed -i '5c\CCX_VERSION = 2.19' Makefile
sed -i '43,49d' Makefile
sed -i '43i\LIBS = \\\n\t$(SPOOLES_LIBS) \\\n\t-lstdc++ \\\n\t$(YAML_LIBS) \\\n\t$(ARPACK_LIBS) \\\n\t-lopenblas \\\n\t-llapack \\\n\t-lblas \\\n\t-lgfortran \\\n\t-lpthread -lm -lc \\\n\t$(PKGCONF_LIBS)' Makefile
make clean
make -j

[RUN]
run = ./ccx_preCICE --version
binary =
nodes = 1


