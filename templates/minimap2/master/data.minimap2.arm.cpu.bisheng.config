[SERVER]
11.11.11.11

[DOWNLOAD]
minimap2/master https://github.com/lh3/minimap2/archive/master.zip minimap2-master.zip

[DEPENDENCY]
set -e
set -x

./jarvis -install hpckit/${HPCKIT_VERSION} any
module use ${JARVIS_ROOT}/software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles
module purge
module add bisheng/compiler${BISHENG_VERSION}/bishengmodule
yum install wget git gcc-c++ zlib -y
mkdir -p ${JARVIS_ROOT}/software/apps/bisheng${BISHENG_VERSION}/minimap2/master/bin
cd ${JARVIS_TMP}
rm -rf ${JARVIS_TMP}/minimap2-master
unzip ${JARVIS_DOWNLOAD}/minimap2-master.zip

[ENV]
module use ./software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles
module purge
module add bisheng/compiler${BISHENG_VERSION}/bishengmodule

[APP]
app_name = minimap2
build_dir = ${JARVIS_TMP}/minimap2-master/
binary_dir = ${JARVIS_ROOT}/software/apps/bisheng${BISHENG_VERSION}/minimap2/master/bin
case_dir = ${JARVIS_TMP}/minimap2-master/

[BUILD]
make arm_neon=1 aarch64=1
./minimap2 --v
cp ./minimap2  ${JARVIS_ROOT}/software/apps/bisheng${BISHENG_VERSION}/minimap2/master/bin

[CLEAN]

[RUN]
run =
binary = ./minimap2 -a test/MT-human.fa test/MT-orang.fa > test.sam
nodes = 1

[PERF]
perf=
nsys=
ncu=--target-processes all

