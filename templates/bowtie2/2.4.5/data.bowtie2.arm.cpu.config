[SERVER]
11.11.11.11

[DOWNLOAD]
case http://hgdownload.cse.ucsc.edu/goldenPath/mm10/bigZips/chromFa.tar.gz

[DEPENDENCY]
set -e
set -x
./jarvis -install hpckit/${HPCKIT_VERSION} any
module purge
module use ${JARVIS_ROOT}/software/modulefiles
module load hpckit${HPCKIT_VERSION}/bisheng/compiler${BISHENG_VERSION}/bishengmodule
module use ${JARVIS_ROOT}/software/moduledeps/bisheng${BISHENG_VERSION}

mkdir -p ${JARVIS_ROOT}/workloads/bowtie2/2.4.5
cd ${JARVIS_ROOT}/workloads/bowtie2/2.4.5
if [ ! -f "mm10.fa" ];then
 tar -xvf ${JARVIS_DOWNLOAD}/bowtie2-2.4.5.tar.gz
 tar xf ${JARVIS_DOWNLOAD}/chromFa.tar.gz
 cat *.fa > mm10.fa
fi

[ENV]
module purge
module use ${JARVIS_ROOT}/software/modulefiles
module load hpckit${HPCKIT_VERSION}/bisheng/compiler${BISHENG_VERSION}/bishengmodule
module use ${JARVIS_ROOT}/software/moduledeps/bisheng${BISHENG_VERSION}
module load bowtie2/2.4.5

[APP]
app_name = bowtie2
build_dir = ${JARVIS_TMP}/bowtie2-2.4.5
binary_dir =
case_dir = ${JARVIS_ROOT}/workloads/bowtie2/2.4.5

[BUILD]
./jarvis -install bowtie2/2.4.5 clang

[RUN]
run =
binary = bowtie2-build mm10.fa mm10 && bowtie2 -p 6 -3 5 --local -x mm10 -1 bowtie2-2.4.5/example/reads/reads_1.fq -2 bowtie2-2.4.5/example/reads/reads_2.fq -S example.sam
nodes = 1

