[SERVER]
11.11.11.11

[DOWNLOAD]
flatbuffer/24.3.25 https://github.com/google/flatbuffers/archive/refs/tags/v24.3.25.zip flatbuffers-v24.3.25.zip

[DEPENDENCY]
set -e
set -x

yum install make cmake gcc g++ -y
module purge
./jarvis -install hpckit/${HPCKIT_VERSION} any
module use ./software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles
module add gcc/compiler12.3.1/gccmodule
export CC=`which gcc`
export CXX=`which g++`
export FC=`which gfortran`

[ENV]
module purge
module use ./software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles
module add gcc/compiler12.3.1/gccmodule
export CC=`which gcc`
export CXX=`which g++`
export FC=`which gfortran`
CUR_PATH=$(pwd)
export JARVIS_ROOT=${CUR_PATH}
export JARVIS_TMP=${CUR_PATH}/tmp
export PATH=${JARVIS_ROOT}/software/apps/bisheng${BISHENG_VERSION}/flatbuffer/24.3.25/bin:$PATH

[APP]
app_name = FLATBUFFERS
build_dir = 
binary_dir = 
case_dir =

[BUILD]
cd ${JARVIS_TMP}
rm -rf flatbuffers-24.3.25 
unzip ${JARVIS_DOWNLOAD}/flatbuffers-v24.3.25.zip
cd flatbuffers-24.3.25 
cmake -G "Unix Makefiles" -DCMAKE_INSTALL_PREFIX=${JARVIS_ROOT}/software/apps/bisheng${BISHENG_VERSION}/flatbuffer/24.3.25
make -j32
make install

[CLEAN]
make clean

[RUN]
run = flatc --version
binary =
nodes = 1

