[SERVER]
11.11.11.11

[DOWNLOAD]
FDS/6.7.4 https://github.com/firemodels/fds/archive/refs/tags/FDS6.7.4.tar.gz

[DEPENDENCY]

module purge
./jarvis -install hpckit/${HPCKIT_VERSION} any
module use ${JARVIS_ROOT}/software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles
module add bisheng/compiler${BISHENG_VERSION}/bishengmodule bisheng/hmpi${HMPI_VERSION}/release
export CC=`which mpicc`
export CXX=`which mpicxx`
export FC=`which mpifort`
export F77=`which mpifort`

[ENV]
module purge
./jarvis -install hpckit/${HPCKIT_VERSION} any
module use ${JARVIS_ROOT}/software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles
module add bisheng/compiler${BISHENG_VERSION}/bishengmodule bisheng/hmpi${HMPI_VERSION}/release
export CC=`which mpicc`
export CXX=`which mpicxx`
export FC=`which mpifort`
export F77=`which mpifort`
export PATH=${JARVIS_ROOT}/software/apps/fds_FDS6.7.4/Build/mpi_gnu_linux_64:$PATH
export OMP_NUM_THREADS=1

[APP]
app_name = fds
build_dir = ${JARVIS_ROOT}/tmp
binary_dir = ${JARVIS_ROOT}/software/apps/fds_FDS6.7.4/Build/mpi_gnu_linux_64
case_dir = ${JARVIS_ROOT}/workloads/fds_FDS6.7.4/testcase

[BUILD]
rm -rf ${JARVIS_ROOT}/software/apps/fds_FDS6.7.4
mkdir -p ${JARVIS_ROOT}/software/apps/fds_FDS6.7.4
tar -xvf  ${JARVIS_DOWNLOAD}/FDS6.7.4.tar.gz --strip-components 1 -C ${JARVIS_ROOT}/software/apps/fds_FDS6.7.4
cd ${JARVIS_ROOT}/software/apps/fds_FDS6.7.4/Build
sed -i "s/-ffpe-summary=none//g" ./makefile
sed -i '58c\GNU_COMPINFO=-DCOMPVER_PP=\\"$(OPENMPI_COMPVERSION)\\"' ./makefile
export CFLAGS="-Wno-implicit-function-declaration -Wno-implicit-int"
sed -i '29c\clang -v | head -1> gfortran_version 2>&1' Scripts/gnu_compversion.sh
sed -i '30c\GFORTRANVERSION=clang' Scripts/gnu_compversion.sh
sed -i '32c\echo "\\"Gnu flang $GFORTRANVERSION\\""' Scripts/gnu_compversion.sh
cd mpi_gnu_linux_64
./make_fds.sh
cd ${JARVIS_ROOT}/workloads
mkdir -p fds_FDS6.7.4/testcase
cd fds_FDS6.7.4/testcase
export OMP_NUM_THREADS=1
export PATH=${JARVIS_ROOT}/software/apps/fds_FDS6.7.4/Build/mpi_gnu_linux_64:$PATH
sed -i 's/IJK=50,50,50/IJK=20,20,20/' ${JARVIS_ROOT}/software/apps/fds_FDS6.7.4/Validation/MPI_Scaling_Tests/FDS_Input_Files/weak_scaling_test_001.fds


[RUN]
run =  `which mpirun` -np $(nproc) --mca btl ^openib --allow-run-as-root fds_mpi_gnu_linux_64 ${JARVIS_ROOT}/software/apps/fds_FDS6.7.4/Validation/MPI_Scaling_Tests/FDS_Input_Files/weak_scaling_test_001.fds
binary =
nodes = 1
