[SERVER]
11.11.11.11

[DOWNLOAD]

[DEPENDENCY]
module purge
./jarvis -install hpckit/${HPCKIT_VERSION} any
module use ./software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles
module add gcc/compiler12.3.1/gccmodule gcc/hmpi${HPCKIT_VERSION}/release
export CC=mpicc CXX=mpicxx FC=mpifort F77=mpifort

[ENV]
module purge
module use ./software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles
module add gcc/compiler12.3.1/gccmodule gcc/hmpi${HPCKIT_VERSION}/release
export CC=mpicc CXX=mpicxx FC=mpifort F77=mpifort

[APP]
app_name = IPM
build_dir = ${JARVIS_ROOT}
binary_dir =
case_dir =

[BUILD]
./jarvis -install IPM/2.0.6 gcc+mpi

[RUN]
run =
binary =
nodes = 1

