[SERVER]
11.11.11.11

[DOWNLOAD]


[DEPENDENCY]
set -e
set -x
./jarvis -install hpckit/${HPCKIT_VERSION} any
module purge
module use ./software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles
module load bisheng/compiler${BISHENG_VERSION}/bishengmodule
module load bisheng/hmpi${HMPI_VERSION}

[ENV]
module purge
module use ./software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles
module load bisheng/compiler${BISHENG_VERSION}/bishengmodule
module load bisheng/hmpi${HMPI_VERSION}

[APP]
app_name = amg
build_dir = ${JARVIS_ROOT}
binary_dir =
case_dir =

[BUILD]
./jarvis -install amg/1.2 bisheng+mpi


[RUN]
run = ${JARVIS_ROOT}/software/libs/bisheng${BISHENG_VERSION}-hmpi${HPCKIT_VERSION}/amg/1.2/bin/amg  --version
binary =
nodes = 1

