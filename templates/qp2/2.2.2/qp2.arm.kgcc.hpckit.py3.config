[SERVER]
11.11.11.11

[DOWNLOAD]
QuantumPackage/qp2/2.2.2

[DEPENDENCY]
set -e
module purge
./jarvis -install hpckit/${HPCKIT_VERSION} any
module use ${JARVIS_ROOT}/software/modulefiles/hpckit${HPCKIT_VERSION}
module load gcc/compiler12.3.1/gccmodule
module load gcc/hmpi${HMPI_VERSION}/release
module load gcc/kml${HPCKIT_VERSION}/kml
module unload gcc/kml${HPCKIT_VERSION}/kspblas/omp
module unload gcc/kml${HPCKIT_VERSION}/kvml/serial
export CC=mpicc CXX=mpicxx FC=mpifort F77=mpif77 F90=mpif90
sed -i '10i sed -i '\''88s/-fp-model strict//'\'' ${JARVIS_TMP}/Python-3.9.9/Makefile' package/python3/3.9.9/install.sh
module use ${JARVIS_ROOT}/software/moduledeps/gcc12.3.1-hmpi${HMPI_VERSION}
./jarvis -install python3/3.9.9 gcc+mpi
module load python3/3.9.9
./jarvis -install hdf5/1.12.1 gcc+mpi
module load hdf5/1.12.1

rm -rf ${JARVIS_ROOT}/software/apps/qp2
mkdir -p ${JARVIS_ROOT}/software/apps/qp2
git clone https://github.com/QuantumPackage/qp2.git -b v2.2.2 ${JARVIS_ROOT}/software/apps/qp2
cd ${JARVIS_ROOT}/software/apps/qp2
git submodule update --init --recursive

[ENV]
module purge
module use ${JARVIS_ROOT}/software/modulefiles/hpckit${HPCKIT_VERSION}
module load gcc/compiler12.3.1/gccmodule
module load gcc/hmpi${HMPI_VERSION}/release
module load gcc/kml${HPCKIT_VERSION}/kml
module unload gcc/kml${HPCKIT_VERSION}/kspblas/omp
module unload gcc/kml${HPCKIT_VERSION}/kvml/serial
export CC=mpicc CXX=mpicxx FC=mpifort F77=mpif77 F90=mpif90
module use ${JARVIS_ROOT}/software/moduledeps/gcc12.3.1-hmpi${HMPI_VERSION}
module load python3/3.9.9
module load hdf5/1.12.1

[APP]
app_name = qp2
build_dir = ${JARVIS_ROOT}/software/apps/qp2
binary_dir =
case_dir = ${JARVIS_ROOT}/software/apps/qp2

[BUILD]
sed -i 's/CC=gcc/CC=mpicc/g' configure
sed -i 's/CXX=g++/CXX=mpicxx/g' configure
#If you don't have HDF5, use trexio-nohdf5,; use trexio need add --with-hdf5=$HDF5_PATH
sed -i '235s/$/\ CPPFLAGS="-I\${JARVIS_UTILS}\/hpckit\/${HPCKIT_VERSION}\/HPCKit\/${HPCKIT_VERSION}\/hmpi\/gcc\/hmpi\/include" --with-hdf5=\${JARVIS_LIBS}\/gcc12.3.1-hmpi${HMPI_VERSION}\/hdf5\/1.12.1/' configure
./configure -i zlib
./configure -i ninja
./configure -i zeromq
./configure -i trexio
./configure -i f77zmq
./configure -i gmp
./configure -i ocaml
./configure -i docopt
./configure -i resultsFile

cat > config/gfortran_hmpi.cfg <<EOF
@@[COMMON]
FC           : mpif90 -ffree-line-length-none -fallow-argument-mismatch -I . -I ${JARVIS_UTILS}/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/hmpi/gcc/release/hmpi/include -g -fPIC -std=legacy
LAPACK_LIB   : -L${JARVIS_UTILS}/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/hmpi/gcc/release/hmpi/lib -lmpi -lmpi_mpifh -L${JARVIS_UTILS}/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/kml/gcc/lib/${kp} -L${JARVIS_UTILS}/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/kml/gcc/lib/${kp}/kblas/multi -lklapack_full -lkblas
IRPF90       : irpf90
IRPF90_FLAGS : --ninja --align=32 -DMPI -DSET_NESTED

@@[OPTION]
MODE    : OPT
CACHE   : 0
OPENMP  : 1

@@[OPT]
FCFLAGS : -Ofast

@@[PROFILE]
FC      : -p -g
FCFLAGS : -Ofast

@@[DEBUG]
FCFLAGS : -fcheck=all -g

@@[OPENMP]
FC           : -fopenmp
IRPF90_FLAGS : --openmp
EOF

sed -i 's/@@//g' config/gfortran_hmpi.cfg
source quantum_package.rc
./configure -c config/gfortran_hmpi.cfg
make
echo "[INFO] Please ignore the errors from the first make; Some cmx files or model cannot be found during the first make, so a second make is needed."
make

[CLEAN]
./bin/ninja clean

[RUN]
run =
binary = source quantum_package.rc && cd tests/input/ && rm -rf be && qp create_ezfio -b 6-31g be.xyz -o be && qp run fci | tee output.fic.out
nodes = 1
