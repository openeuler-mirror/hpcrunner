[SERVER]
11.11.11.11

[DOWNLOAD]
OpenMolcas/24.10 ${JARVIS_PROXY}/Molcas/OpenMolcas/archive/refs/tags/v24.10.tar.gz OpenMolcas-24.10.tar.gz

[DEPENDENCY]
set -e
yum install cmake -y
module purge
./jarvis -install hpckit/${HPCKIT_VERSION} any
module use ${JARVIS_ROOT}/software/modulefiles
GCC_VERSION=`ls software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles/gcc|grep compiler|awk -F "compiler" '{print $2}'`
module load hpckit${HPCKIT_VERSION}/gcc/compiler${GCC_VERSION}/gccmodule  hpckit${HPCKIT_VERSION}/gcc/hmpi${HMPI_VERSION}/release 
./jarvis -install hdf5/1.12.1 gcc+mpi
module use ${JARVIS_ROOT}/software/moduledeps/gcc${GCC_VERSION}-hmpi${HMPI_VERSION}
module load hdf5/1.12.1
./jarvis -install lapack/3.10.1 gcc+mpi
module load lapack/3.10.1
./jarvis -install ga/5.8.2 gcc+mpi

mkdir -p ${JARVIS_ROOT}/software/app/gcc${GCC_VERSION}-hmpi${HMPI_VERSION}/openmolcas/24.10
mkdir -p ${JARVIS_ROOT}/software/workloads/openmolcas/24.10/case
rm -rf ${JARVIS_TMP}/OpenMolcas-24.10
tar -zxvf ${JARVIS_DOWNLOAD}/OpenMolcas-24.10.tar.gz -C ${JARVIS_TMP}

[ENV]
module purge
module use ${JARVIS_ROOT}/software/modulefiles
GCC_VERSION=`ls software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles/gcc|grep compiler|awk -F "compiler" '{print $2}'`
module load hpckit${HPCKIT_VERSION}/gcc/compiler${GCC_VERSION}/gccmodule  hpckit${HPCKIT_VERSION}/gcc/hmpi${HMPI_VERSION}/release
module use ${JARVIS_ROOT}/software/moduledeps/gcc${GCC_VERSION}-hmpi${HMPI_VERSION}
module load hdf5/1.12.1
module load lapack/3.10.1
export GAROOT=${JARVIS_LIBS}/gcc${GCC_VERSION}-hmpi${HMPI_VERSION}/ga/5.8.2
export TMPDIR=${JARVIS_ROOT}/software/workloads/openmolcas/24.10/case

[APP]
app_name =   openmolcas
build_dir =  ${JARVIS_TMP}/OpenMolcas-24.10
binary_dir = ${JARVIS_ROOT}/software/app/gcc${GCC_VERSION}-hmpi${HMPI_VERSION}/openmolcas/24.10
case_dir =   ${JARVIS_ROOT}/software/app/gcc${GCC_VERSION}-hmpi${HMPI_VERSION}/openmolcas/24.10
#case_dir = ${JARVIS_ROOT}/software/workloads/openmolcas/24.10/case

[BUILD]
pip3 install pyparsing==3.2.0
rm -rf build/
mkdir build
cd build/
CC=mpicc CXX=mpicxx FC=mpifort F77=mpifort cmake .. -DCMAKE_INSTALL_PREFIX=${JARVIS_ROOT}/software/app/gcc${GCC_VERSION}-hmpi${HMPI_VERSION}/openmolcas/24.10 -DMPI_Fortran_COMPILER=mpifort -DMPI_C_COMPILER=mpicc -DMPI_CXX_COMPILER=mpicxx -DMPI=ON -DGA=ON -DLINALG=Manual -DLINALG_LIBRARIES="-L${JARVIS_LIBS}/gcc${GCC_VERSION}-hmpi${HMPI_VERSION}/lapack/3.10.1/lib64 -lblas -llapack"
make -j4
make install

#测试准备部分
cp -ar ../test/ ${JARVIS_ROOT}/software/app/gcc${GCC_VERSION}-hmpi${HMPI_VERSION}/openmolcas/24.10



[CLEAN]
rm -rf ./*

[RUN]
#MOLCAS_NPROCS用于指定MPI并行核数
#MOLCAS_KEEP_WORKDIR每次计算完自动清空临时文件
run = export OMPI_ALLOW_RUN_AS_ROOT=1 OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1 MOLCAS_NPROCS=8 MOLCAS_KEEP_WORKDIR=NO &&
binary = pymolcas verify test/standard/004.input
nodes = 1
