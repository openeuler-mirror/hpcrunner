[SERVER]
11.11.11.11

[DOWNLOAD]
openfoam/v1906 https://sourceforge.net/projects/openfoam/files/v1906/OpenFOAM-v1906.tgz
ThirdParty/v1906 https://sourceforge.net/projects/openfoam/files/v1906/ThirdParty-v1906.tgz

[DEPENDENCY]
set -x
set -e
module purge
yum -y install  zlib-devel texinfo gstreamer-plugins-base-devel libXext-devel libGLU-devel libXt-devel libXrender-devel libXinerama-devel libpng-devel libXrandr-devel libXi-devel libXft-devel libjpeg-turbo-devel libXcursor-devel readline-devel ncurses-devel mpfr-devel gmp-devel libmpc*
./jarvis -install hpckit/${HPCKIT_VERSION} any
source ${JARVIS_ROOT}/software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/setvars.sh

mkdir -p $JARVIS_ROOT/software/apps/gcc12.3.1-hmpi${HMPI_VERSION}/
tar -xzvf $JARVIS_DOWNLOAD/OpenFOAM-v1906.tgz -C $JARVIS_ROOT/software/apps/gcc12.3.1-hmpi${HMPI_VERSION}/ 
tar -zxvf $JARVIS_DOWNLOAD/ThirdParty-v1906.tgz -C $JARVIS_ROOT/software/apps/gcc12.3.1-hmpi${HMPI_VERSION}/

[ENV]
source ${JARVIS_ROOT}/software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/setvars.sh
source $JARVIS_ROOT/software/apps/gcc12.3.1-hmpi${HMPI_VERSION}/OpenFOAM-v1906/etc/bashrc

[APP]
app_name = OpenFOAM
build_dir = $JARVIS_ROOT/software/apps/gcc12.3.1-hmpi${HMPI_VERSION}/OpenFOAM-v1906/
binary_dir = 
case_dir = $JARVIS_ROOT/software/apps/gcc12.3.1-hmpi${HMPI_VERSION}/OpenFOAM-v1906/tutorials/incompressible/pisoFoam/LES/motorBike/motorBike/

[BUILD]
sed -i "s| List<char>\&\& buffer,| ::Foam::List<char>\&\& buffer,|g" ./src/OpenFOAM/db/IOstreams/memory/IListStream.H
./Allwmake -j 

[CLEAN]
rm -rf build

[RUN]
run = 
binary = ./Allrun
nodes = 1
