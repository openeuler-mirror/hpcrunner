[SERVER]
11.11.11.11

[DOWNLOAD]
vaspkit/0.52 https://sourceforge.net/projects/vaspkit/files/Src/vaspkit.0.52.tar.gz

[DEPENDENCY]

module purge
./jarvis -install hpckit/${HPCKIT_VERSION} any
module purge
module use ./software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles
module load bisheng/compiler${BISHENG_VERSION}/bishengmodule

export CC=clang CXX=clang++ FC=flang

cd ${JARVIS_ROOT}
rm -rf vaspkit-0.52
tar -xzvf ${JARVIS_DOWNLOAD}/vaspkit.0.52.tar.gz

[ENV]
module purge
module use ./software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles
module load bisheng/compiler${BISHENG_VERSION}/bishengmodule

[APP]
app_name = vaspkit
build_dir = ${JARVIS_ROOT}/vaspkit.0.52/
binary_dir = ${JARVIS_ROOT}/vaspkit.0.52/src/
case_dir = 

[BUILD]
sed -i "6c FC=flang" make.inc
sed -i "12c CC=clang" make.inc
cd src
make

[CLEAN]
cd src
make clean

[RUN]
run = ${JARVIS_ROOT}vaspkit.0.52/src/vaspkit
binary = vaspkit
nodes = 1

[PERF]
perf=
nsys=
ncu=
