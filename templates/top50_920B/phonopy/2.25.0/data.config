[SERVER]
11.11.11.11

[DOWNLOAD]
phonopy/2.25.0 https://github.com/phonopy/phonopy/archive/refs/tags/v2.25.0.tar.gz phonopy_v2.25.0.tar.gz

[DEPENDENCY]
set -e
module purge
module use $JARVIS_MODULES/modules
./jarvis -install cmake/3.28.2 any
module load cmake/3.28.2
./jarvis -install hpckit/2025.0.0 any
module load hpckit/2025.0.0
./jarvis -install eigen3/3.4.0 any
module load eigen3/3.4.0
./jarvis -install anaconda3/2024.10 any
module load anaconda3/2024.10
echo "done"

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.0.0
module load gcc/compiler12.3.1/gccmodule
module load cmake/3.28.2
module load eigen3/3.4.0
module load anaconda3/2024.10
export Eigen3_DIR=${EIGEN3_PATH}


[APP]
fake = 1
app_name = phonopy
app_version = 2.25.0
compiler = gcc
build_dir = ${JARVIS_APP}/phonopy/2.25.0-kgcc12.3.1/project
binary_dir = ${JARVIS_DEV}/phonopy/2.25.0
case_dir = ${JARVIS_JOBSCRIPT}/phonopy/2.25.0

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"
echo "Eigen3_Dir:${Eigen3_Dir}"

####### build prepare
set +x && echo_info "build prepare!!!" && set -x

####### build start
set +x && echo_info "build start" && set -x

set +x && build_mod_check "${BUILD_DIR}/phonopy-2.25.0/dist/phonopy-2.25.0-cp310-cp310-linux_aarch64.whl" "prompt" && set -x
rm -f "${BUILD_DIR}/phonopy-2.25.0/dist/phonopy-2.25.0-cp310-cp310-linux_aarch64.whl"
echo "Eigen3_DIR:${Eigen3_DIR}"
set +x
source $CONDA_SH
set -x

PHONOPY_ENV=${BUILD_DIR}/conda_env/phonopy
#if [ "$(conda env list | grep phonopy | awk '{print $1}')" != "phonopy" ]; then
conda create  --prefix=${PHONOPY_ENV} python=3.10
#fi
conda activate ${PHONOPY_ENV}

pip install numpy==1.24.0 pyyaml matplotlib h5py spglib seekpath scipy symfc cp2k-input-tools pypolymlp==0.2.8 pytest \
--trusted-host mirrors.huaweicloud.com -i https://mirrors.huaweicloud.com/repository/pypi/simple 

pip uninstall cmake

tar --no-same-owner -zxvf ${JARVIS_DOWNLOAD}/phonopy_v2.25.0.tar.gz 

cd phonopy-2.25.0

if [ -d "build" ]; then
rm -rf build
fi

export PHONOPY_USE_OPENMP=true

python setup.py bdist_wheel

pip uninstall phonopy

pip install dist/*.whl

####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/phonopy/2.25.0
mkdir -p ${JOBDIR}
${BUILD_DIR}/env.sh_gen.sh ${JOBDIR}/env.sh
echo "source \$CONDA_SH" >> ${JOBDIR}/env.sh

cat > ${JOBDIR}/phonopy-2.25.0-run.sh << EOF
#!/bin/bash
source env.sh
cd ${BUILD_DIR}/phonopy-2.25.0
conda activate ${PHONOPY_ENV}
export OMP_NUM_THREADS=8
pytest
EOF

chmod u+x ${JOBDIR}/env.sh
#chmod u+x ${JOBDIR}/job_run.sh
#chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/phonopy-2.25.0-run.sh

set +x && echo_info "Install done!!!" && set -x

[RUN]
