[SERVER]
11.11.11.11

[DOWNLOAD]


[DEPENDENCY]
module purge
./jarvis -install hpckit/2025.0.0 any
module use $JARVIS_MODULES/modules
module load hpckit/2025.0.0
module load bisheng/compiler4.2.0/bishengmodule
module load bisheng/hmpi25.0.0/hmpi


./jarvis -install hdf5/1.12.0/clang bisheng+mpi
module load hdf5-clang/1.12.0-bisheng4.2.0-hmpi25.0.0
./jarvis -install pnetcdf/1.11.2/clang bisheng+mpi
module load pnetcdf-clang/1.11.2-bisheng4.2.0-hmpi25.0.0
./jarvis -install netcdf/4.7.4/clang bisheng+mpi
module load netcdf-clang/4.7.4-bisheng4.2.0-hmpi25.0.0-hdf51.12.0-pnetcdf1.11.2
./jarvis -install grib_api/1.21.0 bisheng+mpi
module load grib_api/1.21.0-bisheng4.2.0-hmpi25.0.0


[ENV]
module purge
module use $JARVIS_MODULES/modules

module load hpckit/2025.0.0
module load bisheng/compiler4.2.0/bishengmodule
module load bisheng/hmpi25.0.0/hmpi
module load hdf5-clang/1.12.0-bisheng4.2.0-hmpi25.0.0
module load pnetcdf-clang/1.11.2-bisheng4.2.0-hmpi25.0.0
module load netcdf-clang/4.7.4-bisheng4.2.0-hmpi25.0.0-hdf51.12.0-pnetcdf1.11.2
module load grib_api/1.21.0-bisheng4.2.0-hmpi25.0.0


[APP]
fake = 1
app_name = devgrib_api
app_version = 1.21.0
compiler = bisheng+mpi
build_dir = ${JARVIS_DEV}/devgrib_api/1.21.0-bisheng4.2.0-hmpi25.0.0
binary_dir =  ${JARVIS_JOBSCRIPT}/devgrib_api/1.21.0
case_dir =

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

####### build prepare
set +x && echo_info "build prepare!!!" && set -x


#### install jobsript for case test
echo "Install start"
JOBDIR=${JARVIS_JOBSCRIPT}/devgrib_api/1.21.0
mkdir -p ${JOBDIR}
${BUILD_DIR}/env.sh_gen.sh ${JOBDIR}/env.sh

echo "Appending module load to env.sh..."
#echo "module load cdo/1.9.8-bisheng4.2.0-hmpi25.0.0" >> ${JOBDIR}/env.sh

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_cmake
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=1"
#DSUB -o job_out_%J.log
#DSUB -e job_err_%J.log
#DSUB -T '2h'

export HOSTFILE=hostfile.cmake
rm -f \$HOSTFILE
touch \$HOSTFILE
cat \${CCSCHEDULER_ALLOC_FILE} | sort > \$HOSTFILE
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
source ./env.sh

ulimit -s unlimited

{  ; } 2>&1 | tee tee_cdo.xlog
EOF

cat > ${JOBDIR}/local_run.sh << EOF
#!/bin/bash
source ./env.sh
echo "GRIB_API_PATH:${GRIB_API_PATH}"
cd \$GRIB_API_PATH/bin
./grib_ls ../share/grib_api/samples/sh_sfc_grib1.tmpl
./grib_compare  ../share/grib_api/samples/sh_sfc_grib1.tmpl  ../share/grib_api/samples/sh_sfc_grib2.tmpl
cd -
EOF

cat > ${JOBDIR}/devgrib_api-1.21.0-run.sh << EOF
#!/bin/bash
./local_run.sh 2>&1 | tee tee_local_run.xlog
#dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/env.sh
chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/devgrib_api-1.21.0-run.sh

set +x && echo_info "Install done!!!" && set -x

[CLEAN]

[RUN]
run =   
binary = $JARVIS_ROOT/software/apps/bisheng4.1.0-hmpi2.4.3/
nodes = 1

[BATCH]
#定义日志文件
LOG_FILE="cdo-proformance.log"

>"$LOG_FILE"

$RUN_TOOL "cdo" "mpirun --allow-run-as-root -np 64 cdo XXXX" $LOG_FILE
#mpirun --allow-run-as-root -np 64 cdo XXXXX

echo "All commands executed. Performance log saved to $LOG_FILE"

[JOB]
#!/bin/sh
#DSUB -n cdo_test
#DSUB --mpi hmpi
#DSUB -q default
#DSUB -N 1
#DSUB -R cpu=128
#DSUB -oo cdo.%J.out
#DSUB -oe cdo.%J.err

LOG_FILE="cdo-proformance.log"

>"$LOG_FILE"

$RUN_TOOL "cdo" "mpirun --allow-run-as-root -np 64 cdo XXXX" $LOG_FILE

echo "ALL commands executed. Performance log saved to $LOG_FILE"

