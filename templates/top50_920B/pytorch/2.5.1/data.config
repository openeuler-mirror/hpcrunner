[SERVER]
11.11.11.11

[DOWNLOAD]

true

[DEPENDENCY]
set -e
set -x

module purge
module use $JARVIS_MODULES/modules
./jarvis -install anaconda3/2023.3 any

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load anaconda3/2023.3

[APP]
app_name = pytorch
app_version = 2.5.1
build_dir = ${JARVIS_DEV}/pytorch/2.5.1
binary_dir =
mod_exc_dir = conda_env/pytorch
case_dir = ${JARVIS_JOBSCRIPT}/pytorch/2.5.1/

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

####### build prepare
set +x && echo_info "build prepare!!!" && set -x

####### build start
set +x && echo_info "build start" && set -x

PATH_INSTALL=$1
mkdir -p ${PATH_INSTALL}
cd ${PATH_INSTALL}
set +x
source $CONDA_SH
set -x

PYTORCH_ENV=${PATH_INSTALL}/conda_env/pytorch
set +x && build_mod_check "${PATH_INSTALL}/conda_env/pytorch/lib/python3.9/site-packages/torch/__init__.py" "prompt" && set -x
if true; then

conda create --prefix=${PYTORCH_ENV} python=3.9
set +x
conda activate ${PYTORCH_ENV}
set -x
set +e
python3 -c "import torch;print(torch.__version__)"
res=$?
set -e
if [  $res -ne 0 ]; then
    conda install pytorch=2.5.1 torchvision torchaudio cpuonly -c pytorch
fi

set +e
python3 -c "import jaxlib;import jax;import chex; import numpy;print(jaxlib.__version__)"
res=$?
set -e
if [  $res -ne 0 ]; then
    python3 -m pip install tensorflow jaxlib==0.4.21 jax==0.4.21 chex==0.1.84 numpy==1.26.3 --trusted-host mirrors.huaweicloud.com -i https://mirrors.huaweicloud.com/repository/pypi/simple
res=$?
fi

[  $? -ne 0 ] && "echo No torch module" && exit 1

fi

####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x

JOBDIR=${JARVIS_JOBSCRIPT}/pytorch/2.5.1
mkdir -p ${JOBDIR}
${JARVIS_DEV}/pytorch/2.5.1/env.sh_gen.sh ${JOBDIR}/env.sh
echo "source \$CONDA_SH" >> ${JOBDIR}/env.sh

cat > ${JOBDIR}/SimpleNet.py << EOF
import torch
import torch.nn as nn
import torch.optim as optim

# 定义一个简单的神经网络
class SimpleNet(nn.Module):
    def __init__(self):
        super(SimpleNet, self).__init__()
        self.fc1 = nn.Linear(3, 5)
        self.fc2 = nn.Linear(5, 2)

    def forward(self, x):
        x = torch.relu(self.fc1(x))
        x = self.fc2(x)
        return x

# 创建网络实例
net = SimpleNet()

# 创建输入数据
input_data = torch.tensor([[1.0, 2.0, 3.0]])

# 前向传播
output = net(input_data)
print(output)
EOF

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_pytorch
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=1"
#DSUB -o pytorch_out_%J.log
#DSUB -e pytorch_err_%J.log
#DSUB -T '2h'

export HOSTFILE=hostfile.cmake
rm -f \$HOSTFILE
touch \$HOSTFILE
cat \${CCSCHEDULER_ALLOC_FILE} | sort > \$HOSTFILE
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
source ./env.sh

echo "activate conda env:${PYTORCH_ENV}"
conda activate ${PYTORCH_ENV}
ulimit -s unlimited

{ time  -p mpirun  --hostfile $HOSTFILE -np 1 --allow-run-as-root --bind-to cpulist:ordered -x OMP_PROC_BIND=close -x OMP_PLACES=cores  -x OMP_NUM_THREADS=1 -x UCX_TLS=sm python3 SimpleNet.py ; } 2>&1 | tee tee_pytorch.xlog
EOF

cat >${JOBDIR}/local_run.sh << EOF
#!/bin/bash
source ./env.sh
echo "activate conda env:${PYTORCH_ENV}"
conda activate ${PYTORCH_ENV}
{ time  -p python3 SimpleNet.py ; } 2>&1 | tee tee_pytorch.xlog

EOF

cat > ${JOBDIR}/pytorch-2.5.1-run.sh << EOF

./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF


chmod u+x ${JOBDIR}/env.sh
chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/pytorch-2.5.1-run.sh

set +x && echo_info "Install done!!!" && set -x

[CLEAN]
echo "make clean"

[RUN]
run = mpirun --allow-run-as-root -x OMP_NUM_THREADS=1 -np 1  bash -c " conda init bash"
binary = 
nodes = 1

[BATCH]
conda init bash
source ~/.bashrc
conda activate base

[JOB]
#!/bin/bash
#DSUB -n case_cmake
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=1"
#DSUB -o cmake_out_%J.log
#DSUB -e cmake_err_%J.log
#DSUB -T '2h'

export HOSTFILE=hostfile.cmake
rm -f $HOSTFILE
touch $HOSTFILE
cat ${CCSCHEDULER_ALLOC_FILE} | sort > $HOSTFILE
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
source ./env.sh

ulimit -s unlimited

{ time  -p mpirun  --hostfile $HOSTFILE -np 1 --allow-run-as-root --bind-to cpulist:ordered -x OMP_PROC_BIND=close -x OMP_PLACES=cores  -x OMP_NUM_THREADS=1 -x UCX_TLS=sm conda activate base ; } 2>&1 | tee tee_Anaconda3.xlog
