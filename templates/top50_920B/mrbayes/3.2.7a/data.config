[SERVER]
11.11.11.11

[DOWNLOAD]
mrbayes/3.2.7a https://github.com/NBISweden/MrBayes/releases/download/v3.2.7a/mrbayes-3.2.7a.tar.gz

[DEPENDENCY]
set -e
set -x

module purge
module use $JARVIS_MODULES/modules

./jarvis -install hpckit/2025.0.0 any
module load hpckit/2025.0.0
module load gcc/compiler12.3.1/gccmodule

tar --no-same-owner -zxvf ${JARVIS_DOWNLOAD}/mrbayes-3.2.7a.tar.gz -C ${JARVIS_DEV}

echo "done"

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.0.0
module load gcc/compiler12.3.1/gccmodule

[APP]
fake = 0
app_name = mrbayes
app_version = 3.2.7a
compiler = gcc
build_dir = ${JARVIS_DEV}/mrbayes-3.2.7a
binary_dir =
case_dir = ${JARVIS_JOBSCRIPT}/mrbayes/3.2.7a

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

set +x && check_install_path "${PATH_INSTALL}" && set -x
set +x && build_mod_check "${PATH_INSTALL}/bin/mb" "prompt" && set -x
set +x && rm_file_from_base ${PATH_INSTALL}/bin mb  && set -x
####### build prepare
set +x && echo_info "build prepare!!!" && set -x

####### build start
set +x && echo_info "build start" && set -x

./configure --prefix=${PATH_INSTALL}
make
make install

####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/mrbayes/3.2.7a
mkdir -p ${JOBDIR}

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_bma
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=128"
#DSUB -o pytorch_out_%J.log
#DSUB -e pytorch_err_%J.log
#DSUB -T '2h'
source env.sh
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1

EOF

cat > ${JOBDIR}/test.nex << EOF
#NEXUS
[Test 1. Mixed model with partitions.]
begin mrbayes;
    set autoclose=yes nowarnings=yes;
    execute "primates.nex";
    partition test = 2: 1-400, 401-.;
    set partition=test;
    lset nst=mixed rates=invgamma;
    unlink statefr=(all) revmat=(all) pinvar=(all) shape=(all);
    prset ratepr=variable;
    mcmc ng=20000;
    sump;
    sumt;
end;
EOF

cat >${JOBDIR}/local_run.sh << EOF
#!/bin/bash
module purge
module use $JARVIS_MODULES/modules
module load mrbayes/3.2.7a-kgcc12.3.1

if [ -d "test" ]; then
rm -rf test
fi
mkdir test
cd test
cp $PATH_INSTALL/share/examples/mrbayes/primates.nex .
cp ../test.nex .
time mb test.nex
EOF


cat > ${JOBDIR}/mrbayes-3.2.7a-run.sh << EOF
#!/bin/bash
cd ${JOBDIR}

./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/mrbayes-3.2.7a-run.sh

set +x && echo_info "Install done!!!" && set -x

[RUN]
