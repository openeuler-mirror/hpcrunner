[SERVER]
11.11.11.11

[DOWNLOAD]

true

[DEPENDENCY]
set -e
set -x

module purge
module use $JARVIS_MODULES/modules
./jarvis -install anaconda3/2023.3 any

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load anaconda3/2023.3
[APP]

app_name = Anaconda3
app_version = 2023.03
build_dir = ${JARVIS_DEV}/Anaconda3/2023.3
binary_dir = 
case_dir = ${JARVIS_JOBSCRIPT}/Anaconda3/2023.3/

[BUILD]
set -e
set -x

####  build
echo "build start"
echo "build done!!!"

#### install jobsript for case test
echo "Install start"
mkdir -p ${JARVIS_JOBSCRIPT}/Anaconda3/2023.3/
${JARVIS_DEV}/Anaconda3/2023.3/env.sh_gen.sh ${JARVIS_JOBSCRIPT}/Anaconda3/2023.3/env.sh

cat > ${JARVIS_JOBSCRIPT}/Anaconda3/2023.3/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_cmake
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=1"
#DSUB -o cmake_out_%J.log
#DSUB -e cmake_err_%J.log
#DSUB -T '2h'

export HOSTFILE=hostfile.cmake
rm -f \$HOSTFILE
touch \$HOSTFILE
cat \${CCSCHEDULER_ALLOC_FILE} | sort > \$HOSTFILE
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
source ./env.sh

ulimit -s unlimited

{ time  -p mpirun  --hostfile $HOSTFILE -np 1 --allow-run-as-root --bind-to cpulist:ordered -x OMP_PROC_BIND=close -x OMP_PLACES=cores  -x OMP_NUM_THREADS=1 -x UCX_TLS=sm $ANACONDA3_PATH /bin/conda activate base ; } 2>&1 | tee tee_Anaconda3.xlog
EOF

cat >${JARVIS_JOBSCRIPT}/Anaconda3/2023.3/local_run.sh << EOF
#!/bin/bash
source ./env.sh
{ time  -p $ANACONDA3_PATH /bin/conda activate base ; } 2>&1 | tee tee_Anaconda3.xlog

EOF

cat > ${JARVIS_JOBSCRIPT}/Anaconda3/2023.3/Anaconda3-run.sh << EOF

./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF


chmod u+x ${JARVIS_JOBSCRIPT}/Anaconda3/2023.3/env.sh
chmod u+x ${JARVIS_JOBSCRIPT}/Anaconda3/2023.3/job_run.sh
chmod u+x ${JARVIS_JOBSCRIPT}/Anaconda3/2023.3/local_run.sh
chmod u+x ${JARVIS_JOBSCRIPT}/Anaconda3/2023.3/Anaconda3-run.sh

echo "Install done!!!"

[CLEAN]
echo "make clean"

[RUN]
run = mpirun --allow-run-as-root -x OMP_NUM_THREADS=1 -np 1  bash -c " conda init bash"
binary = 
nodes = 1

[BATCH]
conda init bash
source ~/.bashrc
conda activate base

[JOB]
#!/bin/bash
#DSUB -n case_cmake
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=1"
#DSUB -o cmake_out_%J.log
#DSUB -e cmake_err_%J.log
#DSUB -T '2h'

export HOSTFILE=hostfile.cmake
rm -f $HOSTFILE
touch $HOSTFILE
cat ${CCSCHEDULER_ALLOC_FILE} | sort > $HOSTFILE
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
source ./env.sh

ulimit -s unlimited

{ time  -p mpirun  --hostfile $HOSTFILE -np 1 --allow-run-as-root --bind-to cpulist:ordered -x OMP_PROC_BIND=close -x OMP_PLACES=cores  -x OMP_NUM_THREADS=1 -x UCX_TLS=sm conda activate base ; } 2>&1 | tee tee_Anaconda3.xlog
