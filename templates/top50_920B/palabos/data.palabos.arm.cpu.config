[SERVER]
11.11.11.11

[DOWNLOAD]
palabos/2.1 https://gitlab.com/unigespc/palabos/-/archive/v2.1r0/palabos-v2.1r0.zip palabos-v2.1r0.zip


[DEPENDENCY]

yum install ImageMagick-6.7.8.9-15.el7_2.aarch64 -y
module purge
./jarvis -install hpckit/2025.0.0 any
module use $JARVIS_MODULES/modules
module load hpckit/2025.0.0
module load bisheng/compiler4.2.0/bishengmodule
module load bisheng/hmpi25.0.0/hmpi

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.0.0
module load bisheng/compiler4.2.0/bishengmodule
module load bisheng/hmpi25.0.0/hmpi



[APP]
app_name = palabos
app_version = 2.1
compiler = bisheng+mpi
build_dir = ${JARVIS_DEV}/palabos/2.1
binary_dir =  ${JARVIS_JOBSCRIPT}/palabos/2.1

case_dir =

[BUILD]
export CC=clang CXX=clang++ FC=flang
unzip ${JARVIS_DOWNLOAD}/palabos-v2.1r0.zip
cd palabos-v2.1r0
cd examples/showCases/cavity2d
make -j 16
cd ${JARVIS_DEV}/palabos/2.1/palabos-v2.1r0/examples/showCases/cavity3d
sed -n  "s|std::max( (plint)3|std::max( (plint)1000|p" ./cavity3d.cpp
sed -i  "s|std::max( (plint)3|std::max( (plint)1000|" ./cavity3d.cpp
make -j 128
echo "Creating job script directory: ${JARVIS_JOBSCRIPT}/palabos/2.1/"
mkdir -p ${JARVIS_JOBSCRIPT}/palabos/2.1/

echo "Copying files to job script directory..."
cp -ar ${JARVIS_DEV}/palabos/2.1/palabos-v2.1r0/examples/showCases/cavity3d/  ${JARVIS_JOBSCRIPT}/palabos/2.1/


echo "Generating environment script..."
 ${JARVIS_DEV}/palabos/2.1/env.sh_gen.sh ${JARVIS_JOBSCRIPT}/palabos/2.1/env.sh


cat > ${JARVIS_JOBSCRIPT}/palabos/2.1/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_ncl
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=1"
#DSUB -o ncl_out_%J.log
#DSUB -e ncl_err_%J.log
#DSUB -T '2h'

export HOSTFILE=hostfile.palabos
rm -f \$HOSTFILE
touch \$HOSTFILE
cat \${CCSCHEDULER_ALLOC_FILE} | sort > \$HOSTFILE
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
source ./env.sh
cd cavity3d
ulimit -s unlimited

{ time  -p mpirun  --hostfile $HOSTFILE -np 128 --allow-run-as-root --bind-to cpulist:ordered -x OMP_PROC_BIND=close -x OMP_PLACES=cores  -x OMP_NUM_THREADS=1 -x UCX_TLS=sm ./cavity3d 600 ; } 2>&1 | tee tee_palabos.xlog
EOF

cat > ${JARVIS_JOBSCRIPT}/palabos/2.1/local_run.sh << EOF
source env.sh
cd cavity3d
{ time mpirun  -mca pml ucx -mca btl tcp -x UCX_TLS=sm,tcp --allow-run-as-root -np 128 ./cavity3d 600 ; } 2>&1 | tee tee_palabos.xlog
EOF

cat > ${JARVIS_JOBSCRIPT}/palabos/2.1/palabos-2.1-run.sh << EOF
./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF


chmod u+x ${JARVIS_JOBSCRIPT}/palabos/2.1/env.sh
chmod u+x ${JARVIS_JOBSCRIPT}/palabos/2.1/job_run.sh
chmod u+x ${JARVIS_JOBSCRIPT}/palabos/2.1/local_run.sh
chmod u+x ${JARVIS_JOBSCRIPT}/palabos/2.1/palabos-2.1-run.sh

echo "Install done!!!"
[RUN]
run =  
binary =
nodes = 1
