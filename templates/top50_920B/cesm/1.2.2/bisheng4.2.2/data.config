[SERVER]
11.11.11.11

[DOWNLOAD]

[DEPENDENCY]
set -e
set -x
module purge
module use $JARVIS_MODULES/modules
./jarvis -install cmake/3.28.2 any
module load cmake/3.28.2
./jarvis -install hpckit/2025.0.0 any
set +x
module load hpckit/2025.0.0
module load gcc/compiler12.3.1/gccmodule
module load bisheng/compiler4.2.0/bishengmodule
module load bisheng/hmpi25.0.0/hmpi
set -x
export CC=clang CXX=clang++ FC=flang

./jarvis -install zlib/1.2.11 bisheng
set +x
module  load zlib/1.2.11-bisheng4.2.0 
set -x

./jarvis -install szip/2.1.1 bisheng
set +x
module load szip/2.1.1-bisheng4.2.0
set -x

./jarvis -install hdf5/1.12.3/clang bisheng+mpi
set +x
module load hdf5-clang/1.12.3-bisheng4.2.0-hmpi25.0.0
set -x

./jarvis -install pnetcdf/1.11.2/clang bisheng+mpi
set +x
module load pnetcdf-clang/1.11.2-bisheng4.2.0-hmpi25.0.0
set -x

./jarvis -install netcdf/4.7.4/clang bisheng+mpi
set +x
module load netcdf-clang/4.7.4-bisheng4.2.0-hmpi25.0.0
set -x

export CC=gcc CXX=g++ FC=gfortran
./jarvis -install curl/7.70.0 gcc
set +x
module load curl/7.70.0-kgcc12.3.1
set -x

export CC=clang CXX=clang++ FC=flang
./jarvis -install openblas/0.3.9/clang bisheng
set +x
module load openblas-clang/0.3.9-bisheng4.2.0
set -x
exit 0

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load cmake/3.28.2
module load hpckit/2025.0.0
module load gcc/compiler12.3.1/gccmodule
module load bisheng/compiler4.2.0/bishengmodule
module load bisheng/hmpi25.0.0/hmpi
module load zlib/1.2.11-bisheng4.2.0
module load szip/2.1.1-bisheng4.2.0
module load hdf5-clang/1.12.3-bisheng4.2.0-hmpi25.0.0
module load pnetcdf-clang/1.11.2-bisheng4.2.0-hmpi25.0.0
module load netcdf-clang/4.7.4-bisheng4.2.0-hmpi25.0.0-hdf51.12.3-pnetcdf1.11.2
module load curl/7.70.0-kgcc12.3.1
module load openblas-clang/0.3.9-bisheng4.2.0

[APP]
app_name = cesm
app_version = 1.2.2
compiler = bisheng+mpi
build_dir = ${JARVIS_APP}/cesm/1.2.2-bisheng4.2.0-hmpi25.0.0/project
binary_dir =
mod_exc_dir = project 
case_dir = ${JARVIS_JOBSCRIPT}/cesm/1.2.2

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1

####### build prepare
set +x && echo_info "build prepare!!!" && set -x
cd ${JARVIS_APP}/cesm/1.2.2-bisheng4.2.0-hmpi25.0.0/project

if [ -d $(pwd)/cesm-1.2.2 ] && false; then
	set +x && echo_error "Exist Project:$(pwd)/cesm-1.2.2!!!" && set -x
	exit 1
fi
build_mod_check_dir  "$(pwd)/cesm-1.2.2" "prompt"
rm -rf $(pwd)/cesm-1.2.2
unzip -q ${JARVIS_DOWNLOAD}/CESM-release-rcesm1.0.zip
mv CESM-release-rcesm1.0 cesm-1.2.2

tar xzf ${JARVIS_DOWNLOAD}/CESM-manic-1.2.2.tar.gz
cp -rf CESM-manic-1.2.2/* cesm-1.2.2/manage_externals/
rm -rf CESM-manic-1.2.2

unzip -q ${JARVIS_DOWNLOAD}/cime-ihesp-regional-master_200911.zip
mv cime-ihesp-regional-master_200911 cesm-1.2.2/cime

mkdir -p cesm-1.2.2/components
unzip -q ${JARVIS_DOWNLOAD}/ctsm-ihesp-regional-master_191203.zip
mv ctsm-ihesp-regional-master_191203 cesm-1.2.2/components/clm

unzip -q ${JARVIS_DOWNLOAD}/roms_ihesp-ihesp-regional-master_200922.zip
mv roms_ihesp-ihesp-regional-master_200922 cesm-1.2.2/components/roms

unzip -q ${JARVIS_DOWNLOAD}/wrf_ihesp-ihesp-regional-master_200922.zip
mv wrf_ihesp-ihesp-regional-master_200922 cesm-1.2.2/components/wrf

unzip -q ${JARVIS_DOWNLOAD}/PTCLM-PTCLM2_180611.zip
mv PTCLM-PTCLM2_180611 cesm-1.2.2/components/clm/tools/PTCLM

unzip -q ${JARVIS_DOWNLOAD}/fates-release-fates_s1.8.1_a3.0.0.zip
mv fates-release-fates_s1.8.1_a3.0.0 cesm-1.2.2/components/clm/src/fates

set +x && echo_info "3 Check all externals...." && set -x
cd cesm-1.2.2
./manage_externals/checkout_externals
./manage_externals/checkout_externals -S

mkdir -p ${PATH_INSTALL}/bin
rm -rf ${PATH_INSTALL}/bin/cesm-1.2.2
cp ${BUILD_DIR}/cesm-1.2.2 ${PATH_INSTALL}/bin/ -ar

JOBDIR=${JARVIS_JOBSCRIPT}/cesm/1.2.2

####### build
set +x && echo_info "build start" && set -x

cat > ${PATH_INSTALL}/module_tail.modulefile << EOF
EOF

set +x && echo_info "build done!!!" && set -x


####### install start
set +x && echo_info "install start" && set -x

set +x && echo_info "install done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
mkdir -p ${JOBDIR}
${BUILD_DIR}/env.sh_gen.sh ${JOBDIR}/env.sh
cp ${JARVIS_DOWNLOAD}/cesm_1.2.2_inputdata.tar.gz ${JOBDIR}/ -ar
cp ${JARVIS_ROOT}/dataconfig_patches/cesm_case.sh ${JOBDIR}/ -ar
chmod ugo+rw ${JOBDIR}/cesm_case.sh

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_cesm
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=256"
#DSUB -o pytorch_out_%J.log
#DSUB -e pytorch_err_%J.log
#DSUB -T '2h'

export HOSTFILE=hostfile.cesm
rm -f \$HOSTFILE
touch \$HOSTFILE
cat \${CCSCHEDULER_ALLOC_FILE} | sort > \$HOSTFILE
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
source ./env.sh

WORK_DIR=\$(pwd)
mkdir \${WORK_DIR}/job_work

./cesm_case.sh CASE_BUILD \${WORK_DIR}/job_work ${PATH_INSTALL} 2>&1 | tee tee_cesm_build.xlog

./cesm_case.sh CASE_SUBMIT \${WORK_DIR}/job_work ${PATH_INSTALL} 2>&1 | tee tee_cesm_submit1.xlog

EOF

cat >${JOBDIR}/local_run.sh << EOF
#!/bin/bash
source ./env.sh
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
WORK_DIR=\$(pwd)
mkdir -p \${WORK_DIR}/local_work

./cesm_case.sh CASE_BUILD \${WORK_DIR}/local_work "${PATH_INSTALL}" 2>&1 | tee tee_cesm_build.xlog
./cesm_case.sh CASE_SUBMIT \${WORK_DIR}/local_work "${PATH_INSTALL}" 2>&1 | tee tee_cesm_submit.xlog

EOF

cat > ${JOBDIR}/cesm-4.6.0-run.sh << EOF
./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/env.sh
chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/cesm-4.6.0-run.sh

set +x && echo_info "Install script done!!!" && set -x

[CLEAN]
./clean -a

[RUN]
run = mpirun --allow-run-as-root -n 32 -x OMP_NUM_THREADS=1 -bind-to core ${WRF_DIR}/run/wrf.exe
binary = 
nodes = 1

