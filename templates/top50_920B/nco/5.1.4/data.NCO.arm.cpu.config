[SERVER]
11.11.11.11

[DOWNLOAD]
NCO/5.1.4 https://sourceforge.net/projects/nco/files/nco-5.1.4.tar.gz
NCO/CASE http://thredds.northwestknowledge.net:8080/thredds/fileServer/TERRACLIMATE_ALL/TerraClimate4C_climateanalogs_variabilitymask.nc TerraClimate4C_climateanalogs_variabilitymask.nc

[DEPENDENCY]
set -e
set -x
module purge
./jarvis -install hpckit/2025.0.0 any
module use $JARVIS_MODULES/modules
module load hpckit/2025.0.0
module load bisheng/compiler4.2.0/bishengmodule
module load bisheng/hmpi25.0.0/hmpi

./jarvis -install pnetcdf/1.11.2/clang bisheng+mpi
module load pnetcdf-clang/1.11.2-bisheng4.2.0-hmpi25.0.0
./jarvis -install libjpeg/v9b bisheng+mpi
module load libjpeg/v9b-bisheng4.2.0-hmpi25.0.0
./jarvis -install hdf5/1.8.20/clang bisheng+mpi
module load hdf5-clang/1.8.20-bisheng4.2.0-hmpi25.0.0
./jarvis -install hdf4/4.2.13 bisheng+mpi
module load hdf4/4.2.13-bisheng4.2.0-hmpi25.0.0
./jarvis -install netcdf/4.7.4/clang bisheng+mpi
module load netcdf-clang/4.7.4-bisheng4.2.0-hmpi25.0.0-hdf51.8.20-pnetcdf1.11.2
./jarvis -install gsl/2.6 bisheng+mpi
./jarvis -install antlr/2.7.7 bisheng+mpi
./jarvis -install udunits/2.2.28 bisheng+mpi


[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.0.0
module load bisheng/compiler4.2.0/bishengmodule
module load bisheng/hmpi25.0.0/hmpi
module load pnetcdf-clang/1.11.2-bisheng4.2.0-hmpi25.0.0
module load libjpeg/v9b-bisheng4.2.0-hmpi25.0.0
module load hdf5-clang/1.8.20-bisheng4.2.0-hmpi25.0.0
module load netcdf-clang/4.7.4-bisheng4.2.0-hmpi25.0.0-hdf51.8.20-pnetcdf1.11.2
module load gsl/2.6-bisheng4.2.0-hmpi25.0.0
module load antlr/2.7.7-bisheng4.2.0-hmpi25.0.0
module load udunits/2.2.28-bisheng4.2.0-hmpi25.0.0


[APP]
app_name = nco
app_version = 5.1.4
compiler = bisheng+mpi
build_dir = ${JARVIS_DEV}/nco/5.1.4-bisheng4.2.0-hmpi25.0.0
binary_dir =
case_dir = ${JARVIS_JOBSCRIPT}/nco/5.1.4

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

####### build prepare
set +x && echo_info "build prepare!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/nco/5.1.4

if true; then
build_mod_check "${PATH_INSTALL}/bin/ncks" "prompt"
rm -rf nco-5.1.4
tar zxvf ${JARVIS_DOWNLOAD}/nco-5.1.4.tar.gz
cd nco-5.1.4
####### build start
set +x && echo_info "build start" && set -x

MPIRUN_PATH=$(which mpirun)
export MPI_HOME=$(dirname $(dirname ${MPIRUN_PATH}))

./configure --prefix=${PATH_INSTALL} \
  CPPFLAGS="-I${ANTLR_PATH}/include -I${UDUNITS_PATH}/include -I${NETCDF_CLANG_PATH}/include" \
  CFLAGS="-fopenmp -O2" \
  LDFLAGS="-L${ANTLR_PATH}/lib -L${UDUNITS_PATH}/lib -L${NETCDF_CLANG_PATH}/lib -L${MPI_HOME}/lib " \
  LIBS="-ludunits2 -lnetcdf -lantlr "

make -j 32
make install

fi
####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
mkdir -p ${JOBDIR}
${BUILD_DIR}/env.sh_gen.sh ${JOBDIR}/env.sh
echo "module load nco/5.1.4-bisheng4.2.0-hmpi25.0.0" >> ${JOBDIR}/env.sh
cp ${JARVIS_DOWNLOAD}/TerraClimate4C_climateanalogs_variabilitymask.nc ${JOBDIR}/ -ar

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_nco
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=1"
#DSUB -o job_out_%J.log
#DSUB -e job_err_%J.log
#DSUB -T '2h'

export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
source ./env.sh

ulimit -s unlimited

EOF

cat > ${JOBDIR}/local_run.sh << EOF
#!/bin/bash
source ./env.sh
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
ncfile=TerraClimate4C_climateanalogs_variabilitymask.nc
file_str=txt
time -p ncks -m \$ncfile
rm -f ncks_trd_output.\$file_str
time -p ncks --trd \$ncfile > ncks_trd_output.\$file_str
rm -f lon_output.nc.\$file_str
time -p ncks -v lon \$ncfile lon_output.nc.\$file_str
time -p ncdump -h \$ncfile

EOF

cat > ${JOBDIR}/nco-5.1.4-run.sh << EOF
#!/bin/bash
./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/env.sh
chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/nco-5.1.4-run.sh

set +x && echo_info "Install done!!!" && set -x

[RUN]
run =  ./ncap2 -v
binary = 
nodes = 1

