[SERVER]
11.11.11.11

[DOWNLOAD]


[DEPENDENCY]
module purge
module use $JARVIS_MODULES/modules
export CC=gcc CXX=g++
./jarvis -install openmpi/4.1.2 gcc

module load openmpi/4.1.2-gcc10.3.1


[ENV]
module purge
module use $JARVIS_MODULES/modules
export CC=gcc CXX=g++
module load openmpi/4.1.2-gcc10.3.1


[APP]
fake = 1
app_name = devopenmpi
app_version = 4.1.2
compiler = gcc
build_dir = ${JARVIS_DEV}/devopenmpi/4.1.2-gcc10.3.1
binary_dir =  ${JARVIS_JOBSCRIPT}/devopenmpi/4.1.2
case_dir =

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

####### build prepare
set +x && echo_info "build prepare!!!" && set -x


#### install jobsript for case test
echo "Install start"
JOBDIR=${JARVIS_JOBSCRIPT}/devopenmpi/4.1.2
mkdir -p ${JOBDIR}
${BUILD_DIR}/env.sh_gen.sh ${JOBDIR}/env.sh

echo "Appending module load to env.sh..."
#echo "module load xxx" >> ${JOBDIR}/env.sh

cat > ${JOBDIR}/HelloWorld.c << 'EOF'
#include <mpi.h>
#include <stdio.h>

int main(int argc, char** argv) {
    // 初始化MPI环境
    MPI_Init(NULL, NULL);
    
    // 获取进程总数
    int world_size;
    MPI_Comm_size(MPI_COMM_WORLD, &world_size);
    
    // 获取当前进程的排名（ID）
    int world_rank;
    MPI_Comm_rank(MPI_COMM_WORLD, &world_rank);
    
    // 获取处理器名称
    char processor_name[MPI_MAX_PROCESSOR_NAME];
    int name_len;
    MPI_Get_processor_name(processor_name, &name_len);
    
    // 打印Hello World消息
    printf("Hello world from processor %s, rank %d out of %d processors\n",
           processor_name, world_rank, world_size);
    
    // 终止MPI环境
    MPI_Finalize();
    
    return 0;
}
EOF

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_cmake
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=1"
#DSUB -o job_out_%J.log
#DSUB -e job_err_%J.log
#DSUB -T '2h'

export HOSTFILE=hostfile.cmake
rm -f \$HOSTFILE
touch \$HOSTFILE
cat \${CCSCHEDULER_ALLOC_FILE} | sort > \$HOSTFILE
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
source ./env.sh

ulimit -s unlimited

{  ; } 2>&1 | tee tee_cdo.xlog
EOF

cat > ${JOBDIR}/local_run.sh << EOF
#!/bin/bash
source ./env.sh
mpicc -o HelloWorld HelloWorld.c
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
{  mpirun -n 2 --mca btl ^openib,tcp,vader,uct -x UCX_TLS=sm,rc -mca pml ucx  HelloWorld; } 2>&1 | tee tee_cdo.xlog
EOF

cat > ${JOBDIR}/openmpi-4.1.2-run.sh << EOF
#!/bin/bash
./local_run.sh 2>&1 | tee tee_local_run.xlog
#dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/env.sh
chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/openmpi-4.1.2-run.sh

set +x && echo_info "Install done!!!" && set -x

[CLEAN]

[RUN]
run =   
binary = $JARVIS_ROOT/software/apps/bisheng4.1.0-hmpi2.4.3/
nodes = 1

[BATCH]
#定义日志文件
LOG_FILE="cdo-proformance.log"

>"$LOG_FILE"

$RUN_TOOL "cdo" "mpirun --allow-run-as-root -np 64 cdo XXXX" $LOG_FILE
#mpirun --allow-run-as-root -np 64 cdo XXXXX

echo "All commands executed. Performance log saved to $LOG_FILE"

[JOB]
#!/bin/sh
#DSUB -n cdo_test
#DSUB --mpi hmpi
#DSUB -q default
#DSUB -N 1
#DSUB -R cpu=128
#DSUB -oo cdo.%J.out
#DSUB -oe cdo.%J.err

LOG_FILE="cdo-proformance.log"

>"$LOG_FILE"

$RUN_TOOL "cdo" "mpirun --allow-run-as-root -np 64 cdo XXXX" $LOG_FILE

echo "ALL commands executed. Performance log saved to $LOG_FILE"

