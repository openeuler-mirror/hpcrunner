[SERVER]
11.11.11.11

[DOWNLOAD]
gadget2/v2.3.5 https://github.com/gadget-framework/gadget2/archive/refs/tags/v2.3.5.tar.gz gadget2-2.3.5.tar.gz 

[DEPENDENCY]
set -e
#set -x
module purge
module use $JARVIS_MODULES/modules
./jarvis -install cmake/3.28.2 any
module load cmake/3.28.2
./jarvis -install hpckit/2025.0.0 any
module load hpckit/2025.0.0
module load gcc/gcc12.3.1/gccmodule



[ENV]
module purge
module use $JARVIS_MODULES/modules
module load cmake/3.28.2
module load hpckit/2025.0.0
module load gcc/compiler12.3.1/gccmodule

[APP]
app_name = gadget2
app_version = 2.3.5
compiler = gcc
build_dir = ${JARVIS_APP}/gadget2/2.3.5-kgcc12.3.1/project
binary_dir =
mod_exc_dir = WRFV4.6.0 
case_dir = ${JARVIS_JOBSCRIPT}/gadget2/2.3.1

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
LOG_FILE=tee_install_$(date +%Y%m%d%H%M%S).xlog
echo "CURRENT SHELL:$SHELL"

####### build prepare
set +x && echo_info "build prepare!!!" && set -x
set +x && build_mod_check "${PATH_INSTALL}/bin/gadget" "prompt" && set -x
rm -f ${PATH_INSTALL}/bin/gadget
{
rm -rf gadget2-2.3.5
tar -zxf ${JARVIS_DOWNLOAD}/gadget2-2.3.5.tar.gz
cd gadget2-2.3.5

####### build start
set +x && echo_info "build start" && set -x
mkdir -p ${PATH_INSTALL}/bin
sed -n "s|/usr/local|${PATH_INSTALL}|gp" GNUmakefile
sed -i "s|/usr/local|${PATH_INSTALL}|g" GNUmakefile
make PREFIX=${PATH_INSTALL} verbose=1
make install 


} 2>&1 | tee ${LOG_FILE}
res=${PIPESTATUS[0]}
[ $res -ne 0 ] && echo "compile Failed" && exit 1

cat > ${PATH_INSTALL}/module_tail.modulefile << EOF
setenv PRJ_URL_GADGET2 ${JARVIS_APP}/gadget2/2.3.5-kgcc12.3.1/project/gadget2-2.3.5
EOF

####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/gadget2/2.3.5
mkdir -p ${JOBDIR}
${BUILD_DIR}/env.sh_gen.sh ${JOBDIR}/env.sh

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_wrf
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=128"
#DSUB -o job_out_%J.log
#DSUB -e job_err_%J.log
#DSUB -T '2h'

export HOSTFILE=hostfile.job
rm -f \$HOSTFILE
touch \$HOSTFILE
cat \${CCSCHEDULER_ALLOC_FILE} | sort > \$HOSTFILE
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
source ./env.sh
{   gadget -v ; } 2>&1 | tee tee_gadget2.xlog
EOF

cat > ${JOBDIR}/local_run.sh << EOF
#!/bin/bash
source ./env.sh
{ gadget -v ; } 2>&1 | tee tee_gadget2.xlog
EOF

cat > ${JOBDIR}/gadget2-2.3.5-run.sh << EOF
#!/bin/bash

./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/env.sh
chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/gadget2-2.3.5-run.sh

set +x && echo_info "Install done!!!" && set -x

[CLEAN]
./clean -a

[RUN]
run = mpirun --allow-run-as-root -n 32 -x OMP_NUM_THREADS=1 -bind-to core ${WRF_DIR}/run/wrf.exe
binary = 
nodes = 1

