[SERVER]
11.11.11.11

[DOWNLOAD]
NCL/6.6.2 $JARVIS_PROXY/chen-shaoheng/NCL-SOURCE/releases/download/ncl-6.6.2/ncl-6.6.2.tar.gz ncl-6.6.2.tar.gz
triangle/1.6 http://www.netlib.org/voronoi/triangle.zip

[DEPENDENCY]
set -e
source ${JARVIS_LIBSHELL}
check_rpms_installed tar byacc bison expat-devel expat libtirpc-devel libX11 libX11-devel libXmu libXmu-devel libXaw libXaw-devel flex flex-devel freetype-devel libpng-devel libpng libjpeg-turbo-devel libjpeg-turbo  libXi libSM-devel libXi-devel libXext-devel pkgconf curl libcurl-devel zlib-devel cairo cairo-devel pixman pixman-devel patch  || exit 1
module purge
module use $JARVIS_MODULES/modules
./jarvis -install hpckit/2025.0.0 any
module load hpckit/2025.0.0
module load gcc/compiler12.3.1
module load gcc/hmpi25.0.0

export CC=mpicc CXX=mpicxx FC=mpif90 F77=mpif90
./jarvis -install hdf5/1.10.1 gcc+mpi
module load hdf5/1.10.1-kgcc12.3.1-hmpi25.0.0

export CC=mpicc CXX=mpicxx FC=mpifort
./jarvis -install pnetcdf/1.11.2 gcc+mpi
module add pnetcdf/1.11.2-kgcc12.3.1-hmpi25.0.0

./jarvis -install netcdf/4.7.4  gcc+mpi
module add netcdf/4.7.4-kgcc12.3.1-hmpi25.0.0-hdf51.10.1-pnetcdf1.11.2

export CC=gcc FC=gfortran CXX=g++
./jarvis -install libjpeg/v9b gcc
module add libjpeg/v9b-kgcc12.3.1

export CC=mpicc CXX=mpicxx FC=mpifort F77=mpifort
./jarvis -install hdf4/4.2.15 gcc+mpi
module add hdf4/4.2.15-kgcc12.3.1-hmpi25.0.0

export CC=gcc FC=gfortran CXX=g++
./jarvis -install proj/7.0.0 gcc
module add proj/7.0.0-kgcc12.3.1

./jarvis -install libpng/1.6.37 gcc
module add libpng/1.6.37-kgcc12.3.1
export CC=mpicc CXX=mpicxx FC=mpifort
./jarvis -install gdal/3.9.0 gcc
module add gdal/3.9.0-kgcc12.3.1
 

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.0.0
module load gcc/compiler12.3.1
module load gcc/hmpi25.0.0
module load hdf5/1.10.1-kgcc12.3.1-hmpi25.0.0
module add pnetcdf/1.11.2-kgcc12.3.1-hmpi25.0.0
module add netcdf/4.7.4-kgcc12.3.1-hmpi25.0.0-hdf51.10.1-pnetcdf1.11.2
module add libjpeg/v9b-kgcc12.3.1
module add hdf4/4.2.15-kgcc12.3.1-hmpi25.0.0
module add proj/5.2.0-kgcc12.3.1
module add libpng/1.6.37-kgcc12.3.1
module add gdal/3.9.0-kgcc12.3.1


[APP]
fake = 1
app_name = devgdal
app_version = 3.9.0
compiler = gcc+mpi
build_dir = ${JARVIS_DEV}/devgdal/3.9.0-kgcc12.3.1-hmpi25.0.0/project
binary_dir =
case_dir = ${JARVIS_JOBSCRIPT}/gdal/3.9.0

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

####### build prepare
set +x && echo_info "build prepare!!!" && set -x
echo "PRJ_URL_GDAL_030900:${PRJ_URL_GDAL_030900}"

#### install jobsript for case test
echo "Install start"
JOBDIR=${JARVIS_JOBSCRIPT}/gdal/3.9.0
mkdir -p ${JOBDIR}
${BUILD_DIR}/env.sh_gen.sh ${JOBDIR}/env.sh

echo "Appending module load to env.sh..."
#echo "module load xxx" >> ${JOBDIR}/env.sh


cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_gdal
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=1"
#DSUB -o job_out_%J.log
#DSUB -e job_err_%J.log
#DSUB -T '2h'

export HOSTFILE=hostfile.cmake
rm -f \$HOSTFILE
touch \$HOSTFILE
cat \${CCSCHEDULER_ALLOC_FILE} | sort > \$HOSTFILE
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
source ./env.sh

ulimit -s unlimited

EOF

cat > ${JOBDIR}/local_run.sh << EOF
#!/bin/bash
source ./env.sh
cd ${PRJ_URL_GDAL_030900}/build
ctest -v --output-on-failure
EOF

cat > ${JOBDIR}/gdal-3.9.0-run.sh << EOF
#!/bin/bash
source ./env.sh
./local_run.sh 2>&1 | tee tee_localrun.xlog
#dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/env.sh
chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/gdal-3.9.0-run.sh 

set +x && echo_info "Install done!!!" && set -x


[BATCH]
mpirun --allow-run-as-root -x OMP_NUM_THREADS=1 -np 1 test.sh

[RUN]
run = mpirun -v --allow-run-as-root -x OMP_NUM_THREADS=1 -np 1  ${JARVIS_JOBSCRIPT}/NCL/6.6.2/test.sh
binary = 
nodes = 1

[JOB]
#!/bin/bash
#DSUB -n case_ncl
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=1"
#DSUB -o ncl_out_%J.log
#DSUB -e ncl_err_%J.log
#DSUB -T '2h'

export HOSTFILE=hostfile.ncl
rm -f $HOSTFILE
touch $HOSTFILE
cat ${CCSCHEDULER_ALLOC_FILE} | sort > $HOSTFILE
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
source ./env.sh

ulimit -s unlimited

{ time  -p mpirun  --hostfile $HOSTFILE -np 1 --allow-run-as-root --bind-to cpulist:ordered -x OMP_PROC_BIND=close -x OMP_PLACES=cores  -x OMP_NUM_THREADS=1 -x UCX_TLS=sm sh tast.sh ; } 2>&1 | tee tee_ncl.xlog

