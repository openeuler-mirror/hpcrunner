[SERVER]
11.11.11.11

[DOWNLOAD]
samtools https://github.com/samtools/samtools/releases/download/1.10/samtools-1.10.tar.bz2 samtools-1.10.tar.bz2

[DEPENDENCY]
set -e
set -x
module purge
module use $JARVIS_MODULES/modules
./jarvis -install hpckit/2025.0.0 any
module load hpckit/2025.0.0
module load bisheng/compiler4.2.0/bishengmodule
./jarvis -install samtools/1.10 bisheng
module load samtools/1.10-bisheng4.2.0


[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.0.0
module load bisheng/compiler4.2.0/bishengmodule
module load load samtools/1.10-bisheng4.2.0

[APP]
fake = 1
app_name = samtools
app_version = 1.10
compiler = bisheng
build_dir = ${JARVIS_APP}/samtools/1.10-bisheng4.2.0/project
binary_dir =
case_dir = ${JARVIS_JOBSCRIPT}/samtools/1.10

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"


####### build prepare
set +x && echo_info "build prepare!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/samtools/1.10

####### build start
set +x && echo_info "build start" && set -x


####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
mkdir -p ${JOBDIR}
${BUILD_DIR}/env.sh_gen.sh ${JOBDIR}/env.sh
echo "module load samtools/1.10-bisheng4.2.0" >> ${JOBDIR}/env.sh

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_bma
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=128"
#DSUB -o out_%J.log
#DSUB -e err_%J.log
#DSUB -T '2h'
source env.sh
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
cp ${JARVIS_JOBSCRIPT}/caseshare/bwaoutput/bwa.sam ./ -ar
time -p samtools view -bS bwa.sam > bwa.bam
time -p samtools sort bwa.bam > bwa.sort
EOF

cat >${JOBDIR}/local_run.sh << EOF
#!/bin/bash
source env.sh
cp ${JARVIS_JOBSCRIPT}/caseshare/bwaoutput/bwa.sam ./ -ar
time -p samtools view -bS bwa.sam > bwa.bam
time -p samtools sort bwa.bam > bwa.sort
EOF

cat > ${JOBDIR}/samtools-1.10-run.sh << EOF
#!/bin/bash
[ ! -f ${JARVIS_JOBSCRIPT}/caseshare/bwaoutput/bwa.sam ] && echo "do bma case firstly" && exit 1
./local_run.sh 2>&1 | tee tee_local_run.xlog
dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/env.sh
chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/samtools-1.10-run.sh

set +x && echo_info "Install done!!!" && set -x

[RUN]
