[SERVER]
11.11.11.11

[DOWNLOAD]

[DEPENDENCY]
set -e
set -x

module purge
module use $JARVIS_MODULES/modules
./jarvis -install hpckit/2025.0.0 any
module load hpckit/2025.0.0
module load gcc/compiler12.3.1


[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.0.0
module load gcc/compiler12.3.1

[APP]
app_name = gulp
app_version = 6.2
compiler = gcc
build_dir = ${JARVIS_APP}/gulp/6.2-kgcc12.3.1/project
binary_dir = ${JARVIS_APP}/gulp/6.2-kgcc12.3.1/project/gulp-6.2/Src/
case_dir = ${JARVIS_DEV}/gulp/6.2/gulp-6.2/Examples/

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"

####### build prepare
set +x && echo_info "build prepare!!!" && set -x

set +x && build_mod_check "${BUILD_DIR}/gulp-6.2/Src/gulp" "prompt" && set -x

####### build start
set +x && echo_info "build start" && set -x

export CC=`which gcc`
export CXX=`which g++`
export FC=`which gfortran`
tar -vzxf ${JARVIS_DOWNLOAD}/gulp-6.2.tgz

cd gulp-6.2/Src
./mkgulp -j 16

mkdir -p ${PATH_INSTALL}/bin
rm -f ${PATH_INSTALL}/bin/gulp
ln -s ${BUILD_DIR}/gulp-6.2/Src/gulp ${PATH_INSTALL}/bin/gulp 


####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
JOBDIR="${JARVIS_JOBSCRIPT}/gulp/6.2"
mkdir -p ${JOBDIR}
${BUILD_DIR}/env.sh_gen.sh ${JOBDIR}/env.sh
echo "module load gulp/6.2-kgcc12.3.1" >> ${JOBDIR}/env.sh
cp -r ${BUILD_DIR}/gulp-6.2/Examples  ${JOBDIR}/

cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_gulp
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=1"
#DSUB -o gulp_out_%J.log
#DSUB -e gulp_err_%J.log
#DSUB -T '2h'

export HOSTFILE=hostfile.gulp
rm -f \$HOSTFILE
touch \$HOSTFILE
cat \${CCSCHEDULER_ALLOC_FILE} | sort > \$HOSTFILE
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
source ./env.sh

ulimit -s unlimited
cd Examples
{ gulp < example11.gin > example11.got; } 2>&1 | tee tee_gulp.xlog
EOF


cat > ${JOBDIR}/local_run.sh << EOF
#!/bin/bash
source ./env.sh
cd Examples
{ time gulp < example7a.gin > example7a.got ; } 2>&1 | tee tee_gulp.xlog
cat example7a.got
echo -e "\033[0;32m=============================\033[0m"
EOF

cat > ${JOBDIR}/gulp-6.2-kgcc12.3.1-run.sh << EOF
#!/bin/bash
source ./env.sh
./local_run.sh 2>&1 | tee tee_local_run.xlog
#dsub -s job_run.sh
EOF


chmod u+x ${JOBDIR}/env.sh
chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/gulp-6.2-kgcc12.3.1-run.sh
set +x && echo_info "Install done!!!" && set -x

[CLEAN]
make clean

[RUN]
run = 
binary = gulp < example84.gin > example84.got
nodes = 1

[PERF]
perf= 
nsys=
ncu=--target-processes all
