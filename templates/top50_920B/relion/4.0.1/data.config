[SERVER]
11.11.11.11

[DOWNLOAD]
relion/4.0.1 https://github.com/3dem/relion/archive/refs/tags/4.0.1.tar.gz relion-4.0.1.tar.gz
class_ranker/0.1.3 ftp://ftp.mrc-lmb.cam.ac.uk/pub/dari/class_ranker_0.1.3_torch_1.0.1.pt.tar.gz class_ranker_0.1.3_torch_1.0.1.pt.tar.gz

[DEPENDENCY]
set -e

module purge
module use $JARVIS_MODULES/modules
./jarvis -install cmake/3.28.2 any
module load cmake/3.28.2
./jarvis -install hpckit/2025.0.0 any
module load hpckit/2025.0.0
module load bisheng/compiler4.2.0/bishengmodule
module load bisheng/hmpi25.0.0/hmpi
set -x
./jarvis -install fftw/3.3.8 bisheng+mpi
module load fftw/3.3.8-bisheng4.2.0-hmpi25.0.0

./jarvis -install wxWidgets/3.0.5 bisheng
module load  wxWidgets/3.0.5-bisheng4.2.0

./jarvis -install ctffind/4.1.14/clang bisheng
module load ctffind-clang/4.1.14-bisheng4.2.0
set +x
./jarvis -install libpng/1.6.37 bisheng
module load libpng/1.6.37-bisheng4.2.0

echo "done"

[ENV]
module purge
module use $JARVIS_MODULES/modules
module load hpckit/2025.0.0
module load bisheng/compiler4.2.0/bishengmodule
module load bisheng/hmpi25.0.0/hmpi
module load fftw/3.3.8-bisheng4.2.0-hmpi25.0.0
module load wxWidgets/3.0.5-bisheng4.2.0
module load ctffind-clang/4.1.14-bisheng4.2.0
module load libpng/1.6.37-bisheng4.2.0
module load cmake/3.28.2

[APP]
fake = 0
app_name = relion
app_version = 4.0.1
compiler = bisheng+mpi
build_dir = ${JARVIS_APP}/relion/4.0.1-bisheng4.2.0-hmpi25.0.0/project
binary_dir = ${JARVIS_APP}/relion/4.0.1-bisheng4.2.0-hmpi25.0.0
case_dir = ${JARVIS_JOBSCRIPT}/relion/4.0.1

[BUILD]
set -e
source ${JARVIS_LIBSHELL}
set -x
key=$2
bmod="${key#*=}"
BUILD_DIR=$(pwd)
PATH_INSTALL=$1
echo "CURRENT SHELL:$SHELL"


####### build prepare
set +x && echo_info "build prepare!!!" && set -x


install_path=$1
cd ${BUILD_DIR}
build_mod_check "${PATH_INSTALL}/bin/relion_refine_mpi" "prompt"

mymd5=$(md5sum  ${JARVIS_DOWNLOAD}/class_ranker_0.1.3_torch_1.0.1.pt.tar.gz | awk '{print $1}')
if [ $mymd5 != "b39f0cbc31f510e3a03e89f1e11110fe" ]; then
	set +x && echo_error "Invalid package:${JARVIS_DOWNLOAD}/class_ranker_0.1.3_torch_1.0.1.pt.tar.gz, expect md5:b39f0cbc31f510e3a03e89f1e11110fe" && set -x
	exit 1
fi

if true; then 
tar --no-same-owner -zxvf ${JARVIS_DOWNLOAD}/relion-4.0.1.tar.gz
mkdir -p ${BUILD_DIR}/relion-4.0.1/external/torch_models/
cp ${JARVIS_DOWNLOAD}/class_ranker_0.1.3_torch_1.0.1.pt.tar.gz ${BUILD_DIR}/relion-4.0.1/external/torch_models/ -ar
####### build start
set +x && echo_info "build start" && set -x
cd relion-4.0.1

if [ -d "build" ]; then
rm -rf build
fi
mkdir build
cd build

CPUFLAGS="-mcpu=hip09 -mllvm -force-customized-pipeline=true"

export CMAKE_PREFIX_PATH=${LIBPNG_PATH}:${FFTW_PATH}

sed -i '28i\file(ARCHIVE_EXTRACT\nINPUT \${MODELS_DIR}/\${CLASS_RANKER_MODEL_FILE_NAME_TAR}\nDESTINATION \${MODELS_DIR}/class_ranker)\nmessage(STATUS "Untar \${MODELS_DIR}/\${CLASS_RANKER_MODEL_FILE_NAME_TAR} to \${MODELS_DIR}/class_ranker")' ${BUILD_DIR}/relion-4.0.1/cmake/FetchTorchModels.cmake

cmake .. -DCMAKE_INSTALL_PREFIX=${install_path} \
-DCMAKE_CXX_FLAGS="-O3 -Wno-dynamic-exception-spec ${CPUFLAGS} " -DCMAKE_C_FLAGS="-O3 ${CPUFLAGS}" \
-DGUI=OFF -DCUDA=OFF -DBUILD_SHARED_LIBS=OFF -DCMAKE_BUILD_TYPE=release

make -j
make VERBOSE=1
make install

fi
####### build done
set +x && echo_info "build done!!!" && set -x

####### Install jobscript
set +x && echo_info "Install jobscript!!!" && set -x
JOBDIR=${JARVIS_JOBSCRIPT}/relion/4.0.1
mkdir -p ${JOBDIR}
${BUILD_DIR}/env.sh_gen.sh ${JOBDIR}/env.sh
echo "module load relion/4.0.1-bisheng4.2.0-hmpi25.0.0" >> ${JOBDIR}/env.sh


cat > ${JOBDIR}/job_run.sh << EOF
#!/bin/bash
#DSUB -n case_relion
#DSUB --job_type cosched:hmpi
#DSUB -N 1
#DSUB -nn 1
#DSUB -rpn 1
#DSUB -R "cpu=128"
#DSUB -o out_%J.log
#DSUB -e err_%J.log
#DSUB -T '2h'

export HOSTFILE=hostfile.wrf
rm -f \$HOSTFILE
touch \$HOSTFILE
cat \${CCSCHEDULER_ALLOC_FILE} | sort > \$HOSTFILE
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
source ./env.sh
cd relion_benchmark
mkdir -p class3d
{ time -p mpirun --hostfile $HOSTFILE --allow-run-as-root -n 4 --bind-to cpulist:ordered -x OMP_PROC_BIND=close -x OMP_PLACES=cores -x OMP_NUM_THREADS=1 -x UCX_TLS=sm relion_refine_mpi --j 24 --cpu --pool 100 --dont_combine_weights_via_disc --i Particles/shiny_2sets.star --ref emd_2660.map:mrc --firstiter_cc --ini_high 60 --ctf --ctf_corrected_ref --iter 25 --tau2_fudge 4 --particle_diameter 360 --K 6 --flatten_solvent --zero_mask --oversampling 1 --healpix_order 2 --offset_range 5 --offset_step 2 --sym C1 --norm --scale --random_seed 0 --maxsig 500 --fast_subsets --o class3d/test01 ; } 2>&1 | tee tee_out.xlog
EOF

cat >${JOBDIR}/local_run.sh << EOF
#!/bin/bash
source ./env.sh
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
cd relion_benchmark
mkdir -p class3d
{ time -p mpirun --allow-run-as-root -n 4 relion_refine_mpi --j 24 --cpu --pool 100 --dont_combine_weights_via_disc --i Particles/shiny_2sets.star --ref emd_2660.map:mrc --firstiter_cc --ini_high 60 --ctf --ctf_corrected_ref --iter 25 --tau2_fudge 4 --particle_diameter 360 --K 6 --flatten_solvent --zero_mask --oversampling 1 --healpix_order 2 --offset_range 5 --offset_step 2 --sym C1 --norm --scale --random_seed 0 --maxsig 500 --fast_subsets --o class3d/test01 ; } 2>&1 | tee tee_out.xlog
EOF

cat > ${JOBDIR}/relion-4.0.1-run.sh << EOF
#!/bin/bash
source ./env.sh
if [ ! -f relion_benchmark.tar.gz ]; then
	cp ${JARVIS_DOWNLOAD}/relion_benchmark.tar.gz ./ -ar
fi
if [ ! -d relion_benchmark ]; then
tar -zxf relion_benchmark.tar.gz
fi

./local_run.sh
dsub -s job_run.sh
EOF

chmod u+x ${JOBDIR}/env.sh
chmod u+x ${JOBDIR}/job_run.sh
chmod u+x ${JOBDIR}/local_run.sh
chmod u+x ${JOBDIR}/relion-4.0.1-run.sh

set +x && echo_info "Install done!!!" && set -x

[RUN]
