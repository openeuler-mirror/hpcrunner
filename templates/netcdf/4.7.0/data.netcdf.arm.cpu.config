[SERVER]
11.11.11.11

[DOWNLOAD]

[DEPENDENCY]
module purge
./jarvis -install hpckit/${HPCKIT_VERSION} any
module use ./software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles
module add bisheng/compiler${BISHENG_VERSION}/bishengmodule
module add bisheng/hmpi${HPCKIT_VERSION}/release

./jarvis -install hdf5/1.10.1/clang clang+mpi
./jarvis -install pnetcdf/1.11.2 bisheng+mpi

module use ./software/moduledeps/bisheng${BISHENG_VERSION}-hmpi${HPCKIT_VERSION}
module load hdf5-clang/1.10.1 pnetcdf/1.11.2

[ENV]
module purge
./jarvis -install hpckit/${HPCKIT_VERSION} any
module use ./software/utils/hpckit/${HPCKIT_VERSION}/HPCKit/${HPCKIT_VERSION}/modulefiles
module add bisheng/compiler${BISHENG_VERSION}/bishengmodule
module add bisheng/hmpi${HPCKIT_VERSION}/release
module use ./software/moduledeps/bisheng${BISHENG_VERSION}-hmpi${HPCKIT_VERSION}
module load hdf5-clang/1.10.1 pnetcdf/1.11.2

[APP]
app_name = netcdf
build_dir = ${JARVIS_ROOT}
binary_dir = 
case_dir = 

[BUILD]
./jarvis -install netcdf/4.7.0/clang clang+mpi

[RUN]
run = 
binary = 
nodes = 1
